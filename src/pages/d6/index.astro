    .d6-press__k{ font-family:var(--d6-display); font-weight:500; font-size:var(--d6-s-2); color:var(--d6-citron); }
    .d6-press__v{ font-size:0.78rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--d6-cream-soft); }
    @media (max-width:700px){ .d6-press{ grid-template-columns:1fr; } .d6-press li{ border-bottom:1px solid var(--d6-hair-soft); padding-bottom:1.4rem; } }

