    .d6-show__tab:last-of-type{ border-bottom:1px solid var(--d6-hair-soft); }
    .d6-show__tab:hover{ padding-left:8px; background:rgba(201,162,75,.03); }
    .d6-show__tab-name{ font-family:var(--d6-display); font-weight:500; font-size:var(--d6-s-1); color:var(--d6-cream-dim); transition:color var(--d6-t-fast); }
    .d6-show__tab.is-active .d6-show__tab-name{ color:var(--d6-citron); }
    .d6-show__tab-cap{ font-size:0.66rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--d6-cream-soft); }
    .d6-show__tab-note{ font-size:var(--d6-s--1); color:var(--d6-cream-soft); max-height:0; opacity:0; overflow:hidden; transition:max-height var(--d6-t-med) var(--d6-ease), opacity var(--d6-t-med), margin-top var(--d6-t-med); }
    .d6-show__tab.is-active .d6-show__tab-note{ max-height:6rem; opacity:1; margin-top:4px; }
    .d6-show__cta{ margin-top:1.4rem; width:100%; }
    @media (max-width:820px){ .d6-show{ grid-template-columns:1fr; } .d6-show__frame{ aspect-ratio:16/10; } }

    /* ---------- CHARM ---------- */
    .d6-charm{ display:grid; grid-template-columns:0.9fr 1.1fr; gap:clamp(1.6rem, 0.8rem + 3vw, 4rem); align-items:center; }
    .d6-charm__fig .d6-frame{ aspect-ratio:5/6; }
    .d6-charm__title{ font-size:var(--d6-s-3); margin:0.6rem 0 1.2rem; max-width:14ch; }
    .d6-charm__copy p{ margin:0 0 1.1rem; max-width:var(--d6-measure); }
