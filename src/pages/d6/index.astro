  </style>

  <script>
    // events showcase: tab switch (opacity/transform only)
    const tabs = document.querySelectorAll('.d6-show__tab');
    const panels = document.querySelectorAll('.d6-show__panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.getAttribute('data-tab');
        tabs.forEach((t) => { const on = t === tab; t.classList.toggle('is-active', on); t.setAttribute('aria-pressed', String(on)); });
        panels.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-panel') === key));
      });
    });
  </script>
