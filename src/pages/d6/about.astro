---
import D6Base from '../../layouts/D6Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';

import heroImg from '../../assets/img/charles-susan.jpg';
import diningImg from '../../assets/img/main-dining.jpg';
import lakeImg from '../../assets/img/lake.jpg';
import barImg from '../../assets/img/room-bar.jpg';
import wineImg from '../../assets/img/wine.jpg';

const timeline = [
  { yr: '1980s', t: 'Citron Caterers', d: 'The catering house begins its four-decade run serving Baltimore off premise, from home weddings to corporate galas.' },
  { yr: '2016', t: 'A House on the Water', d: 'Charles and Susan Levine open Citron on Quarry Lake, pairing a serious kitchen with a designer sushi bar and a lakefront room.' },
  { yr: '2019', t: 'The Cellar Honored', d: 'The wine program earns its first Wine Spectator Award of Excellence, a distinction held every year since.' },
  { yr: '2026', t: 'Ten Years On', d: 'This November marks a decade on Quarry Lake, roughly fourteen thousand catered events behind us and counting.' },
];

const values = [
  { n: 'I', t: 'Seasonal, honest cooking', d: 'Executive Chef Mary Hersh builds a Modern American card around the season, with a Maryland accent from colossal lump crab to prime steaks.' },
  { n: 'II', t: 'A cellar worth the room', d: 'A Wine Spectator honored list, poured seven years running, chosen to sit beside raw bar, sushi, and steak alike.' },
  { n: 'III', t: 'Family owned', d: 'Charles and Susan Levine host every night as a celebration, the way a family restaurant should feel.' },
];

const title = 'About, Citron Baltimore, Ten Years on Quarry Lake';
const description = 'The Citron Baltimore story: family owned by Charles and Susan Levine since 2016, a Wine Spectator honored cellar, Executive Chef Mary Hersh, and four decades of Citron Caterers in Charm City.';
---
<D6Base title={title} description={description} ogImage="/lake-poster.jpg">
  <!-- ===================== HERO ===================== -->
  <section class="d6-ahero">
    <div class="d6-wrap d6-ahero__inner">
      <div class="d6-ahero__copy">
        <p class="d6-kicker d6-rv">Our Story</p>
        <h1 class="d6-ahero__title d6-rv" data-delay="1">A little glamour, ten years on the water.</h1>
        <p class="d6-ahero__lead d6-rv" data-delay="2">
          Citron began as a Charm City catering house and became a waterfront restaurant that treats every night
          like an occasion. Family owned by Charles and Susan Levine, cooked by Executive Chef Mary Hersh, and set
          on Quarry Lake in Baltimore County.
        </p>
        <div class="d6-ahero__cta d6-rv" data-delay="3">
          <button class="d6-btn d6-btn--solid" data-cta>Reserve a Table</button>
          <a class="d6-btn d6-btn--ghost" href="/d6/events">Plan an Event</a>
        </div>
      </div>
      <div class="d6-ahero__figure d6-rv" data-delay="2">
        <div class="d6-frame d6-ahero__frame">
          <Image src={heroImg} alt="Charles and Susan Levine, owners of Citron Baltimore" widths={[500, 800]} sizes="(max-width:860px) 90vw, 42vw" loading="eager" fetchpriority="high" format="avif" quality={58} />
        </div>
        <span class="d6-ahero__cap">Charles &amp; Susan Levine, Owners</span>
      </div>
    </div>
    <div class="d6-hero__hr" aria-hidden="true"></div>
  </section>

  <!-- ===================== NARRATIVE ===================== -->
  <section class="d6-section">
    <div class="d6-wrap">
      <div class="d6-narr">
        <div class="d6-narr__figs">
          <div class="d6-frame d6-narr__fig d6-narr__fig--a d6-rv">
            <Image src={diningImg} alt="The main dining room at Citron overlooking the lake" widths={[500, 800]} sizes="(max-width:820px) 90vw, 44vw" loading="lazy" format="avif" quality={52} />
          </div>
          <div class="d6-frame d6-narr__fig d6-narr__fig--b d6-rv" data-delay="2">
            <Image src={lakeImg} alt="Quarry Lake at golden hour" widths={[320, 500]} sizes="(max-width:820px) 50vw, 22vw" loading="lazy" format="avif" quality={52} />
          </div>
        </div>
        <div class="d6-narr__copy d6-rv" data-delay="1">
          <p class="d6-kicker">The House on Quarry Lake</p>
          <h2 class="d6-narr__title">Built for celebration, kept honest by the season.</h2>
          <p>
            When the Levines opened Citron in 2016, they brought four decades of catering instinct into a room on the
            water: put a serious kitchen, a full designer sushi bar, and an award-winning cellar where the lake sets
            the mood, and let every dinner feel like an event.
          </p>
          <p>
            The menu is seasonal Modern American with a Maryland heart, colossal lump crab, center-cut fish, prime
            steaks, and a raw bar that anchors the night. Behind it all, Citron Caterers still carries the house across
            Baltimore, from intimate dinners to five-hundred-guest galas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TIMELINE ===================== -->
  <section class="d6-section d6-section--tint">
    <div class="d6-wrap">
      <div class="d6-sechead d6-rv">
        <p class="d6-kicker">A Short History</p>
        <h2 class="d6-sechead__title">Four decades, one table.</h2>
      </div>
      <ol class="d6-time">
        {timeline.map((e, i) => (
          <li class="d6-time__item d6-rv" data-delay={(i % 3) + 1}>
            <span class="d6-time__yr">{e.yr}</span>
            <span class="d6-time__dot" aria-hidden="true"></span>
            <div class="d6-time__body">
              <h3 class="d6-time__t">{e.t}</h3>
              <p class="d6-time__d">{e.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===================== VALUES ===================== -->
  <section class="d6-section">
    <div class="d6-wrap">
      <div class="d6-sechead d6-rv">
        <p class="d6-kicker">What We Hold To</p>
        <h2 class="d6-sechead__title">Three things, kept simple.</h2>
      </div>
      <div class="d6-vals">
        {values.map((v, i) => (
          <article class="d6-val d6-rv" data-delay={i + 1}>
            <span class="d6-val__no" aria-hidden="true">{v.n}</span>
            <h3 class="d6-val__t">{v.t}</h3>
            <p class="d6-val__d">{v.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== BANNER STATS ===================== -->
  <section class="d6-section d6-section--deep">
    <div class="d6-wrap">
      <div class="d6-abstats">
        <div class="d6-frame d6-abstats__fig d6-rv">
          <Image src={barImg} alt="The bar and sushi counter at Citron" widths={[400, 640]} sizes="(max-width:820px) 90vw, 30vw" loading="lazy" format="avif" quality={52} />
        </div>
        <ul class="d6-abstats__nums">
          <li class="d6-rv"><span class="d6-stat__n" data-count="2016">2016</span><span class="d6-stat__l">Opened on Quarry Lake</span></li>
          <li class="d6-rv" data-delay="1"><span class="d6-stat__n" data-count="14000">14,000</span><span class="d6-stat__l">Events catered over 40 years</span></li>
          <li class="d6-rv" data-delay="2"><span class="d6-stat__n" data-count="300">300</span><span class="d6-stat__l">Seats overlooking the water</span></li>
          <li class="d6-rv" data-delay="3"><span class="d6-stat__n">2019–2025</span><span class="d6-stat__l">Wine Spectator, seven years</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="d6-section d6-acta">
    <div class="d6-acta__fig" aria-hidden="true">
      <div class="d6-frame">
        <Image src={wineImg} alt="" widths={[600, 900]} sizes="100vw" loading="lazy" format="avif" quality={44} />
      </div>
    </div>
    <div class="d6-wrap d6-acta__inner">
      <p class="d6-kicker d6-kicker--center d6-rv">Join us on the water</p>
      <h2 class="d6-acta__title d6-rv" data-delay="1">Come see what ten years built.</h2>
      <div class="d6-acta__row d6-rv" data-delay="2">
        <button class="d6-btn d6-btn--solid" data-cta>Reserve a Table</button>
        <a class="d6-btn d6-btn--ghost" href="/d6/contact">Contact Us</a>
      </div>
    </div>
  </section>

  <style>
    .d6-ahero{ padding-top:clamp(2.4rem, 1.4rem + 4vw, 4.6rem); }
    .d6-ahero__inner{ display:grid; grid-template-columns:1.1fr 0.9fr; gap:clamp(1.6rem, 0.8rem + 3vw, 4rem); align-items:center; }
    .d6-ahero__title{ font-size:var(--d6-s-4); max-width:15ch; margin:0.7rem 0 0; }
    .d6-ahero__lead{ margin:1.3rem 0 0; max-width:52ch; font-size:var(--d6-s-1); font-weight:300; color:var(--d6-cream-dim); }
    .d6-ahero__cta{ display:flex; flex-wrap:wrap; gap:14px; margin-top:1.8rem; }
    .d6-ahero__figure{ position:relative; }
    .d6-ahero__frame{ aspect-ratio:4/5; }
    .d6-ahero__cap{ display:block; margin-top:0.9rem; text-align:center; font-size:0.7rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--d6-citron); }
    @media (max-width:860px){ .d6-ahero__inner{ grid-template-columns:1fr; } .d6-ahero__figure{ max-width:400px; } }

    .d6-narr{ display:grid; grid-template-columns:0.95fr 1.05fr; gap:clamp(1.6rem, 0.8rem + 3vw, 4rem); align-items:center; }
    .d6-narr__figs{ position:relative; }
    .d6-narr__fig--a{ aspect-ratio:4/5; }
    .d6-narr__fig--b{ position:absolute; right:-6%; bottom:-12%; width:52%; aspect-ratio:1/1; border:2px solid var(--d6-panel); }
    .d6-narr__title{ font-size:var(--d6-s-3); margin:0.6rem 0 1.2rem; max-width:16ch; }
    .d6-narr__copy p{ max-width:var(--d6-measure); margin:0 0 1.2rem; }
    @media (max-width:820px){ .d6-narr{ grid-template-columns:1fr; } .d6-narr__figs{ max-width:440px; margin-bottom:2.6rem; } }

    .d6-time{ display:grid; grid-template-columns:repeat(4, 1fr); gap:0; counter-reset:t; }
    .d6-time__item{ position:relative; padding:2.4rem 1.2rem 0; display:flex; flex-direction:column; gap:0.6rem; border-top:1px solid var(--d6-hair); }
    .d6-time__yr{ font-family:var(--d6-display); font-weight:500; font-size:var(--d6-s-2); color:var(--d6-citron); }
    .d6-time__dot{ position:absolute; top:-6px; left:1.2rem; width:11px; height:11px; background:var(--d6-brass); transform:rotate(45deg); }
    .d6-time__t{ font-size:var(--d6-s-1); color:var(--d6-cream); }
    .d6-time__d{ font-size:var(--d6-s--1); color:var(--d6-cream-soft); max-width:34ch; }
    @media (max-width:820px){ .d6-time{ grid-template-columns:1fr 1fr; } }
    @media (max-width:520px){ .d6-time{ grid-template-columns:1fr; } }

    .d6-vals{ display:grid; grid-template-columns:repeat(3, 1fr); gap:clamp(1rem, 0.6rem + 1.5vw, 1.8rem); }
    .d6-val{ padding:clamp(1.6rem, 1rem + 2vw, 2.4rem); border:1px solid var(--d6-hair); transition:border-color var(--d6-t-med), background var(--d6-t-med), transform var(--d6-t-med) var(--d6-ease); }
    .d6-val:hover{ border-color:var(--d6-citron); background:var(--d6-citron-tint); transform:translateY(-4px); }
    .d6-val__no{ font-family:var(--d6-display); font-size:1.4rem; color:var(--d6-brass); letter-spacing:0.08em; }
    .d6-val__t{ font-size:var(--d6-s-1); margin:0.5rem 0 0.7rem; }
    .d6-val__d{ font-size:var(--d6-s--1); color:var(--d6-cream-dim); }
    @media (max-width:760px){ .d6-vals{ grid-template-columns:1fr; } }

    .d6-abstats{ display:grid; grid-template-columns:0.8fr 1.2fr; gap:clamp(1.6rem, 0.8rem + 3vw, 3.6rem); align-items:center; }
    .d6-abstats__fig{ aspect-ratio:4/5; }
    .d6-abstats__nums{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(1.4rem, 0.8rem + 2vw, 2.6rem); }
    .d6-abstats__nums li{ display:flex; flex-direction:column; border-left:1px solid var(--d6-hair); padding-left:1.2rem; }
    @media (max-width:820px){ .d6-abstats{ grid-template-columns:1fr; } .d6-abstats__fig{ max-width:320px; aspect-ratio:4/3; } }

    .d6-acta{ position:relative; overflow:hidden; text-align:center; }
    .d6-acta__fig{ position:absolute; inset:0; opacity:.16; }
    .d6-acta__fig .d6-frame{ height:100%; }
    .d6-acta__fig .d6-frame::after{ display:none; }
    .d6-acta__inner{ position:relative; z-index:1; display:flex; flex-direction:column; align-items:center; gap:1rem; }
    .d6-acta__title{ font-size:var(--d6-s-4); max-width:16ch; }
    .d6-acta__row{ display:flex; flex-wrap:wrap; justify-content:center; gap:14px; margin-top:0.6rem; }
  </style>
</D6Base>
