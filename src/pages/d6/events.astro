---
import D6Base from '../../layouts/D6Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';

import heroImg from '../../assets/img/cove-gala.jpg';
import coveWed from '../../assets/img/cove-wedding.jpg';
import courtyard from '../../assets/img/courtyard-lakefront.jpg';
import terrace from '../../assets/img/terrace-event.jpg';
import bar from '../../assets/img/bar-pdr.jpg';
import offprem from '../../assets/img/room-offpremise.jpg';
import alfresco from '../../assets/img/alfresco.jpg';

const spaces = [
  {
    n: 'I', name: 'The Cove', cap: '150–500 guests', img: coveWed,
    alt: 'A wedding reception set in The Cove ballroom',
    desc: 'Our grand ballroom and its lakeside terrace, dressed for weddings, galas, and milestone celebrations. Floor-to-ceiling water views and room to dance until the last song.',
    tags: ['Weddings', 'Galas', 'Dancing'],
  },
  {
    n: 'II', name: 'The Lakefront Courtyard', cap: '40–120 guests', img: courtyard,
    alt: 'Lakefront courtyard arranged for an outdoor gathering',
    desc: 'Alfresco dining on the water under open sky and string light. A favorite for cocktail receptions, rehearsal dinners, and warm-weather celebrations.',
    tags: ['Alfresco', 'Receptions', 'Cocktails'],
  },
  {
    n: 'III', name: 'The Terrace', cap: '20–80 guests', img: terrace,
    alt: 'Terrace event overlooking Quarry Lake at dusk',
    desc: 'An intimate waterside terrace for toasts, showers, and dinners that want the lake close. Golden-hour views as the evening settles in.',
    tags: ['Intimate', 'Toasts', 'Showers'],
  },
  {
    n: 'IV', name: 'The Private Dining Room', cap: '10–40 guests', img: bar,
    alt: 'A private dining room and bar for a small gathering',
    desc: 'A handsome room off the main floor for board dinners, birthdays, and wine dinners. Full service from the same kitchen and cellar as the restaurant.',
    tags: ['Business', 'Wine Dinners', 'Birthdays'],
  },
];

const title = 'Events & Private Dining, Citron Baltimore, The Cove at Quarry Lake';
const description = 'Host from 10 to 500 guests on Quarry Lake. The Cove ballroom, lakefront courtyard, terrace, and private dining, plus Citron Caterers for off-premise events across Baltimore.';
---
<D6Base title={title} description={description} ogImage="/lake-poster.jpg">
  <!-- ===================== HERO ===================== -->
  <section class="d6-ehero">
    <div class="d6-frame d6-ehero__bg">
      <Image src={heroImg} alt="A gala set for dinner in The Cove at Citron Baltimore" widths={[900, 1300, 1500]} sizes="100vw" loading="eager" fetchpriority="high" format="avif" quality={50} />
    </div>
    <div class="d6-wrap d6-ehero__inner">
      <p class="d6-kicker d6-rv">Events &amp; Private Dining</p>
      <h1 class="d6-ehero__title d6-rv" data-delay="1">From ten to five hundred, on the water.</h1>
      <p class="d6-ehero__lead d6-rv" data-delay="2">
        Weddings, galas, corporate dinners, and celebrations of every size, hosted in the grand rooms of Citron
        or carried to your address by Citron Caterers.
      </p>
      <div class="d6-ehero__cta d6-rv" data-delay="3">
        <a class="d6-btn d6-btn--solid" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <a class="d6-btn d6-btn--ghost" href={`mailto:${SITE.email}`}>Email Our Events Team</a>
      </div>
    </div>
  </section>

  <!-- ===================== INTRO STRIP ===================== -->
  <section class="d6-section d6-section--tint">
    <div class="d6-wrap">
      <div class="d6-estat">
        <div class="d6-estat__lead d6-rv">
          <p class="d6-kicker">One Portal, Every Occasion</p>
          <h2 class="d6-estat__title">Four marquee settings, and a caterer with forty years of range.</h2>
        </div>
        <ul class="d6-estat__nums">
          <li class="d6-rv" data-delay="1"><span class="d6-stat__n" data-count="500">500</span><span class="d6-stat__l">Guests at capacity</span></li>
          <li class="d6-rv" data-delay="2"><span class="d6-stat__n" data-count="14000">14,000</span><span class="d6-stat__l">Events over 40 years</span></li>
          <li class="d6-rv" data-delay="3"><span class="d6-stat__n">7 days</span><span class="d6-stat__l">Private events, weekly</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== SPACES ===================== -->
  <section class="d6-section">
    <div class="d6-wrap">
      <div class="d6-sechead d6-rv">
        <p class="d6-kicker">The Spaces</p>
        <h2 class="d6-sechead__title">A room for every celebration.</h2>
        <p class="d6-sechead__lead">A few of our marquee settings. The full inventory of nine spaces, floor plans, and dates lives in the planning portal.</p>
      </div>

      <div class="d6-spaces">
        {spaces.map((s, i) => (
          <article class:list={["d6-space d6-rv", { 'is-rev': i % 2 === 1 }]}>
            <div class="d6-frame d6-space__fig">
              <Image src={s.img} alt={s.alt} widths={[500, 800]} sizes="(max-width:820px) 92vw, 48vw" loading="lazy" format="avif" quality={50} />
            </div>
            <div class="d6-space__body">
              <span class="d6-space__no" aria-hidden="true">{s.n}</span>
              <h3 class="d6-space__name">{s.name}</h3>
              <p class="d6-space__cap">{s.cap}</p>
              <p class="d6-space__desc">{s.desc}</p>
              <ul class="d6-space__tags">
                {s.tags.map((t) => (<li>{t}</li>))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CATERING ===================== -->
  <section class="d6-section d6-section--deep">
    <div class="d6-wrap">
      <div class="d6-cater">
        <div class="d6-cater__figs">
          <div class="d6-frame d6-cater__fig d6-cater__fig--a d6-rv">
            <Image src={offprem} alt="An off-premise catering table by Citron Caterers" widths={[400, 640]} sizes="(max-width:820px) 60vw, 26vw" loading="lazy" format="avif" quality={50} />
          </div>
          <div class="d6-frame d6-cater__fig d6-cater__fig--b d6-rv" data-delay="2">
            <Image src={alfresco} alt="An alfresco catered gathering on the water" widths={[400, 640]} sizes="(max-width:820px) 60vw, 26vw" loading="lazy" format="avif" quality={50} />
          </div>
        </div>
        <div class="d6-cater__copy d6-rv" data-delay="1">
          <p class="d6-kicker">Citron Caterers</p>
          <h2 class="d6-cater__title">Off premise, and unmistakably Citron.</h2>
          <p>
            For four decades our catering house has served Charm City beyond the lake: home weddings, corporate galas,
            and everything in between, roughly fourteen thousand events and counting. We build PhRMA-compliant menus for
            corporate clients and full-service celebrations at your address.
          </p>
          <ul class="d6-cater__list">
            <li>Full-service off-premise catering across Baltimore</li>
            <li>Weddings, corporate, and private celebrations</li>
            <li>PhRMA-compliant corporate menus</li>
            <li>The same kitchen and cellar behind the restaurant</li>
          </ul>
          <a class="d6-btn d6-btn--solid" href={SITE.portalUrl}>Plan Catering</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section class="d6-section d6-ecta">
    <div class="d6-wrap d6-ecta__inner">
      <div class="d6-div d6-rv"><span class="d6-div__gem"></span></div>
      <p class="d6-kicker d6-kicker--center d6-rv">Let us host you</p>
      <h2 class="d6-ecta__title d6-rv" data-delay="1">Begin your event on Quarry Lake.</h2>
      <p class="d6-ecta__lead d6-rv" data-delay="2">Open the planning portal to check dates, capacities, and menus, or reach our events team directly.</p>
      <div class="d6-ecta__row d6-rv" data-delay="3">
        <a class="d6-btn d6-btn--solid" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <a class="d6-btn d6-btn--ghost" href={SITE.phoneHref}>{SITE.phone}</a>
      </div>
    </div>
  </section>

  <style>
    .d6-ehero{ position:relative; min-height:clamp(420px, 62vh, 640px); display:flex; align-items:flex-end; overflow:hidden; }
    .d6-ehero__bg{ position:absolute; inset:0; }
    .d6-ehero__bg::after{ inset:0; }
    .d6-ehero__bg::before{ background:linear-gradient(180deg, rgba(9,17,16,.35) 0%, rgba(9,17,16,.55) 45%, rgba(9,17,16,.94) 100%); }
    .d6-ehero__inner{ position:relative; z-index:2; padding-block:clamp(2.4rem, 1.4rem + 4vw, 4.4rem); }
    .d6-ehero__title{ font-size:var(--d6-s-4); max-width:16ch; margin:0.8rem 0 0; }
    .d6-ehero__lead{ max-width:54ch; margin:1.2rem 0 0; color:var(--d6-cream-dim); font-size:var(--d6-s-1); font-weight:300; }
    .d6-ehero__cta{ display:flex; flex-wrap:wrap; gap:14px; margin-top:1.8rem; }

    .d6-estat{ display:grid; grid-template-columns:1.3fr 1fr; gap:clamp(1.6rem, 0.8rem + 3vw, 3.6rem); align-items:center; }
    .d6-estat__title{ font-size:var(--d6-s-2); margin-top:0.7rem; max-width:20ch; }
    .d6-estat__nums{ display:flex; flex-direction:column; gap:1.3rem; border-left:1px solid var(--d6-hair); padding-left:clamp(1.2rem, 0.8rem + 1.5vw, 2.2rem); }
    .d6-estat__nums li{ display:flex; flex-direction:column; }
    @media (max-width:820px){ .d6-estat{ grid-template-columns:1fr; } .d6-estat__nums{ border-left:none; padding-left:0; border-top:1px solid var(--d6-hair); padding-top:1.6rem; } }

    .d6-spaces{ display:flex; flex-direction:column; gap:clamp(2.4rem, 1.4rem + 4vw, 4.8rem); }
    .d6-space{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(1.4rem, 0.8rem + 2.5vw, 3.4rem); align-items:center; }
    .d6-space.is-rev .d6-space__fig{ order:2; }
    .d6-space__fig{ aspect-ratio:5/4; }
    .d6-space__no{ font-family:var(--d6-display); font-size:1.4rem; color:var(--d6-brass); letter-spacing:0.08em; }
    .d6-space__name{ font-size:var(--d6-s-3); margin:0.3rem 0 0.4rem; }
    .d6-space__cap{ font-size:0.72rem; letter-spacing:0.24em; text-transform:uppercase; color:var(--d6-citron); margin:0 0 1rem; }
    .d6-space__desc{ max-width:52ch; margin:0 0 1.2rem; }
    .d6-space__tags{ display:flex; flex-wrap:wrap; gap:8px; }
    .d6-space__tags li{ font-size:0.66rem; letter-spacing:0.16em; text-transform:uppercase; color:var(--d6-cream-dim); border:1px solid var(--d6-hair); padding:6px 12px; }
    @media (max-width:820px){ .d6-space{ grid-template-columns:1fr; } .d6-space.is-rev .d6-space__fig{ order:0; } }

    .d6-cater{ display:grid; grid-template-columns:0.95fr 1.05fr; gap:clamp(1.6rem, 0.8rem + 3vw, 4rem); align-items:center; }
    .d6-cater__figs{ position:relative; display:grid; grid-template-columns:1fr 1fr; gap:14px; }
    .d6-cater__fig{ aspect-ratio:3/4; }
    .d6-cater__fig--b{ margin-top:2.6rem; }
    .d6-cater__title{ font-size:var(--d6-s-3); margin:0.6rem 0 1.1rem; max-width:16ch; }
    .d6-cater__copy p{ max-width:var(--d6-measure); margin:0 0 1.3rem; }
    .d6-cater__list{ display:flex; flex-direction:column; gap:0.7rem; margin:0 0 1.8rem; }
    .d6-cater__list li{ position:relative; padding-left:1.6rem; font-size:var(--d6-s--1); color:var(--d6-cream-dim); }
    .d6-cater__list li::before{ content:""; position:absolute; left:0; top:0.55em; width:8px; height:8px; border:1px solid var(--d6-brass); transform:rotate(45deg); }
    @media (max-width:820px){ .d6-cater{ grid-template-columns:1fr; } .d6-cater__figs{ max-width:440px; } }

    .d6-ecta__inner{ text-align:center; display:flex; flex-direction:column; align-items:center; gap:1rem; }
    .d6-ecta .d6-div{ margin-bottom:0.4rem; }
    .d6-ecta__title{ font-size:var(--d6-s-4); max-width:16ch; }
    .d6-ecta__lead{ max-width:54ch; color:var(--d6-cream-dim); }
    .d6-ecta__row{ display:flex; flex-wrap:wrap; justify-content:center; gap:14px; margin-top:0.6rem; }
  </style>
</D6Base>
