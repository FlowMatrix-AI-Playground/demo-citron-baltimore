---
// Portal 1, "The Concierge": a split-screen event-planning checkout.
// Self-contained page (own head, nav, footer). Shared tokens + self-hosted
// fonts come from the read-only global stylesheet; nothing shared is modified.
import '../../styles/global.css';
import { Image } from 'astro:assets';
import { SPACES, VENDORS, bookCall } from '../../data/spaces.js';
import { SITE } from '../../data/site.js';

// Eagerly resolve every room image so we can look each one up by filename.
const imgModules = import.meta.glob('../../assets/img/*.jpg', { eager: true });
const imgFor = (file) => imgModules[`../../assets/img/${file}`].default;

const capLabel = (cap) =>
  typeof cap === 'number' ? `Up to ${cap} guests` : 'Any scale, off site';

const title = 'Plan Your Event · The Concierge · Citron Baltimore';
const description =
  'Build your Citron Baltimore event in real time. Explore all nine waterfront spaces at Quarry Lake, add the services you need, and send a prefilled inquiry to our events team.';
const canonical = new URL('/portals/1', SITE ? 'https://citronbaltimore.com' : undefined);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#0B1210" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Citron Baltimore" />
  <meta property="og:image" content="https://citronbaltimore.com/lake-poster.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Restaurant",
    "name": "Citron Baltimore",
    "servesCuisine": "Modern American",
    "priceRange": "$$$",
    "telephone": SITE.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "2605 Quarry Lake Dr",
      "addressLocality": "Baltimore",
      "addressRegion": "MD",
      "postalCode": "21209"
    },
    "url": "https://citronbaltimore.com",
    "acceptsReservations": "True"
  })} />
</head>
<body class="portal-page">
  <a class="skip" href="#explorer">Skip to spaces</a>

  <!-- Slim portal nav -->
  <header class="p-nav">
    <div class="p-nav__inner">
      <a class="p-nav__logo" href="/">
        <span class="p-nav__mark">Citron</span>
        <span class="p-nav__sub">Concierge</span>
      </a>
      <nav class="p-nav__actions" aria-label="Portal">
        <a class="p-link" href="/">
          <span aria-hidden="true">&larr;</span> Back to site
        </a>
        <a class="btn btn--ghost p-reserve" href={SITE.reserveUrl} target="_blank" rel="noopener">
          Reserve a table
        </a>
      </nav>
    </div>
  </header>

  <main id="main">
    <!-- Intro -->
    <section class="p-head">
      <div class="p-head__inner">
        <p class="eyebrow">The Concierge</p>
        <h1 class="p-head__title">Design your night on the water.</h1>
        <p class="p-head__lead measure">
          Explore all nine Citron spaces, from a twenty-seat fireside table to a full
          five-hundred-guest buyout. Add the rooms and services you are picturing,
          tell us your date and headcount, and we will build the rest of the plan with you.
        </p>
      </div>
    </section>

    <!-- Split-screen: explorer + sticky rail -->
    <div class="portal">
      <section class="explorer" id="explorer" aria-label="Event spaces">
        {SPACES.map((space, i) => (
          <article class="card reveal">
            <div class="card__media">
              <Image
                src={imgFor(space.img)}
                alt={`The ${space.name} at Citron Baltimore`}
                width={640}
                height={427}
                quality={52}
                format="avif"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
                sizes="(max-width: 900px) 92vw, 40vw"
              />
              <span class="cap-chip">{capLabel(space.cap)}</span>
            </div>

            <div class="card__body">
              <h2 class="card__title">{space.name}</h2>
              <p class="card__desc">{space.desc}</p>

              <dl class="breakdown">
                <div class="breakdown__row">
                  <dt>Best for</dt>
                  <dd>{space.best}</dd>
                </div>
                <div class="breakdown__row">
                  <dt>Layout</dt>
                  <dd>{space.layout}</dd>
                </div>
                <div class="breakdown__row">
                  <dt>Catering</dt>
                  <dd>{space.cater}</dd>
                </div>
              </dl>

              <div class="qs">
                <p class="qs__label">A few things we will ask</p>
                <ul class="qs__list">
                  {space.q.map((question) => <li>{question}</li>)}
                </ul>
              </div>

              <div class="card__actions">
                <button
                  type="button"
                  class="btn btn--add"
                  data-add={space.key}
                  data-name={space.name}
                  data-caplabel={capLabel(space.cap)}
                  aria-pressed="false"
                >
                  <span class="btn__add-label">Add to my event</span>
                  <span class="btn__added-label" aria-hidden="true">Added</span>
                </button>
                <a class="p-link p-link--call" href={bookCall(space.name)}>
                  Book a call
                </a>
              </div>
            </div>
          </article>
        ))}
      </section>

      <!-- Sticky summary rail (becomes a bottom sheet on mobile) -->
      <aside class="rail" id="rail" aria-label="Your event summary">
        <div class="rail__scroll">
          <div class="rail__head">
            <p class="eyebrow eyebrow--brass">Your event</p>
            <button type="button" class="rail__close" data-rail-close aria-label="Close summary">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true">
                <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
              </svg>
            </button>
          </div>

          <p class="rail__summary" id="rail-summary" aria-live="polite">Nothing added yet.</p>

          <div class="rail__group">
            <h2 class="rail__h">Spaces</h2>
            <p class="rail__empty" id="rail-empty">
              Add a space from the left to begin your plan.
            </p>
            <ul class="chosen" id="rail-spaces"></ul>
          </div>

          <div class="rail__group">
            <h2 class="rail__h">Add-on services</h2>
            <fieldset class="vendors">
              <legend class="sr-only">Select the services you would like</legend>
              {VENDORS.map((vendor, i) => (
                <label class="vendor">
                  <input type="checkbox" class="vendor__box" value={vendor.name} id={`vendor-${i}`} />
                  <span class="vendor__text">
                    <span class="vendor__name">{vendor.name}</span>
                    <span class="vendor__note">{vendor.note}</span>
                  </span>
                </label>
              ))}
            </fieldset>
          </div>

          <div class="rail__group">
            <h2 class="rail__h">The details</h2>
            <div class="field">
              <label for="f-guests">Estimated guests</label>
              <input type="number" id="f-guests" name="guests" min="1" max="500" inputmode="numeric" placeholder="e.g. 120" />
            </div>
            <div class="field">
              <label for="f-date">Preferred date</label>
              <input type="date" id="f-date" name="date" />
            </div>
            <div class="field">
              <label for="f-name">Your name (optional)</label>
              <input type="text" id="f-name" name="name" autocomplete="name" placeholder="Who should we ask for?" />
            </div>
          </div>

          <div class="rail__foot">
            <a class="btn rail__book" id="book" href={`mailto:${SITE.email}`} data-email={SITE.email}>
              Book a call
            </a>
            <p class="rail__note">
              Opens your email with the plan prefilled. Prefer to talk now?
              <a class="p-link" href={SITE.phoneHref}>{SITE.phone}</a>.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </main>

  <!-- Mobile scrim + bottom bar -->
  <div class="rail-scrim" data-rail-close hidden></div>
  <div class="mbar" id="mbar" hidden>
    <p class="mbar__sum" id="mbar-sum">No spaces added yet</p>
    <button type="button" class="btn mbar__btn" id="mbar-open" aria-expanded="false" aria-controls="rail">
      Review event <span class="mbar__count" id="mbar-count" hidden>0</span>
    </button>
  </div>

  <!-- Schedule-a-call modal (pop-up Google Calendar appointment embed) -->
  <div class="cal-modal" id="cal-modal" hidden>
    <div class="cal-modal__overlay" data-cal-close></div>
    <div
      class="cal-modal__dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="cal-modal-title"
      aria-describedby="cal-modal-desc"
    >
      <div class="cal-modal__head">
        <div class="cal-modal__intro">
          <p class="eyebrow eyebrow--brass">Final step</p>
          <h2 class="cal-modal__title" id="cal-modal-title">Schedule your call</h2>
          <p class="cal-modal__desc" id="cal-modal-desc">
            Pick a time that works for you and our events team will meet you on the water.
            We will have your plan in hand.
          </p>
        </div>
        <button type="button" class="cal-modal__close" data-cal-close aria-label="Close scheduler">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
          </svg>
        </button>
      </div>

      <div class="cal-modal__body">
        <div class="cal-skeleton" id="cal-skeleton">
          <span class="cal-skeleton__spinner" aria-hidden="true"></span>
          <span class="cal-skeleton__text">Loading the scheduler&hellip;</span>
        </div>
        <!-- Iframe is injected here by JS only when the modal opens, so no third-party -->
        <!-- request fires on initial page load (protects mobile Lighthouse / TBT). -->
        <!-- TODO: Temporary live Google Calendar appointment schedule (swap the /schedules/<id> to change it) -->
        <div class="cal-embed" id="cal-embed"></div>
      </div>

      <p class="cal-modal__fallback">
        Prefer email?
        <a class="p-link" id="cal-mailto" href={`mailto:${SITE.email}`}>Email us instead</a>.
      </p>
    </div>
  </div>

  <!-- Footer -->
  <footer class="p-foot">
    <div class="p-foot__inner">
      <div class="p-foot__brand">
        <p class="p-foot__logo">Citron</p>
        <p class="p-foot__tag">{SITE.tagline}.</p>
      </div>
      <address class="p-foot__meta">
        <p>{SITE.address}</p>
        <p>
          <a class="p-link" href={SITE.phoneHref}>{SITE.phone}</a>
          <span aria-hidden="true"> · </span>
          <a class="p-link" href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>
      </address>
      <div class="p-foot__links">
        <a class="p-link" href={SITE.reserveUrl} target="_blank" rel="noopener">Reservations</a>
        <a class="p-link" href={SITE.pickupUrl} target="_blank" rel="noopener">Order pick-up</a>
        <a class="p-link" href="/">Main site</a>
      </div>
    </div>
    <p class="p-foot__fine">Waterfront dining, catering &amp; events at Quarry Lake. Est. 2016.</p>
  </footer>

  <style>
    /* ============ Portal 1 · The Concierge ============ */
    .portal-page{ background:var(--abyss); }
    .sr-only{
      position:absolute; width:1px; height:1px; padding:0; margin:-1px;
      overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0;
    }

    /* ---- Nav ---- */
    .p-nav{
      position:sticky; top:0; z-index:60;
      background:color-mix(in oklab, var(--abyss) 82%, transparent);
      backdrop-filter:blur(10px);
      border-bottom:1px solid var(--hair);
    }
    .p-nav__inner{
      max-width:var(--maxw); margin-inline:auto;
      padding:0.85rem var(--gutter);
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
    }
    .p-nav__logo{ display:flex; align-items:baseline; gap:0.55rem; }
    .p-nav__mark{ font-family:var(--serif); font-size:var(--step-1); color:var(--cream); letter-spacing:0.01em; }
    .p-nav__sub{
      font-family:var(--sans); font-size:var(--step--1); font-weight:700;
      text-transform:uppercase; letter-spacing:0.24em; color:var(--brass-light);
    }
    .p-nav__actions{ display:flex; align-items:center; gap:clamp(0.75rem, 0.4rem + 1.5vw, 1.5rem); }
    .p-reserve{ min-height:44px; }

    .p-link{
      font-size:var(--step--1); color:var(--mist); letter-spacing:0.04em;
      border-bottom:1px solid transparent; transition:color var(--t-fast), border-color var(--t-fast);
    }
    .p-link:hover{ color:var(--citron); border-color:color-mix(in oklab, var(--citron) 60%, transparent); }
    .p-link--call{ color:var(--brass-light); font-weight:700; }

    /* ---- Intro ---- */
    .p-head{ padding-block:clamp(2.5rem, 1.6rem + 4vw, 4.5rem); }
    .p-head__inner{ max-width:var(--maxw); margin-inline:auto; padding-inline:var(--gutter); }
    .p-head__title{ font-size:var(--step-3); margin-top:0.6rem; max-width:16ch; }
    .p-head__lead{ margin-top:1.2rem; color:var(--mist-dim); font-size:var(--step-0); }

    /* ---- Split layout ---- */
    .portal{
      max-width:var(--maxw); margin-inline:auto; padding-inline:var(--gutter);
      padding-bottom:clamp(4rem, 3rem + 6vw, 7rem);
      display:grid; gap:clamp(1.5rem, 1rem + 2vw, 2.5rem);
      grid-template-columns:minmax(0, 1fr) clamp(320px, 30vw, 400px);
      align-items:start;
    }

    /* ---- Explorer cards ---- */
    .explorer{
      display:grid; gap:clamp(1.1rem, 0.7rem + 1.5vw, 1.75rem);
      grid-template-columns:repeat(auto-fill, minmax(280px, 1fr));
    }
    .card{
      display:flex; flex-direction:column;
      background:linear-gradient(180deg, var(--night) 0%, var(--abyss-2) 100%);
      border:1px solid var(--hair); border-radius:8px; overflow:hidden;
      transition:border-color var(--t-med) var(--ease), transform var(--t-med) var(--ease);
    }
    .card:hover{ border-color:var(--hair-strong); transform:translateY(-3px); }
    .card__media{ position:relative; aspect-ratio:3 / 2; overflow:hidden; }
    .card__media img{ width:100%; height:100%; object-fit:cover; }
    .cap-chip{
      position:absolute; left:12px; bottom:12px;
      background:color-mix(in oklab, var(--abyss) 78%, transparent);
      backdrop-filter:blur(4px);
      color:var(--citron); border:1px solid color-mix(in oklab, var(--citron) 40%, transparent);
      font-family:var(--sans); font-weight:700; font-size:0.72rem;
      letter-spacing:0.1em; text-transform:uppercase;
      padding:0.35rem 0.7rem; border-radius:999px;
    }
    .card__body{ display:flex; flex-direction:column; gap:1rem; padding:clamp(1.1rem, 0.8rem + 1vw, 1.5rem); }
    .card__title{ font-size:var(--step-2); }
    .card__desc{ color:var(--mist-dim); font-size:var(--step--1); line-height:1.6; margin:0; }

    .breakdown{ display:grid; gap:0.6rem; margin:0; padding-top:0.4rem; border-top:1px solid var(--hair); }
    .breakdown__row{ display:grid; grid-template-columns:5.5rem 1fr; gap:0.75rem; align-items:baseline; }
    .breakdown dt{
      font-family:var(--sans); font-weight:700; font-size:0.68rem;
      letter-spacing:0.12em; text-transform:uppercase; color:var(--brass-light);
    }
    .breakdown dd{ margin:0; font-size:var(--step--1); color:var(--mist); }

    .qs__label{
      font-family:var(--sans); font-weight:700; font-size:0.68rem;
      letter-spacing:0.12em; text-transform:uppercase; color:var(--mist-dim); margin:0 0 0.5rem;
    }
    .qs__list{ display:grid; gap:0.4rem; }
    .qs__list li{
      position:relative; padding-left:1.1rem; font-size:var(--step--1); color:var(--mist); line-height:1.5;
    }
    .qs__list li::before{
      content:""; position:absolute; left:0; top:0.6em; width:6px; height:6px;
      border-radius:50%; background:var(--citron);
    }

    .card__actions{ display:flex; flex-wrap:wrap; align-items:center; gap:1rem; margin-top:0.3rem; }
    .btn--add{ position:relative; }
    .btn--add .btn__added-label{ display:none; }
    .btn--add[aria-pressed="true"]{ --bg:var(--olive); --fg:var(--cream); border-color:var(--olive); }
    .btn--add[aria-pressed="true"] .btn__add-label{ display:none; }
    .btn--add[aria-pressed="true"] .btn__added-label{ display:inline; }
    .btn--add[aria-pressed="true"] .btn__added-label::before{ content:"\2713  "; }

    /* ---- Rail ---- */
    .rail{
      position:sticky; top:5rem; align-self:start;
      background:linear-gradient(180deg, var(--night-2) 0%, var(--night) 100%);
      border:1px solid var(--hair-strong); border-radius:10px; overflow:hidden;
    }
    .rail__scroll{
      max-height:calc(100vh - 7rem); overflow-y:auto;
      padding:clamp(1.1rem, 0.8rem + 1vw, 1.6rem);
      display:flex; flex-direction:column; gap:1.4rem;
    }
    .rail__head{ display:flex; align-items:center; justify-content:space-between; }
    .rail__close{
      display:none; width:40px; height:40px; place-items:center;
      background:none; border:none; color:var(--mist-dim); cursor:pointer;
    }
    .rail__close:hover{ color:var(--cream); }
    .rail__summary{ margin:0; color:var(--mist); font-size:var(--step--1); }
    .rail__summary.is-active{ color:var(--citron); font-weight:500; }
    .rail__group{ display:flex; flex-direction:column; gap:0.7rem; padding-top:1.2rem; border-top:1px solid var(--hair); }
    .rail__group:first-of-type{ border-top:0; padding-top:0; }
    .rail__h{ font-size:var(--step-1); }
    .rail__empty{ margin:0; color:var(--mist-dim); font-size:var(--step--1); }

    .chosen{ display:flex; flex-direction:column; gap:0.5rem; }
    .chosen__item{
      display:flex; align-items:center; justify-content:space-between; gap:0.75rem;
      padding:0.6rem 0.75rem; border:1px solid var(--hair); border-radius:6px;
      background:rgba(199, 224, 75, 0.05);
    }
    .chosen__text{ display:flex; flex-direction:column; gap:0.1rem; }
    .chosen__name{ font-family:var(--serif); font-size:var(--step-0); color:var(--cream); line-height:1.1; }
    .chosen__cap{ font-size:0.72rem; color:var(--mist-dim); }
    .chosen__rm{
      flex:none; width:30px; height:30px; display:grid; place-items:center;
      background:none; border:1px solid var(--hair); border-radius:50%;
      color:var(--mist-dim); cursor:pointer; transition:color var(--t-fast), border-color var(--t-fast);
    }
    .chosen__rm:hover{ color:var(--cream); border-color:var(--hair-strong); }

    .vendors{ border:0; margin:0; padding:0; display:flex; flex-direction:column; gap:0.5rem; }
    .vendor{ display:flex; align-items:flex-start; gap:0.65rem; cursor:pointer; padding:0.4rem 0; }
    .vendor__box{ margin-top:0.25rem; width:18px; height:18px; accent-color:var(--citron); flex:none; }
    .vendor__text{ display:flex; flex-direction:column; gap:0.1rem; }
    .vendor__name{ font-size:var(--step--1); color:var(--mist); }
    .vendor__note{ font-size:0.72rem; color:var(--mist-dim); }

    .field{ display:flex; flex-direction:column; gap:0.35rem; margin-bottom:0.75rem; }
    .field label{
      font-family:var(--sans); font-weight:700; font-size:0.68rem;
      letter-spacing:0.12em; text-transform:uppercase; color:var(--mist-dim);
    }
    .field input{
      width:100%; min-height:46px; padding:0 0.85rem;
      background:var(--abyss-2); color:var(--cream);
      border:1px solid var(--hair); border-radius:5px;
      font-family:var(--sans); font-size:var(--step--1);
      transition:border-color var(--t-fast);
    }
    .field input:hover{ border-color:var(--hair-strong); }
    .field input::placeholder{ color:var(--mist-dim); }

    .rail__foot{ display:flex; flex-direction:column; gap:0.75rem; padding-top:1.2rem; border-top:1px solid var(--hair); }
    .rail__book{ width:100%; justify-content:center; }
    .rail__note{ margin:0; font-size:0.75rem; color:var(--mist-dim); line-height:1.5; }

    /* ---- Mobile scrim + bar ---- */
    .rail-scrim{
      position:fixed; inset:0; z-index:70;
      background:rgba(6, 10, 9, 0.7); backdrop-filter:blur(4px);
      opacity:0; transition:opacity var(--t-med) var(--ease);
    }
    .rail-scrim.is-visible{ opacity:1; }
    .mbar{
      position:fixed; left:0; right:0; bottom:0; z-index:65;
      display:flex; align-items:center; justify-content:space-between; gap:1rem;
      padding:0.75rem var(--gutter);
      background:color-mix(in oklab, var(--abyss) 88%, transparent);
      backdrop-filter:blur(10px); border-top:1px solid var(--hair-strong);
    }
    .mbar__sum{ margin:0; font-size:var(--step--1); color:var(--mist); }
    .mbar__btn{ min-height:46px; flex:none; }
    .mbar__count{
      display:inline-grid; place-items:center; min-width:1.4em; height:1.4em; padding:0 0.35em;
      margin-left:0.5em; border-radius:999px; background:var(--abyss); color:var(--citron);
      font-size:0.8em; line-height:1;
    }

    /* ---- Footer ---- */
    .p-foot{ border-top:1px solid var(--hair); padding-block:clamp(2.5rem, 2rem + 3vw, 4rem); }
    .p-foot__inner{
      max-width:var(--maxw); margin-inline:auto; padding-inline:var(--gutter);
      display:grid; gap:1.75rem; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));
    }
    .p-foot__logo{ font-family:var(--serif); font-size:var(--step-2); color:var(--cream); margin:0; }
    .p-foot__tag{ margin:0.4rem 0 0; color:var(--mist-dim); font-size:var(--step--1); }
    .p-foot__meta p{ margin:0 0 0.4rem; font-size:var(--step--1); color:var(--mist); font-style:normal; }
    .p-foot__links{ display:flex; flex-direction:column; gap:0.55rem; align-items:flex-start; }
    .p-foot__fine{
      max-width:var(--maxw); margin:2rem auto 0; padding-inline:var(--gutter);
      color:var(--mist-dim); font-size:0.75rem; letter-spacing:0.03em;
    }

    /* ---- Responsive: rail becomes a bottom sheet ---- */
    @media (max-width: 900px){
      .portal{ grid-template-columns:1fr; padding-bottom:6rem; }
      .mbar{ display:flex; }
      .rail{
        position:fixed; left:0; right:0; bottom:0; top:auto; z-index:80;
        border-radius:14px 14px 0 0; border-bottom:0;
        transform:translateY(105%); transition:transform var(--t-med) var(--ease);
        max-height:86vh;
      }
      .rail.is-open{ transform:translateY(0); }
      .rail__scroll{ max-height:86vh; }
      .rail__close{ display:grid; }
    }
    @media (min-width: 901px){
      .mbar,[hidden].rail-scrim{ display:none !important; }
    }

    /* ---- Schedule-a-call modal ---- */
    .cal-modal{
      position:fixed; inset:0; z-index:120;
      display:grid; place-items:center;
      padding:clamp(1rem, 0.5rem + 2vw, 2rem);
    }
    .cal-modal[hidden]{ display:none; }
    .cal-modal__overlay{
      position:absolute; inset:0;
      background:rgba(6, 10, 9, 0.74); backdrop-filter:blur(5px);
      opacity:0; transition:opacity var(--t-med) var(--ease);
    }
    .cal-modal.is-open .cal-modal__overlay{ opacity:1; }
    .cal-modal__dialog{
      position:relative; z-index:1;
      width:min(760px, 100%); max-height:92vh;
      display:flex; flex-direction:column;
      background:linear-gradient(180deg, var(--night-2) 0%, var(--night) 100%);
      border:1px solid var(--hair-strong); border-radius:14px;
      box-shadow:0 30px 80px rgba(0, 0, 0, 0.5);
      overflow:hidden;
      opacity:0; transform:translateY(12px) scale(0.98);
      transition:opacity var(--t-med) var(--ease), transform var(--t-med) var(--ease);
    }
    .cal-modal.is-open .cal-modal__dialog{ opacity:1; transform:none; }
    .cal-modal__head{
      display:flex; align-items:flex-start; justify-content:space-between; gap:1rem;
      padding:clamp(1.2rem, 0.9rem + 1vw, 1.6rem);
      border-bottom:1px solid var(--hair);
    }
    .cal-modal__title{ font-size:var(--step-2); margin:0.4rem 0 0; }
    .cal-modal__desc{ margin:0.5rem 0 0; color:var(--mist-dim); font-size:var(--step--1); line-height:1.55; max-width:46ch; }
    .cal-modal__close{
      flex:none; width:44px; height:44px; display:grid; place-items:center;
      background:none; border:1px solid var(--hair); border-radius:50%;
      color:var(--mist-dim); cursor:pointer;
      transition:color var(--t-fast), border-color var(--t-fast);
    }
    .cal-modal__close:hover{ color:var(--cream); border-color:var(--hair-strong); }
    .cal-modal__body{
      position:relative; overflow-y:auto;
      background:var(--abyss-2);
    }
    .cal-embed{ min-height:600px; }
    .cal-embed iframe{ display:block; }
    .cal-skeleton{
      position:absolute; inset:0; z-index:1;
      display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.9rem;
      color:var(--mist-dim); font-size:var(--step--1);
      background:var(--abyss-2);
    }
    .cal-skeleton[hidden]{ display:none; }
    .cal-skeleton__spinner{
      width:34px; height:34px; border-radius:50%;
      border:2px solid var(--hair-strong);
      border-top-color:var(--citron);
      animation:cal-spin 0.9s linear infinite;
    }
    .cal-modal__fallback{
      margin:0; padding:clamp(0.9rem, 0.7rem + 1vw, 1.2rem) clamp(1.2rem, 0.9rem + 1vw, 1.6rem);
      border-top:1px solid var(--hair);
      font-size:0.8rem; color:var(--mist-dim);
    }
    @keyframes cal-spin{ to{ transform:rotate(360deg); } }

    @media (prefers-reduced-motion: reduce){
      .card,.rail,.rail-scrim{ transition:none !important; }
      .card:hover{ transform:none; }
      .cal-modal__overlay,.cal-modal__dialog{ transition:none !important; }
      .cal-modal__dialog{ transform:none; }
      .cal-skeleton__spinner{ animation:none; }
    }
  </style>

  <script>
    // ---------- Scroll reveal (transform/opacity, reduced-motion safe) ----------
    (() => {
      const els = document.querySelectorAll('.reveal');
      if (!els.length) return;
      if (!('IntersectionObserver' in window) || matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('is-in'));
        return;
      }
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) { en.target.classList.add('is-in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
      els.forEach((el) => io.observe(el));
    })();

    // ---------- Event builder ----------
    (() => {
      const bookBtn = document.getElementById('book');
      if (!bookBtn) return;
      const email = bookBtn.dataset.email;

      const state = {
        spaces: new Map(), // key -> { name, cap }
        guests: '',
        date: '',
        name: '',
      };

      const addButtons = document.querySelectorAll('[data-add]');
      const vendorBoxes = document.querySelectorAll('.vendor__box');
      const listEl = document.getElementById('rail-spaces');
      const emptyEl = document.getElementById('rail-empty');
      const summaryEl = document.getElementById('rail-summary');
      const mbarSum = document.getElementById('mbar-sum');
      const mbarCount = document.getElementById('mbar-count');
      const gEl = document.getElementById('f-guests');
      const dEl = document.getElementById('f-date');
      const nEl = document.getElementById('f-name');

      const selectedVendors = () =>
        [...vendorBoxes].filter((b) => b.checked).map((b) => b.value);

      function buildMailto() {
        const spaces = [...state.spaces.values()];
        const vendors = selectedVendors();
        const subject = spaces.length
          ? 'Event Inquiry: ' + spaces.map((s) => s.name).join(', ')
          : 'Event Inquiry: Citron Baltimore';

        const L = [];
        L.push('Hello Citron Events team,');
        L.push('');
        L.push('I would love to book a call about an upcoming event. Here is what I have in mind:');
        L.push('');
        if (spaces.length) {
          L.push('Spaces of interest:');
          spaces.forEach((s) => L.push('  - ' + s.name + ' (' + s.cap + ')'));
          L.push('');
        }
        if (vendors.length) {
          L.push('Add-on services:');
          vendors.forEach((v) => L.push('  - ' + v));
          L.push('');
        }
        L.push('Estimated guests: ' + (state.guests || 'To be confirmed'));
        L.push('Preferred date: ' + (state.date || 'Flexible'));
        L.push('');
        L.push('Thank you,');
        L.push(state.name || '');

        const body = L.join('\n');
        return 'mailto:' + email + '?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
      }

      function render() {
        const spaces = [...state.spaces.entries()];
        const vendorCount = selectedVendors().length;

        // Spaces list
        listEl.innerHTML = '';
        spaces.forEach(([key, s]) => {
          const li = document.createElement('li');
          li.className = 'chosen__item';
          const text = document.createElement('span');
          text.className = 'chosen__text';
          const nm = document.createElement('span');
          nm.className = 'chosen__name';
          nm.textContent = s.name;
          const cp = document.createElement('span');
          cp.className = 'chosen__cap';
          cp.textContent = s.cap;
          text.append(nm, cp);
          const rm = document.createElement('button');
          rm.type = 'button';
          rm.className = 'chosen__rm';
          rm.setAttribute('aria-label', 'Remove ' + s.name);
          rm.textContent = '×';
          rm.addEventListener('click', () => toggleSpace(key));
          li.append(text, rm);
          listEl.appendChild(li);
        });
        emptyEl.hidden = spaces.length > 0;

        // Summary line
        const parts = [];
        if (spaces.length) parts.push(spaces.length + (spaces.length === 1 ? ' space' : ' spaces'));
        if (vendorCount) parts.push(vendorCount + (vendorCount === 1 ? ' service' : ' services'));
        if (state.guests) parts.push(state.guests + ' guests');
        const summaryText = parts.length ? parts.join('  ·  ') : 'Nothing added yet.';
        summaryEl.textContent = summaryText;
        summaryEl.classList.toggle('is-active', parts.length > 0);

        // Mobile bar
        mbarSum.textContent = spaces.length
          ? spaces.length + (spaces.length === 1 ? ' space added' : ' spaces added')
          : 'No spaces added yet';
        const badge = spaces.length + vendorCount;
        mbarCount.textContent = String(badge);
        mbarCount.hidden = badge === 0;

        // Mailto
        bookBtn.href = buildMailto();
      }

      function toggleSpace(key) {
        const btn = document.querySelector(`[data-add="${key}"]`);
        if (state.spaces.has(key)) {
          state.spaces.delete(key);
          if (btn) btn.setAttribute('aria-pressed', 'false');
        } else if (btn) {
          state.spaces.set(key, { name: btn.dataset.name, cap: btn.dataset.caplabel });
          btn.setAttribute('aria-pressed', 'true');
        }
        render();
      }

      addButtons.forEach((btn) => {
        btn.addEventListener('click', () => toggleSpace(btn.dataset.add));
      });
      vendorBoxes.forEach((box) => box.addEventListener('change', render));
      gEl.addEventListener('input', () => { state.guests = gEl.value.trim(); render(); });
      dEl.addEventListener('input', () => { state.date = dEl.value; render(); });
      nEl.addEventListener('input', () => { state.name = nEl.value.trim(); render(); });

      // ---------- Mobile bottom sheet ----------
      const rail = document.getElementById('rail');
      const scrim = document.querySelector('.rail-scrim');
      const openBtn = document.getElementById('mbar-open');
      const closers = document.querySelectorAll('[data-rail-close]');
      const isMobile = () => matchMedia('(max-width: 900px)').matches;
      let lastFocus = null;

      function openSheet() {
        if (!isMobile()) return;
        lastFocus = document.activeElement;
        rail.classList.add('is-open');
        scrim.hidden = false;
        requestAnimationFrame(() => scrim.classList.add('is-visible'));
        openBtn.setAttribute('aria-expanded', 'true');
        document.documentElement.style.overflow = 'hidden';
        const first = rail.querySelector('.rail__close');
        if (first) first.focus();
      }
      function closeSheet() {
        rail.classList.remove('is-open');
        scrim.classList.remove('is-visible');
        openBtn.setAttribute('aria-expanded', 'false');
        document.documentElement.style.overflow = '';
        const done = () => { scrim.hidden = true; scrim.removeEventListener('transitionend', done); };
        scrim.addEventListener('transitionend', done);
        if (lastFocus && lastFocus.focus) lastFocus.focus();
      }

      openBtn.addEventListener('click', openSheet);
      closers.forEach((c) => c.addEventListener('click', closeSheet));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && rail.classList.contains('is-open')) { closeSheet(); return; }
        if (e.key === 'Tab' && rail.classList.contains('is-open') && isMobile()) {
          const f = rail.querySelectorAll('a[href],button:not([disabled]),input,[tabindex]:not([tabindex="-1"])');
          if (!f.length) return;
          const first = f[0], last = f[f.length - 1];
          if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      });
      // If viewport grows past mobile while sheet open, reset inline overflow.
      matchMedia('(max-width: 900px)').addEventListener('change', (ev) => {
        if (!ev.matches) { document.documentElement.style.overflow = ''; scrim.hidden = true; scrim.classList.remove('is-visible'); }
      });

      // Reveal mobile bar (hidden until JS ready to avoid layout flash pre-hydration).
      document.getElementById('mbar').hidden = false;

      render();
    })();

    // ---------- Schedule-a-call pop-up modal (lazy Google Calendar embed) ----------
    (() => {
      const bookBtn = document.getElementById('book');
      const modal = document.getElementById('cal-modal');
      if (!bookBtn || !modal) return;

      const dialog = modal.querySelector('.cal-modal__dialog');
      const embed = document.getElementById('cal-embed');
      const skeleton = document.getElementById('cal-skeleton');
      const mailto = document.getElementById('cal-mailto');
      const closers = modal.querySelectorAll('[data-cal-close]');
      // Temporary live appointment schedule URL. The iframe is created only when the
      // modal first opens, so no third-party request happens on initial page load.
      const CAL_SRC = 'https://calendar.google.com/calendar/appointments/schedules/AcZssZ2ltBnOZRoXf-MooGc4ac0roHsjC3KkkGEzDKPkL80oZ5SGT6YvkgFM3HLlPUU3z-nmL9WKShdc?gv=true';
      let iframe = null;
      let lastFocus = null;

      function ensureIframe() {
        if (iframe) return;
        iframe = document.createElement('iframe');
        iframe.title = 'Schedule a call with Citron events';
        iframe.loading = 'lazy';
        iframe.style.cssText = 'border:0;width:100%;height:600px';
        iframe.addEventListener('load', () => { if (skeleton) skeleton.hidden = true; });
        // Set src last so the network request is deferred until the modal opens.
        iframe.src = CAL_SRC;
        embed.appendChild(iframe);
      }

      function openModal() {
        lastFocus = document.activeElement;
        // Carry the prefilled email plan into the modal fallback link.
        if (mailto && bookBtn.href) mailto.href = bookBtn.href;
        if (skeleton) skeleton.hidden = false;
        modal.hidden = false;
        ensureIframe();
        requestAnimationFrame(() => modal.classList.add('is-open'));
        document.documentElement.style.overflow = 'hidden';
        const first = modal.querySelector('.cal-modal__close');
        if (first) first.focus();
      }

      function closeModal() {
        modal.classList.remove('is-open');
        document.documentElement.style.overflow = '';
        const finish = () => {
          modal.hidden = true;
          dialog.removeEventListener('transitionend', finish);
        };
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) finish();
        else dialog.addEventListener('transitionend', finish);
        if (lastFocus && lastFocus.focus) lastFocus.focus();
      }

      // Intercept the "Book a call" action: open the scheduler instead of only mailto.
      bookBtn.addEventListener('click', (e) => {
        e.preventDefault();
        openModal();
      });
      closers.forEach((c) => c.addEventListener('click', closeModal));

      document.addEventListener('keydown', (e) => {
        if (modal.hidden) return;
        if (e.key === 'Escape') { closeModal(); return; }
        if (e.key === 'Tab') {
          const f = dialog.querySelectorAll('a[href],button:not([disabled]),iframe,[tabindex]:not([tabindex="-1"])');
          if (!f.length) return;
          const first = f[0], last = f[f.length - 1];
          if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      });
    })();
  </script>
</body>
</html>
