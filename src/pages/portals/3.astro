---
import '../../styles/global.css';
import { Image } from 'astro:assets';
import { SPACES, VENDORS } from '../../data/spaces.js';
import { SITE } from '../../data/site.js';
import logo from '../../assets/img/logo-dark.png';

// Eager-resolve every room image so we can map SPACES[].img to an asset.
const imgs = import.meta.glob('../../assets/img/*.jpg', { eager: true });
const imgFor = (name) => imgs['../../assets/img/' + name].default;

const capLabel = (cap) => (typeof cap === 'number' ? `Up to ${cap} guests` : 'Any scale, off-premise');

const steps = [
  { n: '01', label: 'The Room' },
  { n: '02', label: 'The Details' },
  { n: '03', label: 'The Vendors' },
  { n: '04', label: 'The Call' },
];

const title = 'The Storyboard, Plan Your Event, Citron Baltimore';
const description = 'An editorial, step-by-step planner for private events at Citron on Quarry Lake: choose your room, add the details, select vendors, and book the call.';
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#0B1210" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Citron Baltimore" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body class="pf-body">
  <a class="skip" href="#flow">Skip to the planner</a>

  <!-- ===== SLIM NAV ===== -->
  <header class="pf-nav">
    <div class="pf-nav__inner">
      <a class="pf-brand" href="/">
        <Image src={logo} alt="Citron Baltimore" width={132} height={40} loading="eager" class="pf-brand__logo" />
      </a>
      <nav class="pf-nav__links" aria-label="Portal">
        <a class="pf-nav__back" href="/">
          <span aria-hidden="true">&larr;</span> Back to site
        </a>
        <a class="pf-nav__reserve" href={SITE.reserveUrl} target="_blank" rel="noopener">Reserve</a>
      </nav>
    </div>
  </header>

  <main id="flow" class="pf-main">
    <!-- ===== HERO / TITLE ===== -->
    <section class="pf-hero">
      <p class="eyebrow pf-hero__eyebrow">The Storyboard</p>
      <h1 class="pf-hero__title">Plan your event,<br /><em class="pf-hero__em">one frame at a time.</em></h1>
      <p class="pf-hero__lede measure">Four steps, told like a story. Choose your room, sketch the details, pick your people, and we will take the call. Nothing leaves this page until you send it.</p>
    </section>

    <!-- ===== PROGRESS STRIP ===== -->
    <nav class="pf-strip" aria-label="Planning steps">
      <ol class="pf-strip__list" role="list">
        {steps.map((s, i) => (
          <li class="pf-strip__item">
            <button
              type="button"
              class="pf-step"
              data-step={String(i + 1)}
              aria-current={i === 0 ? 'step' : undefined}
              aria-disabled={i === 0 ? 'false' : 'true'}
            >
              <span class="pf-step__mark" aria-hidden="true">
                <span class="pf-step__num">{s.n}</span>
                <svg class="pf-step__check" viewBox="0 0 24 24" width="18" height="18" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="pf-step__label">{s.label}</span>
            </button>
            {i < steps.length - 1 && <span class="pf-strip__rule" aria-hidden="true"></span>}
          </li>
        ))}
      </ol>
    </nav>

    <!-- ===== STEP 01, THE ROOM ===== -->
    <section class="pf-panel is-active" id="panel-1" data-panel="1" aria-labelledby="h-1" tabindex="-1">
      <header class="pf-panel__head">
        <span class="pf-panel__kicker">Step 01</span>
        <h2 class="pf-panel__title" id="h-1">The Room</h2>
        <p class="pf-panel__sub measure">Nine spaces, from a fireside twenty to the whole property. Pick the one that fits the night.</p>
      </header>

      <ul class="pf-rooms" role="list">
        {SPACES.map((s, i) => (
          <li class="pf-rooms__cell">
            <button type="button" class="pf-room" data-room={s.key} aria-pressed="false">
              <span class="pf-room__media">
                <Image
                  src={imgFor(s.img)}
                  alt={`${s.name} at Citron Baltimore`}
                  widths={[300, 400]}
                  sizes="(max-width:640px) 90vw, 300px"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 ? 'high' : undefined}
                  format="avif"
                  quality={52}
                  class="pf-room__img"
                />
                <span class="pf-room__cap">{capLabel(s.cap)}</span>
                <span class="pf-room__tick" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </span>
              <span class="pf-room__body">
                <span class="pf-room__name">{s.name}</span>
                <span class="pf-room__best">{s.best}</span>
              </span>
            </button>
          </li>
        ))}
      </ul>

      <div class="pf-panel__nav">
        <p class="pf-hint" data-hint="1">Select a room to continue.</p>
        <button type="button" class="btn pf-next" data-next="2" disabled>Next, the details <span aria-hidden="true">&rarr;</span></button>
      </div>
    </section>

    <!-- ===== STEP 02, THE DETAILS ===== -->
    <section class="pf-panel" id="panel-2" data-panel="2" aria-labelledby="h-2" tabindex="-1" hidden>
      <header class="pf-panel__head">
        <span class="pf-panel__kicker">Step 02</span>
        <h2 class="pf-panel__title" id="h-2">The Details</h2>
        <p class="pf-panel__sub measure">Here is your room in full. Sketch in the shape of the day, we refine the rest together.</p>
      </header>

      <!-- One detail sheet per space, only the selected one is shown. -->
      {SPACES.map((s) => (
        <div class="pf-detail" data-detail={s.key} hidden>
          <div class="pf-detail__feature">
            <div class="pf-detail__media">
              <Image
                src={imgFor(s.img)}
                alt={`${s.name}, set for a private event at Citron Baltimore`}
                widths={[600, 900]}
                sizes="(max-width:820px) 92vw, 46vw"
                loading="lazy"
                format="avif"
                quality={56}
                class="pf-detail__img"
              />
              <span class="pf-detail__cap">{capLabel(s.cap)}</span>
            </div>
            <div class="pf-detail__copy">
              <h3 class="pf-detail__name">{s.name}</h3>
              <p class="pf-detail__desc">{s.desc}</p>
              <dl class="pf-detail__specs">
                <div><dt>Best for</dt><dd>{s.best}</dd></div>
                <div><dt>Layout</dt><dd>{s.layout}</dd></div>
                <div><dt>Catering</dt><dd>{s.cater}</dd></div>
              </dl>
            </div>
          </div>

          <div class="pf-form" data-form={s.key}>
            <div class="pf-field pf-field--half">
              <label for={`date-${s.key}`}>Preferred date</label>
              <input type="date" id={`date-${s.key}`} name="event-date" data-field="date" />
            </div>
            <div class="pf-field pf-field--half">
              <label for={`guests-${s.key}`}>Estimated guests</label>
              <input type="number" id={`guests-${s.key}`} name="guests" data-field="guests" min="1" inputmode="numeric" placeholder="e.g. 80" />
            </div>
            {s.q.map((q, qi) => (
              <div class="pf-field">
                <label for={`q-${s.key}-${qi}`}>{q}</label>
                <input type="text" id={`q-${s.key}-${qi}`} data-question={q} autocomplete="off" placeholder="Your answer" />
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="pf-panel__nav">
        <button type="button" class="btn btn--ghost pf-back" data-back="1"><span aria-hidden="true">&larr;</span> Back</button>
        <button type="button" class="btn pf-next" data-next="3">Next, the vendors <span aria-hidden="true">&rarr;</span></button>
      </div>
    </section>

    <!-- ===== STEP 03, THE VENDORS ===== -->
    <section class="pf-panel" id="panel-3" data-panel="3" aria-labelledby="h-3" tabindex="-1" hidden>
      <header class="pf-panel__head">
        <span class="pf-panel__kicker">Step 03</span>
        <h2 class="pf-panel__title" id="h-3">The Vendors</h2>
        <p class="pf-panel__sub measure">Tell us which pieces to bring to the table. Every service is handled in-house or through a partner we trust.</p>
      </header>

      <fieldset class="pf-vendors">
        <legend class="pf-vendors__legend">Services of interest</legend>
        {VENDORS.map((v, i) => (
          <label class="pf-vendor" for={`vendor-${i}`}>
            <input type="checkbox" id={`vendor-${i}`} class="pf-vendor__input" data-vendor={v.name} />
            <span class="pf-vendor__box" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="pf-vendor__text">
              <span class="pf-vendor__name">{v.name}</span>
              <span class="pf-vendor__note">{v.note}</span>
            </span>
          </label>
        ))}
      </fieldset>

      <div class="pf-panel__nav">
        <button type="button" class="btn btn--ghost pf-back" data-back="2"><span aria-hidden="true">&larr;</span> Back</button>
        <button type="button" class="btn pf-next" data-next="4">Next, the review <span aria-hidden="true">&rarr;</span></button>
      </div>
    </section>

    <!-- ===== STEP 04, THE CALL ===== -->
    <section class="pf-panel" id="panel-4" data-panel="4" aria-labelledby="h-4" tabindex="-1" hidden>
      <header class="pf-panel__head">
        <span class="pf-panel__kicker">Step 04</span>
        <h2 class="pf-panel__title" id="h-4">The Call</h2>
        <p class="pf-panel__sub measure">Your event, on one page. Read it back, then send it straight to our planning team.</p>
      </header>

      <article class="pf-review" id="review" aria-live="polite">
        <!-- Populated by JS from the selections. -->
      </article>

      <!-- Inline appointment scheduler, sits directly in the Step 04 flow beneath the review. -->
      <section class="pf-sched" aria-labelledby="sched-h">
        <h3 class="pf-sched__title" id="sched-h">Pick a time for the call</h3>
        <p class="pf-sched__lede measure">Choose a slot that works and we will confirm by email. Prefer to write to us instead? Use the email option below the calendar.</p>

        <div class="pf-sched__frame">
          <!-- Skeleton shows until the iframe finishes loading. -->
          <div class="pf-sched__skeleton" data-sched-skeleton>
            <span class="pf-sched__spinner" aria-hidden="true"></span>
            <p class="pf-sched__loading" role="status">Loading the scheduler…</p>
          </div>
          <!-- TODO: Temporary live Google Calendar appointment schedule (swap the /schedules/<id> to change it) -->
          <!-- src is left empty on load and set only when Step 04 becomes active (see script), so it never loads on initial paint. -->
          <iframe
            class="pf-sched__iframe"
            data-sched-frame
            data-src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ2ltBnOZRoXf-MooGc4ac0roHsjC3KkkGEzDKPkL80oZ5SGT6YvkgFM3HLlPUU3z-nmL9WKShdc?gv=true"
            title="Schedule a call with Citron events"
            loading="lazy"
            style="border:0;width:100%;height:600px;border-radius:6px"
          ></iframe>
        </div>
      </section>

      <div class="pf-cta">
        <p class="pf-cta__or">Or email us instead</p>
        <a class="btn btn--ghost pf-book" id="book-call" href="#">Book a Call by email <span aria-hidden="true">&rarr;</span></a>
        <p class="pf-cta__note">Opens a pre-filled email to <span class="pf-cta__mail">{SITE.email}</span>. Nothing sends until you hit send.</p>
      </div>

      <div class="pf-panel__nav">
        <button type="button" class="btn btn--ghost pf-back" data-back="3"><span aria-hidden="true">&larr;</span> Back</button>
      </div>
    </section>
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="pf-foot">
    <div class="pf-foot__inner">
      <div class="pf-foot__brand">
        <span class="pf-foot__name">Citron Baltimore</span>
        <span class="pf-foot__tag">Waterfront dining, catering &amp; events at Quarry Lake</span>
      </div>
      <address class="pf-foot__meta">
        <span>{SITE.address}</span>
        <a href={SITE.phoneHref}>{SITE.phone}</a>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </address>
      <div class="pf-foot__links">
        <a href="/">Back to site</a>
        <a href={SITE.reserveUrl} target="_blank" rel="noopener">Reserve a table</a>
      </div>
    </div>
  </footer>

  <style>
    /* ============ Portal 3, The Storyboard ============ */
    .pf-body{ background:var(--abyss); min-height:100vh; display:flex; flex-direction:column; }

    /* subtle brass filmstrip texture behind everything */
    .pf-main{
      position:relative; flex:1;
      background:
        radial-gradient(120% 60% at 50% -10%, rgba(176,141,62,.10), transparent 60%),
        radial-gradient(90% 50% at 100% 100%, rgba(199,224,75,.05), transparent 55%);
    }

    /* ---- nav ---- */
    .pf-nav{ position:sticky; top:0; z-index:40; background:color-mix(in oklab, var(--abyss) 88%, transparent); backdrop-filter:blur(10px); border-bottom:1px solid var(--hair); }
    .pf-nav__inner{ width:100%; max-width:var(--maxw); margin-inline:auto; padding:.85rem var(--gutter); display:flex; align-items:center; justify-content:space-between; gap:1rem; }
    .pf-brand__logo{ height:34px; width:auto; }
    .pf-nav__links{ display:flex; align-items:center; gap:clamp(1rem, 0.6rem + 1.4vw, 1.8rem); }
    .pf-nav__back{ font-size:var(--step--1); color:var(--mist-dim); letter-spacing:.04em; transition:color var(--t-fast); }
    .pf-nav__back:hover{ color:var(--cream); }
    .pf-nav__reserve{
      font-family:var(--sans); font-weight:700; font-size:var(--step--1); letter-spacing:.16em; text-transform:uppercase;
      color:var(--abyss); background:var(--citron); padding:.62em 1.2em; border-radius:var(--radius);
      transition:transform var(--t-fast) var(--ease), box-shadow var(--t-med);
    }
    .pf-nav__reserve:hover{ transform:translateY(-2px); box-shadow:0 8px 24px -8px color-mix(in oklab, var(--citron) 60%, transparent); }

    /* ---- hero ---- */
    .pf-hero{ width:100%; max-width:var(--maxw); margin-inline:auto; padding:clamp(2.8rem, 1.6rem + 5vw, 5.5rem) var(--gutter) clamp(1.6rem, 1rem + 2vw, 2.6rem); }
    .pf-hero__eyebrow{ color:var(--brass-light); }
    .pf-hero__title{ font-size:var(--step-4); line-height:.98; margin:0; }
    .pf-hero__em{ font-style:italic; font-weight:500; color:var(--brass-light); }
    .pf-hero__lede{ margin-top:1.4rem; color:var(--mist); font-size:var(--step-1); }

    /* ---- progress strip ---- */
    .pf-strip{
      position:sticky; top:57px; z-index:30;
      background:color-mix(in oklab, var(--abyss) 90%, transparent); backdrop-filter:blur(8px);
      border-top:1px solid var(--hair); border-bottom:1px solid var(--hair);
    }
    .pf-strip__list{
      width:100%; max-width:var(--maxw); margin-inline:auto; padding:.7rem var(--gutter);
      display:flex; align-items:center; gap:clamp(.3rem, 0.1rem + 1vw, 1rem);
      overflow-x:auto; scrollbar-width:none;
    }
    .pf-strip__list::-webkit-scrollbar{ display:none; }
    .pf-strip__item{ display:flex; align-items:center; gap:clamp(.3rem, 0.1rem + 1vw, 1rem); flex:0 0 auto; }
    .pf-strip__rule{ width:clamp(1.2rem, 0.4rem + 3vw, 3.2rem); height:1px; background:var(--hair-strong); }

    .pf-step{
      display:flex; align-items:center; gap:.6em; padding:.55em .7em;
      background:none; border:1px solid transparent; border-radius:var(--radius);
      color:var(--mist-dim); cursor:pointer; white-space:nowrap;
      transition:color var(--t-fast), border-color var(--t-fast), background var(--t-fast);
    }
    .pf-step:hover:not([aria-disabled="true"]){ color:var(--cream); }
    .pf-step[aria-disabled="true"]{ cursor:not-allowed; opacity:.55; }
    .pf-step__mark{
      position:relative; width:34px; height:34px; flex:none; display:grid; place-items:center;
      border:1px solid var(--hair-strong); border-radius:50%;
      font-family:var(--serif); font-size:.95rem; letter-spacing:.02em;
      transition:border-color var(--t-fast), background var(--t-fast), color var(--t-fast);
    }
    .pf-step__num{ transition:opacity var(--t-fast); }
    .pf-step__check{ position:absolute; inset:0; margin:auto; opacity:0; color:var(--abyss); transition:opacity var(--t-fast); }
    .pf-step__label{ font-family:var(--sans); font-size:var(--step--1); letter-spacing:.14em; text-transform:uppercase; }

    .pf-step[aria-current="step"]{ color:var(--cream); }
    .pf-step[aria-current="step"] .pf-step__mark{ border-color:var(--citron); color:var(--citron); box-shadow:0 0 0 4px color-mix(in oklab, var(--citron) 12%, transparent); }

    .pf-step.is-done{ color:var(--mist); }
    .pf-step.is-done .pf-step__mark{ background:var(--brass); border-color:var(--brass); color:var(--abyss); }
    .pf-step.is-done .pf-step__num{ opacity:0; }
    .pf-step.is-done .pf-step__check{ opacity:1; }
    .pf-step.is-done[aria-current="step"] .pf-step__mark{ background:var(--citron); border-color:var(--citron); }

    /* ---- panels ---- */
    .pf-panel{ width:100%; max-width:var(--maxw); margin-inline:auto; padding:clamp(2.2rem, 1.4rem + 3vw, 3.8rem) var(--gutter) clamp(3rem, 2rem + 4vw, 5rem); }
    .pf-panel[hidden]{ display:none; }
    .pf-panel.is-active{ animation:pf-fade var(--t-slow) var(--ease) both; }
    @keyframes pf-fade{ from{ opacity:0; transform:translateY(14px); } to{ opacity:1; transform:none; } }
    .pf-panel:focus{ outline:none; }
    .pf-panel:focus-visible{ outline:2px solid var(--citron); outline-offset:6px; }

    .pf-panel__head{ margin-bottom:clamp(1.8rem, 1.2rem + 2vw, 2.8rem); }
    .pf-panel__kicker{ font-family:var(--sans); font-weight:700; font-size:var(--step--1); letter-spacing:.28em; text-transform:uppercase; color:var(--brass-light); display:block; margin-bottom:.7rem; }
    .pf-panel__title{ font-size:var(--step-3); }
    .pf-panel__sub{ margin-top:.9rem; color:var(--mist-dim); }

    /* ---- step 1, room grid ---- */
    .pf-rooms{ display:grid; grid-template-columns:repeat(auto-fill, minmax(230px, 1fr)); gap:clamp(1rem, 0.6rem + 1.4vw, 1.6rem); }
    .pf-room{
      display:flex; flex-direction:column; width:100%; text-align:left; cursor:pointer;
      background:var(--abyss-2); border:1px solid var(--hair); border-radius:6px; overflow:hidden;
      transition:border-color var(--t-med), transform var(--t-med) var(--ease), box-shadow var(--t-med);
    }
    .pf-room:hover{ transform:translateY(-4px); border-color:var(--hair-strong); box-shadow:0 20px 44px -26px rgba(0,0,0,.8); }
    .pf-room__media{ position:relative; aspect-ratio:4 / 3; overflow:hidden; }
    .pf-room__img{ width:100%; height:100%; object-fit:cover; transition:transform var(--t-slow) var(--ease); }
    .pf-room:hover .pf-room__img{ transform:scale(1.05); }
    .pf-room__cap{
      position:absolute; left:10px; bottom:10px; font-family:var(--sans); font-weight:700; font-size:.72rem; letter-spacing:.08em; text-transform:uppercase;
      color:var(--cream); background:color-mix(in oklab, var(--abyss) 72%, transparent); backdrop-filter:blur(4px);
      padding:.4em .7em; border-radius:3px; border:1px solid var(--hair);
    }
    .pf-room__tick{
      position:absolute; top:10px; right:10px; width:28px; height:28px; display:grid; place-items:center;
      color:var(--abyss); background:var(--citron); border-radius:50%; opacity:0; transform:scale(.6);
      transition:opacity var(--t-fast), transform var(--t-fast) var(--ease);
    }
    .pf-room__body{ padding:1rem 1.1rem 1.25rem; display:flex; flex-direction:column; gap:.35rem; }
    .pf-room__name{ font-family:var(--serif); font-size:var(--step-1); color:var(--cream); line-height:1.05; }
    .pf-room__best{ font-size:var(--step--1); color:var(--mist-dim); line-height:1.4; }

    .pf-room[aria-pressed="true"]{ border-color:var(--citron); box-shadow:0 0 0 1px var(--citron), 0 24px 50px -28px rgba(199,224,75,.4); }
    .pf-room[aria-pressed="true"] .pf-room__tick{ opacity:1; transform:none; }

    /* ---- step 2, detail sheet ---- */
    .pf-detail[hidden]{ display:none; }
    .pf-detail__feature{ display:grid; grid-template-columns:minmax(0, 1fr) minmax(0, 1fr); gap:clamp(1.4rem, 0.8rem + 2.5vw, 2.6rem); align-items:center; }
    .pf-detail__media{ position:relative; border-radius:8px; overflow:hidden; border:1px solid var(--hair); }
    .pf-detail__img{ width:100%; height:100%; object-fit:cover; aspect-ratio:5 / 4; }
    .pf-detail__cap{
      position:absolute; left:12px; bottom:12px; font-family:var(--sans); font-weight:700; font-size:.74rem; letter-spacing:.1em; text-transform:uppercase;
      color:var(--abyss); background:var(--brass-light); padding:.42em .8em; border-radius:3px;
    }
    .pf-detail__name{ font-size:var(--step-2); color:var(--cream); }
    .pf-detail__desc{ margin-top:.9rem; color:var(--mist); }
    .pf-detail__specs{ margin-top:1.4rem; display:flex; flex-direction:column; gap:.85rem; border-top:1px solid var(--hair); padding-top:1.4rem; }
    .pf-detail__specs > div{ display:grid; grid-template-columns:8.5rem 1fr; gap:1rem; }
    .pf-detail__specs dt{ font-family:var(--sans); font-weight:700; font-size:.72rem; letter-spacing:.16em; text-transform:uppercase; color:var(--brass-light); padding-top:.15em; }
    .pf-detail__specs dd{ margin:0; color:var(--mist); }

    /* ---- forms ---- */
    .pf-form{ margin-top:clamp(2rem, 1.2rem + 2.5vw, 3rem); display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:1.1rem 1.4rem; }
    .pf-field{ display:flex; flex-direction:column; gap:.5rem; grid-column:1 / -1; }
    .pf-field--half{ grid-column:auto; }
    .pf-field label{ font-family:var(--sans); font-weight:700; font-size:.74rem; letter-spacing:.14em; text-transform:uppercase; color:var(--mist); }
    .pf-field input{
      font-family:var(--sans); font-size:var(--step-0); color:var(--cream);
      background:var(--abyss-2); border:1px solid var(--hair-strong); border-radius:4px;
      padding:.75em .9em; width:100%; transition:border-color var(--t-fast), background var(--t-fast);
    }
    .pf-field input::placeholder{ color:var(--mist-dim); }
    .pf-field input:hover{ border-color:var(--mist-dim); }
    .pf-field input:focus{ outline:none; border-color:var(--citron); background:var(--night); }
    .pf-field input:focus-visible{ outline:2px solid var(--citron); outline-offset:2px; }
    .pf-field input[type="date"]{ color-scheme:dark; }

    /* ---- step 3, vendors ---- */
    .pf-vendors{ border:0; margin:0; padding:0; display:grid; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); gap:1rem; }
    .pf-vendors__legend{ font-family:var(--sans); font-weight:700; font-size:.74rem; letter-spacing:.16em; text-transform:uppercase; color:var(--brass-light); margin-bottom:1rem; padding:0; }
    .pf-vendor{
      display:flex; align-items:center; gap:1rem; padding:1.1rem 1.2rem; cursor:pointer;
      background:var(--abyss-2); border:1px solid var(--hair); border-radius:6px;
      transition:border-color var(--t-med), background var(--t-med), transform var(--t-fast) var(--ease);
    }
    .pf-vendor:hover{ border-color:var(--hair-strong); transform:translateX(3px); }
    .pf-vendor__input{ position:absolute; opacity:0; width:1px; height:1px; }
    .pf-vendor__box{ flex:none; width:26px; height:26px; display:grid; place-items:center; border:1px solid var(--hair-strong); border-radius:5px; color:var(--abyss); transition:background var(--t-fast), border-color var(--t-fast); }
    .pf-vendor__box svg{ opacity:0; transition:opacity var(--t-fast); }
    .pf-vendor__text{ display:flex; flex-direction:column; gap:.2rem; }
    .pf-vendor__name{ font-family:var(--serif); font-size:var(--step-1); color:var(--cream); line-height:1.05; }
    .pf-vendor__note{ font-size:var(--step--1); color:var(--mist-dim); }
    .pf-vendor__input:checked + .pf-vendor__box{ background:var(--citron); border-color:var(--citron); }
    .pf-vendor__input:checked + .pf-vendor__box svg{ opacity:1; }
    .pf-vendor:has(.pf-vendor__input:checked){ border-color:var(--citron); }
    .pf-vendor__input:focus-visible + .pf-vendor__box{ outline:2px solid var(--citron); outline-offset:3px; }

    /* ---- step 4, review ---- */
    .pf-review{
      background:linear-gradient(180deg, var(--abyss-2), var(--night));
      border:1px solid var(--hair-strong); border-radius:10px;
      padding:clamp(1.6rem, 1rem + 2.5vw, 2.8rem);
      box-shadow:0 40px 90px -50px rgba(0,0,0,.9);
    }
    .pf-review__head{ display:flex; flex-wrap:wrap; align-items:baseline; justify-content:space-between; gap:.6rem 1.5rem; padding-bottom:1.3rem; border-bottom:1px solid var(--hair); }
    .pf-review__space{ font-family:var(--serif); font-size:var(--step-2); color:var(--cream); }
    .pf-review__cap{ font-family:var(--sans); font-weight:700; font-size:.74rem; letter-spacing:.14em; text-transform:uppercase; color:var(--brass-light); }
    .pf-review__row{ display:grid; grid-template-columns:10rem 1fr; gap:.4rem 1.2rem; padding:1rem 0; border-bottom:1px solid var(--hair); }
    .pf-review__row:last-child{ border-bottom:0; }
    .pf-review__k{ font-family:var(--sans); font-weight:700; font-size:.72rem; letter-spacing:.14em; text-transform:uppercase; color:var(--mist-dim); padding-top:.2em; }
    .pf-review__v{ color:var(--mist); }
    .pf-review__v ul{ display:flex; flex-wrap:wrap; gap:.5rem; }
    .pf-review__v li{ font-size:var(--step--1); color:var(--cream); background:color-mix(in oklab, var(--brass) 16%, transparent); border:1px solid color-mix(in oklab, var(--brass) 40%, transparent); padding:.35em .8em; border-radius:100px; }
    .pf-review__q{ display:block; }
    .pf-review__q + .pf-review__q{ margin-top:.6rem; }
    .pf-review__q b{ color:var(--cream); font-weight:600; font-family:var(--serif); font-size:var(--step-0); }
    .pf-review__muted{ color:var(--mist-dim); font-style:italic; }

    /* ---- step 4, inline scheduler ---- */
    .pf-sched{ margin-top:clamp(2rem, 1.4rem + 2.5vw, 3rem); }
    .pf-sched__title{ font-family:var(--serif); font-size:var(--step-1); color:var(--cream); }
    .pf-sched__lede{ margin-top:.7rem; color:var(--mist-dim); font-size:var(--step--1); }
    .pf-sched__frame{
      position:relative; margin-top:1.3rem; min-height:600px;
      background:var(--abyss-2); border:1px solid var(--hair-strong); border-radius:8px; overflow:hidden;
    }
    .pf-sched__skeleton{
      position:absolute; inset:0; z-index:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem;
      background:linear-gradient(180deg, var(--abyss-2), var(--night));
    }
    .pf-sched__skeleton[hidden]{ display:none; }
    .pf-sched__spinner{
      width:34px; height:34px; border-radius:50%;
      border:3px solid var(--hair-strong); border-top-color:var(--citron);
      animation:pf-spin 0.9s linear infinite;
    }
    @keyframes pf-spin{ to{ transform:rotate(360deg); } }
    .pf-sched__loading{ font-family:var(--sans); font-size:var(--step--1); letter-spacing:.06em; color:var(--mist-dim); }
    .pf-sched__iframe{ position:relative; z-index:2; display:block; }

    .pf-cta{ margin-top:clamp(1.8rem, 1.2rem + 2vw, 2.6rem); display:flex; flex-direction:column; align-items:flex-start; gap:1rem; }
    .pf-cta__or{ font-family:var(--sans); font-weight:700; font-size:.72rem; letter-spacing:.18em; text-transform:uppercase; color:var(--brass-light); }
    .pf-book{ font-size:var(--step-0); min-height:58px; padding:0 1.9em; }
    .pf-cta__note{ font-size:var(--step--1); color:var(--mist-dim); }
    .pf-cta__mail{ color:var(--brass-light); }

    /* ---- panel nav ---- */
    .pf-panel__nav{ margin-top:clamp(2.2rem, 1.4rem + 2.5vw, 3.4rem); display:flex; flex-wrap:wrap; align-items:center; gap:1rem; }
    .pf-panel__nav .pf-next{ margin-left:auto; }
    .pf-hint{ font-size:var(--step--1); color:var(--mist-dim); letter-spacing:.02em; }
    .btn[disabled]{ opacity:.4; cursor:not-allowed; }
    .btn[disabled]:hover{ transform:none; box-shadow:none; }

    /* ---- footer ---- */
    .pf-foot{ border-top:1px solid var(--hair); background:var(--abyss-2); }
    .pf-foot__inner{ width:100%; max-width:var(--maxw); margin-inline:auto; padding:clamp(2rem, 1.4rem + 2vw, 3rem) var(--gutter); display:flex; flex-wrap:wrap; gap:1.5rem 3rem; align-items:flex-start; justify-content:space-between; }
    .pf-foot__name{ font-family:var(--serif); font-size:var(--step-1); color:var(--cream); display:block; }
    .pf-foot__tag{ font-size:var(--step--1); color:var(--mist-dim); }
    .pf-foot__meta{ font-style:normal; display:flex; flex-direction:column; gap:.35rem; font-size:var(--step--1); color:var(--mist-dim); }
    .pf-foot__meta a:hover{ color:var(--cream); }
    .pf-foot__links{ display:flex; flex-direction:column; gap:.35rem; font-size:var(--step--1); }
    .pf-foot__links a{ color:var(--mist); transition:color var(--t-fast); }
    .pf-foot__links a:hover{ color:var(--citron); }

    /* ---- responsive ---- */
    @media (max-width:760px){
      .pf-detail__feature{ grid-template-columns:1fr; }
      .pf-form{ grid-template-columns:1fr; }
      .pf-field--half{ grid-column:1 / -1; }
      .pf-detail__specs > div{ grid-template-columns:1fr; gap:.15rem; }
      .pf-review__row{ grid-template-columns:1fr; gap:.3rem; }
      .pf-hero__title br{ display:none; }
    }
    @media (prefers-reduced-motion: reduce){
      .pf-panel.is-active{ animation:none; }
      .pf-room:hover{ transform:none; }
      .pf-room:hover .pf-room__img{ transform:none; }
      .pf-vendor:hover{ transform:none; }
      .pf-sched__spinner{ animation:none; }
    }
  </style>

  <script>
    const state = { room: null, step: 1, max: 1 };

    const stepBtns = Array.from(document.querySelectorAll('.pf-step'));
    const panels = Array.from(document.querySelectorAll('.pf-panel'));
    const rooms = Array.from(document.querySelectorAll('.pf-room'));
    const nextBtn1 = document.querySelector('.pf-next[data-next="2"]');
    const hint1 = document.querySelector('[data-hint="1"]');

    function panelFor(n){ return document.querySelector('.pf-panel[data-panel="' + n + '"]'); }

    function setStepEnabled(){
      stepBtns.forEach((b) => {
        const n = Number(b.dataset.step);
        const enabled = n === 1 || (state.room && n <= state.max);
        b.setAttribute('aria-disabled', enabled ? 'false' : 'true');
      });
    }

    function markStates(){
      stepBtns.forEach((b) => {
        const n = Number(b.dataset.step);
        b.classList.toggle('is-done', n < state.step || (n === state.step && n < 4 && n < state.max) || (n === 1 && !!state.room && state.step !== 1));
        if (n === state.step) b.setAttribute('aria-current', 'step');
        else b.removeAttribute('aria-current');
      });
      // step 1 counts as done whenever a room is chosen
      const s1 = stepBtns[0];
      s1.classList.toggle('is-done', !!state.room);
      if (state.step === 1) s1.setAttribute('aria-current', 'step');
    }

    function showDetail(){
      document.querySelectorAll('.pf-detail').forEach((d) => {
        d.hidden = d.dataset.detail !== state.room;
      });
    }

    function goto(n, opts){
      opts = opts || {};
      if (n !== 1 && (!state.room || n > state.max)) return;
      state.step = n;
      state.max = Math.max(state.max, n);
      panels.forEach((p) => {
        const active = Number(p.dataset.panel) === n;
        p.hidden = !active;
        p.classList.toggle('is-active', active);
      });
      if (n === 2) showDetail();
      if (n === 4){ buildReview(); loadScheduler(); }
      setStepEnabled();
      markStates();
      const panel = panelFor(n);
      if (opts.focus !== false && panel){
        panel.focus({ preventScroll: true });
        panel.scrollIntoView({ behavior: (matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth'), block: 'start' });
      }
    }

    // room selection
    rooms.forEach((btn) => {
      btn.addEventListener('click', () => {
        state.room = btn.dataset.room;
        rooms.forEach((r) => r.setAttribute('aria-pressed', String(r === btn)));
        state.max = Math.max(state.max, 2);
        if (nextBtn1) nextBtn1.disabled = false;
        if (hint1) hint1.textContent = 'Room selected. Continue when ready.';
        setStepEnabled();
        markStates();
      });
    });

    // step strip navigation
    stepBtns.forEach((b) => {
      b.addEventListener('click', () => {
        if (b.getAttribute('aria-disabled') === 'true') return;
        goto(Number(b.dataset.step));
      });
      b.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const dir = e.key === 'ArrowRight' ? 1 : -1;
        let i = stepBtns.indexOf(b);
        for (let k = i + dir; k >= 0 && k < stepBtns.length; k += dir){
          if (stepBtns[k].getAttribute('aria-disabled') === 'false'){ stepBtns[k].focus(); break; }
        }
      });
    });

    // next / back buttons
    document.querySelectorAll('.pf-next').forEach((b) => {
      b.addEventListener('click', () => { if (!b.disabled) goto(Number(b.dataset.next)); });
    });
    document.querySelectorAll('.pf-back').forEach((b) => {
      b.addEventListener('click', () => goto(Number(b.dataset.back)));
    });

    // ---- review + mailto ----
    const EMAIL = 'events@citronbaltimore.com';

    function currentDetail(){ return document.querySelector('.pf-detail[data-detail="' + state.room + '"]'); }

    function gather(){
      const detail = currentDetail();
      const roomBtn = document.querySelector('.pf-room[data-room="' + state.room + '"]');
      const name = roomBtn ? roomBtn.querySelector('.pf-room__name').textContent.trim() : '';
      const cap = roomBtn ? roomBtn.querySelector('.pf-room__cap').textContent.trim() : '';
      const date = detail ? detail.querySelector('[data-field="date"]').value : '';
      const guests = detail ? detail.querySelector('[data-field="guests"]').value : '';
      const answers = [];
      if (detail){
        detail.querySelectorAll('[data-question]').forEach((inp) => {
          if (inp.value.trim()) answers.push({ q: inp.dataset.question, a: inp.value.trim() });
        });
      }
      const vendors = [];
      document.querySelectorAll('.pf-vendor__input:checked').forEach((c) => vendors.push(c.dataset.vendor));
      return { name, cap, date, guests, answers, vendors };
    }

    function esc(s){ const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    // ---- inline scheduler, load the iframe only when Step 04 is reached ----
    const schedFrame = document.querySelector('[data-sched-frame]');
    const schedSkeleton = document.querySelector('[data-sched-skeleton]');
    function loadScheduler(){
      if (!schedFrame || schedFrame.getAttribute('src')) return; // already loaded
      const src = schedFrame.dataset.src;
      if (!src) return;
      schedFrame.addEventListener('load', () => { if (schedSkeleton) schedSkeleton.hidden = true; }, { once: true });
      schedFrame.setAttribute('src', src);
    }

    function buildReview(){
      const d = gather();
      const review = document.getElementById('review');
      let html = '';
      html += '<div class="pf-review__head"><span class="pf-review__space">' + esc(d.name) + '</span><span class="pf-review__cap">' + esc(d.cap) + '</span></div>';
      html += '<div class="pf-review__row"><span class="pf-review__k">Preferred date</span><span class="pf-review__v">' + (d.date ? esc(d.date) : '<span class="pf-review__muted">To be confirmed</span>') + '</span></div>';
      html += '<div class="pf-review__row"><span class="pf-review__k">Estimated guests</span><span class="pf-review__v">' + (d.guests ? esc(d.guests) : '<span class="pf-review__muted">To be confirmed</span>') + '</span></div>';

      let qHtml = '';
      if (d.answers.length){
        d.answers.forEach((it) => { qHtml += '<span class="pf-review__q"><b>' + esc(it.q) + '</b><br>' + esc(it.a) + '</span>'; });
      } else {
        qHtml = '<span class="pf-review__muted">No notes added yet.</span>';
      }
      html += '<div class="pf-review__row"><span class="pf-review__k">Details</span><span class="pf-review__v">' + qHtml + '</span></div>';

      let vHtml;
      if (d.vendors.length){
        vHtml = '<ul>' + d.vendors.map((v) => '<li>' + esc(v) + '</li>').join('') + '</ul>';
      } else {
        vHtml = '<span class="pf-review__muted">None selected.</span>';
      }
      html += '<div class="pf-review__row"><span class="pf-review__k">Vendor services</span><span class="pf-review__v">' + vHtml + '</span></div>';

      review.innerHTML = html;

      // build mailto
      const NL = '\r\n';
      let body = 'Hello Citron events team,' + NL + NL;
      body += 'I would like to plan an event in the ' + d.name + ' (' + d.cap + ').' + NL + NL;
      body += 'Preferred date: ' + (d.date || 'To be confirmed') + NL;
      body += 'Estimated guests: ' + (d.guests || 'To be confirmed') + NL + NL;
      if (d.answers.length){
        body += 'Details:' + NL;
        d.answers.forEach((it) => { body += '- ' + it.q + ' ' + it.a + NL; });
        body += NL;
      }
      if (d.vendors.length){
        body += 'Vendor services of interest:' + NL;
        d.vendors.forEach((v) => { body += '- ' + v + NL; });
        body += NL;
      }
      body += 'Thank you,' + NL;
      const subject = 'Event Inquiry: ' + d.name;
      const href = 'mailto:' + EMAIL + '?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
      document.getElementById('book-call').setAttribute('href', href);
    }

    // init
    setStepEnabled();
    markStates();
  </script>
</body>
</html>
