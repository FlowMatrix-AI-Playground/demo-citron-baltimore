    .p5-service.is-on .p5-service__name{ color:var(--citron); }

    /* ---- SUMMARY ---- */
    .p5-recap{ display:grid; grid-template-columns:auto 1fr; gap:.55rem 1.4rem;
      margin:0 0 clamp(1.6rem, 1rem + 2vw, 2.4rem); }
    .p5-recap dt{ font-family:var(--sans); font-weight:700; font-size:var(--step--1);
      letter-spacing:.06em; text-transform:uppercase; color:var(--brass-light); align-self:baseline; }
    .p5-recap dd{ margin:0; font-family:var(--sans); font-size:var(--step-0); color:var(--cream); line-height:1.5; }
    .p5-summary__cta{ display:flex; flex-wrap:wrap; align-items:center; gap:1.2rem; }
    .p5-book{ text-decoration:none; }
    .p5-restart{ font-family:var(--sans); font-size:var(--step-0); color:var(--mist-dim);
      background:none; border:none; cursor:pointer; text-decoration:underline; text-underline-offset:3px;
      transition:color var(--t-fast) var(--ease); }
    .p5-restart:hover{ color:var(--cream); }

    /* ---- ADD-TO-CALENDAR ---- */
    .p5-cal{ margin:0 0 clamp(1.6rem, 1rem + 2vw, 2.4rem); padding:clamp(1.2rem, 0.8rem + 2vw, 1.8rem);
      background:rgba(255,255,255,.015); border:1px solid var(--hair-strong); border-radius:6px; }
    .p5-cal__eyebrow{ font-family:var(--sans); font-weight:700; font-size:var(--step--1);
      letter-spacing:.2em; text-transform:uppercase; color:var(--brass-light); margin:0 0 .5em; }
    .p5-cal__lede{ font-family:var(--sans); font-size:var(--step-0); color:var(--mist-dim);
      line-height:1.55; max-width:52ch; margin:0 0 1.2rem; }
    .p5-cal__btns{ display:flex; flex-wrap:wrap; gap:.7rem; }
    .p5-calbtn{ display:inline-flex; align-items:center; gap:.55rem; font-family:var(--sans);
      font-weight:700; font-size:var(--step--1); letter-spacing:.02em; color:var(--cream);
      text-decoration:none; background:rgba(255,255,255,.03); border:1px solid var(--hair-strong);
      border-radius:4px; padding:.7em 1.05em; cursor:pointer;
      transition:border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease), transform var(--t-fast) var(--ease), color var(--t-fast) var(--ease); }
    .p5-calbtn__ico{ display:inline-flex; color:var(--citron); }
    .p5-calbtn:hover{ border-color:var(--citron); background:rgba(199,224,75,.06); transform:translateY(-2px); }
    .p5-calbtn:focus-visible{ outline:2px solid var(--citron); outline-offset:3px; }
    .p5-calbtn--ghost{ color:var(--mist); background:none; }
    .p5-calbtn--ghost .p5-calbtn__ico{ color:var(--brass-light); }

    .p5-cal__pick{ display:inline-block; margin-top:1.2rem; font-family:var(--sans); font-size:var(--step-0);
      color:var(--citron); background:none; border:none;
      border-bottom:1px solid color-mix(in oklab, var(--citron) 50%, transparent);
      padding:.2em 0; cursor:pointer;
      transition:color var(--t-fast) var(--ease), border-color var(--t-fast) var(--ease); }
    .p5-cal__pick:hover{ color:var(--cream); border-color:var(--cream); }
    .p5-cal__pick:focus-visible{ outline:2px solid var(--citron); outline-offset:3px; }
    .p5-cal__embed{ margin-top:1.2rem; }
    .p5-cal__embed[hidden]{ display:none; }
    .p5-cal__iframe{ width:100%; height:min(620px, 70vh); border:1px solid var(--hair-strong);
      border-radius:6px; background:var(--night); color-scheme:light; }

    /* ---- CONTROLS ---- */
    .p5-controls{ display:flex; align-items:center; justify-content:space-between; gap:1rem;
      margin-top:clamp(1.8rem, 1.2rem + 2.5vw, 2.8rem);
      padding-top:clamp(1.4rem, 1rem + 2vw, 2rem); border-top:1px solid var(--hair); }
    .p5-back{ font-family:var(--sans); font-size:var(--step-0); color:var(--mist);
      background:none; border:none; cursor:pointer; padding:.6em .2em;
      transition:color var(--t-fast) var(--ease); }
    .p5-back:hover{ color:var(--cream); }
    .p5-back[hidden]{ display:none; }
    .p5-next{ margin-left:auto; font-family:var(--sans); font-weight:700; font-size:var(--step--1);
      letter-spacing:.12em; text-transform:uppercase; color:var(--abyss); background:var(--citron);
      border:none; border-radius:2px; padding:.9em 1.6em; cursor:pointer;
      transition:transform var(--t-fast) var(--ease), box-shadow var(--t-med) var(--ease), opacity var(--t-fast); }
    .p5-next:hover{ transform:translateY(-2px); box-shadow:0 12px 34px -12px color-mix(in oklab, var(--citron) 70%, transparent); }
    .p5-next:disabled{ opacity:.4; cursor:not-allowed; transform:none; box-shadow:none; }

    /* ---- FOOTER ---- */
    .p5-foot{ border-top:1px solid var(--hair); padding:clamp(2.2rem, 1.4rem + 3vw, 3.4rem) var(--gutter); }
    .p5-foot__in{ max-width:var(--maxw); margin:0 auto; display:grid; gap:1.4rem;
      grid-template-columns:1fr auto; align-items:start; }
    .p5-foot__name{ font-family:var(--serif); font-size:var(--step-1); color:var(--cream); margin:0 0 .4em; }
    .p5-foot__meta{ font-family:var(--sans); font-size:var(--step--1); color:var(--mist-dim); margin:.2em 0; }
    .p5-foot__meta a{ color:var(--mist); text-decoration:none; }
    .p5-foot__meta a:hover{ color:var(--citron); }
    .p5-foot__links{ display:flex; flex-direction:column; gap:.5rem; text-align:right; }
    .p5-foot__links a{ font-family:var(--sans); font-size:var(--step--1); color:var(--mist);
      text-decoration:none; transition:color var(--t-fast) var(--ease); }
    .p5-foot__links a:hover{ color:var(--citron); }
    .p5-foot__fine{ grid-column:1 / -1; font-family:var(--sans); font-size:var(--step--1);
      color:var(--mist-dim); margin:1rem 0 0; padding-top:1rem; border-top:1px solid var(--hair); }

    /* ---- RESPONSIVE ---- */
    @media (max-width:640px){
      .p5-room.is-picked .p5-room__pick{ flex-direction:column; }
      .p5-room.is-picked .p5-room__media{ flex:none; aspect-ratio:16 / 10; }
      .p5-foot__in{ grid-template-columns:1fr; }
      .p5-foot__links{ text-align:left; }
      .p5-recap{ grid-template-columns:1fr; gap:.2rem 0; }
      .p5-recap dd{ margin-bottom:.7rem; }
    }

    @media (prefers-reduced-motion: reduce){
      .p5-step, .p5-step.is-active, .p5-progress__fill, .p5-room__img,
      .p5-chip, .p5-service, .p5-next, .p5-room__pick, .p5-calbtn, .p5-range::-webkit-slider-thumb{ transition:none !important; }
      .p5-step.enter-fwd, .p5-step.enter-back{ transform:none; }
      html{ scroll-behavior:auto; }
    }
  </style>
</body>
</html>
