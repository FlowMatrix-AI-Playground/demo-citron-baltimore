---
import Base from '../../layouts/D8Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';
import cove from '../../assets/img/room-cove.jpg';
import courtyard from '../../assets/img/courtyard-gathering.jpg';
import terrace from '../../assets/img/terrace-event.jpg';
import venue from '../../assets/img/room-venue.jpg';
import offpremise from '../../assets/img/room-offpremise.jpg';

const spaces = [
  { name: 'The Cove', cap: 'Up to 200', img: cove, blurb: 'Our signature indoor room, staged for galas, weddings, and speaker dinners.' },
  { name: 'Waterfront Courtyard', cap: 'Up to 200', img: courtyard, blurb: 'Open sky and the lake as backdrop for the largest outdoor celebrations.' },
  { name: 'Waterfront Terrace', cap: 'Up to 50', img: terrace, blurb: 'A heated, open-air terrace at the water’s edge where the sunset does the decorating.' },
  { name: 'The Entire Venue', cap: 'Up to 500', img: venue, blurb: 'The whole property, indoors and out, given over to your night.' },
];

const services = ['Floral & Decor', 'Linens & Tabletop', 'AV & Production (Savant)', 'Event Planning', 'Photography', 'Entertainment'];

const faqs = [
  { q: 'How many guests can you host?', a: 'From a fireside twenty to five hundred across the whole property. Nine private spaces in total, the Planning Portal shows each room, its capacity, and live availability so you can match the space to your headcount.' },
  { q: 'How far ahead should we book?', a: 'For weddings and large galas, six to twelve months is ideal, especially May through October and December. Corporate dinners and smaller celebrations often come together in a few weeks. When a date matters, start early in the portal to hold it.' },
  { q: 'Can we bring outside vendors?', a: 'Absolutely. We partner with your florist, planner, band, or photographer, and we can bring our own preferred teams if you would rather we handle everything. Catering and bar service stay in-house so the food and wine hold to our standard.' },
  { q: 'Do you offer PhRMA-compliant menus?', a: 'Yes. We build fully PhRMA-compliant corporate and pharmaceutical menus with the documentation your compliance team needs, without sacrificing the Citron kitchen’s standard.' },
];
---
<Base
  title="Events & Private Dining, Citron Baltimore"
  description="Waterfront private events and off-premise catering in Baltimore, from a fireside twenty to five hundred guests."
>
  <!-- ===== HERO ===== -->
  <section class="d8-ehero" aria-label="Events & Private Dining">
    <div class="d8-ehero__media" aria-hidden="true">
      <Image src={cove} alt="" widths={[768, 1200, 1500]} sizes="100vw" loading="eager" fetchpriority="high" format="avif" quality={46} class="d8-ehero__img" />
      <div class="d8-ehero__scrim"></div>
    </div>
    <div class="d8-wrap d8-ehero__content">
      <p class="d8-label d8-label--mag">Events &amp; Private Dining</p>
      <h1 class="d8-ehero__title">Baltimore celebrates <span class="d8-h-accent">after dark.</span></h1>
      <p class="d8-ehero__lede">One waterfront venue, one catering house, one kitchen, from a fireside twenty to five hundred guests, on-site or wherever your night takes place.</p>
      <div class="d8-ehero__cta">
        <a class="d8-btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <button class="d8-btn d8-btn--ghost" data-cta>Reserve · Pick-Up · Events</button>
      </div>
    </div>
  </section>

  <!-- ===== INTRO ===== -->
  <section class="d8-section d8-eintro">
    <div class="d8-wrap d8-eintro__grid">
      <p class="d8-label d8-label--neon d8-rv">The venue &amp; the catering house</p>
      <h2 class="d8-eintro__head d8-rv" data-delay="1">Forty years of celebrations, and a room on Quarry Lake to <span class="d8-h-accent">hold them.</span></h2>
      <div class="d8-eintro__body d8-rv" data-delay="2">
        <p>Before The Cove opened its doors in 2016, we spent four decades as one of Baltimore’s trusted off-premise caterers, first as Charles Levine Caterers, with roughly fourteen thousand events behind us. That experience runs through every celebration we host today.</p>
        <p>Seasonal Modern American menus, a full sushi bar, and a Wine Spectator honored list. Fully PhRMA-compliant corporate programs. Full-service events, seven days a week, at whatever scale your night requires.</p>
      </div>
    </div>
  </section>

  <!-- ===== SPACES ===== -->
  <section class="d8-section d8-section--tint d8-espaces" id="spaces">
    <div class="d8-wrap">
      <header class="d8-sechead d8-rv">
        <p class="d8-label d8-label--mag">A few of our rooms</p>
        <h2>Spaces made for <span class="d8-h-accent">the moment.</span></h2>
        <p class="d8-espaces__note">Nine spaces in total, explore and book them all in the portal. Here are four that show the range.</p>
      </header>
      <div class="d8-espaces__grid">
        {spaces.map((s, i) => (
          <article class="d8-card d8-espace d8-rv" data-delay={String((i % 3) + 1)}>
            <div class="d8-espace__media">
              <Image src={s.img} alt={`${s.name} set for a private event at Citron Baltimore`} widths={[400, 700, 900]} sizes="(max-width:900px) 90vw, 30vw" loading="lazy" format="avif" quality={54} class="d8-espace__img" />
              <span class="d8-espace__cap">{s.cap}</span>
            </div>
            <div class="d8-espace__body">
              <h3 class="d8-espace__name">{s.name}</h3>
              <p class="d8-espace__blurb">{s.blurb}</p>
              <a class="d8-espace__cta" href={SITE.portalUrl}>Plan in the Portal <span aria-hidden="true">→</span></a>
            </div>
          </article>
        ))}
      </div>
      <p class="d8-espaces__all d8-rv">
        <a class="d8-btn d8-btn--ghost" href={SITE.portalUrl}>Explore all nine spaces in the portal</a>
      </p>
    </div>
  </section>

  <!-- ===== CATERING ===== -->
  <section class="d8-section d8-ecater">
    <div class="d8-wrap d8-ecater__grid">
      <div class="d8-ecater__media d8-rv">
        <Image src={offpremise} alt="Tented off-premise catering by Citron" widths={[500, 800, 900]} sizes="(max-width:820px) 90vw, 48vw" loading="lazy" format="avif" quality={56} class="d8-ecater__img" />
        <span class="d8-charm__frame d8-ecater__frame" aria-hidden="true"></span>
      </div>
      <div class="d8-ecater__copy d8-rv" data-delay="1">
        <p class="d8-label d8-label--neon">Off-premise catering</p>
        <h2 class="d8-ecater__title">We’ll bring the restaurant <span class="d8-h-accent">to you.</span></h2>
        <p class="d8-p">Your tent, your home, your office, a hillside, or a ballroom across town, the Citron kitchen travels, and the standard travels with it. Four decades of off-premise experience means we have solved the logistics before you have thought to ask, at any scale from an intimate dinner to a several-hundred-guest gala.</p>
        <a class="d8-btn" href={SITE.portalUrl}>Start Your Catering Plan</a>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="d8-section d8-section--tint d8-eservices">
    <div class="d8-wrap d8-eservices__inner d8-rv">
      <p class="d8-label d8-label--mag">Everything under one roof</p>
      <h2 class="d8-eservices__title">A full-service team, so you host and <span class="d8-h-accent">we handle the rest.</span></h2>
      <ul class="d8-eservices__list">
        {services.map((s) => (<li class="d8-eservices__item">{s}</li>))}
      </ul>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="d8-section d8-efaq">
    <div class="d8-wrap d8-efaq__grid">
      <header class="d8-efaq__head d8-rv">
        <p class="d8-label d8-label--neon">Good to know</p>
        <h2 class="d8-efaq__title">Questions, <span class="d8-h-accent">answered.</span></h2>
      </header>
      <div class="d8-efaq__list d8-rv" data-delay="1">
        {faqs.map((f) => (
          <details class="d8-faq">
            <summary class="d8-faq__q">
              <span>{f.q}</span>
              <span class="d8-faq__icon" aria-hidden="true"></span>
            </summary>
            <p class="d8-faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="d8-section d8-efinal">
    <div class="d8-wrap d8-efinal__inner d8-rv">
      <p class="d8-label d8-label--mag">Let’s plan your night</p>
      <h2 class="d8-efinal__title">Your celebration starts <span class="d8-h-accent">in the portal.</span></h2>
      <p class="d8-efinal__lede">Browse every space, check dates, and share the shape of your event, we will take it from there.</p>
      <div class="d8-efinal__cta">
        <a class="d8-btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <button class="d8-btn d8-btn--ghost" data-cta>Reserve · Pick-Up · Events</button>
      </div>
    </div>
  </section>
</Base>

<style>
  .d8-p{ color:var(--d8-mist); max-width:54ch; }

  /* ===== HERO ===== */
  .d8-ehero{ position:relative; min-height:clamp(62vh, 56vh + 8vw, 80vh); display:flex; align-items:flex-end; overflow:hidden; color:var(--d8-white); }
  .d8-ehero__media{ position:absolute; inset:0; }
  .d8-ehero__img{ width:100%; height:100%; object-fit:cover; opacity:.5; }
  .d8-ehero__scrim{ position:absolute; inset:0; background:
    radial-gradient(90% 70% at 14% 90%, rgba(224,138,176,.12) 0%, transparent 50%),
    linear-gradient(180deg, rgba(10,10,12,.5) 0%, rgba(10,10,12,.3) 40%, rgba(10,10,12,.96) 100%); }
  .d8-ehero__content{ position:relative; z-index:2; max-width:720px; padding-block:clamp(3rem, 2rem + 6vw, 6rem); }
  .d8-ehero__title{ font-size:var(--d8-s-4); font-weight:700; margin:.28em 0 .3em; max-width:14ch; }
  .d8-ehero__lede{ color:var(--d8-mist); font-size:var(--d8-s-1); max-width:52ch; }
  .d8-ehero__cta{ display:flex; flex-wrap:wrap; gap:14px; margin-top:2rem; }

  /* ===== INTRO ===== */
  .d8-eintro__grid{ display:grid; gap:.4rem; }
  .d8-eintro__head{ font-size:var(--d8-s-3); font-weight:700; max-width:20ch; margin:.55em 0 .7em; }
  .d8-eintro__body{ color:var(--d8-mist); font-size:var(--d8-s-1); max-width:60ch; }
  .d8-eintro__body p + p{ margin-top:1.1em; }

  /* ===== SPACES ===== */
  .d8-espaces__note{ margin-top:.9em; color:var(--d8-mist); font-size:var(--d8-s-0); max-width:50ch; }
  .d8-espaces__grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:clamp(1.2rem, .6rem + 2vw, 2rem); margin-top:clamp(2.2rem, 1.4rem + 3vw, 3.4rem); }
  .d8-espace{ display:flex; flex-direction:column; }
  .d8-espace__media{ position:relative; aspect-ratio:4/5; overflow:hidden; }
  .d8-espace__img{ width:100%; height:100%; object-fit:cover; transition:transform var(--d8-t-slow) var(--d8-ease); filter:brightness(.9); }
  .d8-espace:hover .d8-espace__img{ transform:scale(1.06); filter:brightness(1); }
  .d8-espace__cap{ position:absolute; left:12px; top:12px; font-family:var(--d8-mono); font-weight:700; font-size:.6rem; letter-spacing:.06em; text-transform:uppercase; color:#0A0A0C; background:var(--d8-neon); padding:6px 11px; border-radius:999px; box-shadow:var(--d8-glow-neon); }
  .d8-espace__body{ padding:1.2rem 1.3rem 1.4rem; display:flex; flex-direction:column; flex:1; position:relative; z-index:1; }
  .d8-espace__name{ font-family:var(--d8-display); font-weight:700; font-size:var(--d8-s-1); color:var(--d8-white); }
  .d8-espace__blurb{ color:var(--d8-mist); font-size:var(--d8-s--1); margin:.45em 0 1em; line-height:1.55; }
  .d8-espace__cta{ margin-top:auto; font-family:var(--d8-mono); font-weight:700; font-size:.7rem; letter-spacing:.06em; text-transform:uppercase; color:var(--d8-neon); }
  .d8-espace__cta span{ display:inline-block; transition:transform var(--d8-t-fast) var(--d8-ease); }
  .d8-espace:hover .d8-espace__cta span{ transform:translateX(5px); }
  .d8-espaces__all{ margin-top:clamp(2.4rem, 1.5rem + 3vw, 3.6rem); }
  @media(max-width:980px){ .d8-espaces__grid{ grid-template-columns:1fr 1fr; gap:2rem; } }
  @media(max-width:560px){ .d8-espaces__grid{ grid-template-columns:1fr; } .d8-espace__media{ aspect-ratio:16/10; } }

  /* ===== CATERING ===== */
  .d8-ecater__grid{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:center; }
  .d8-ecater__media{ position:relative; }
  .d8-ecater__img{ width:100%; aspect-ratio:5/4; object-fit:cover; border-radius:var(--d8-radius); }
  .d8-charm__frame{ position:absolute; inset:14px -14px -14px 14px; border:1px solid color-mix(in oklab, var(--d8-neon) 40%, transparent); border-radius:var(--d8-radius); z-index:-1; }
  .d8-ecater__title{ font-size:var(--d8-s-2); font-weight:700; margin:.4em 0 .55em; }
  .d8-ecater__copy .d8-btn{ margin-top:2rem; }
  @media(max-width:820px){ .d8-ecater__grid{ grid-template-columns:1fr; gap:2.6rem; } }

  /* ===== SERVICES ===== */
  .d8-eservices__inner{ max-width:820px; }
  .d8-eservices__title{ font-size:var(--d8-s-2); font-weight:700; margin-top:.4em; max-width:22ch; }
  .d8-eservices__list{ display:flex; flex-wrap:wrap; gap:12px; margin-top:2rem; }
  .d8-eservices__item{ font-family:var(--d8-mono); font-size:.72rem; letter-spacing:.05em; text-transform:uppercase; color:var(--d8-neon); border:1px solid color-mix(in oklab, var(--d8-neon) 34%, transparent); border-radius:999px; padding:10px 18px; transition:background var(--d8-t-med), box-shadow var(--d8-t-med); }
  .d8-eservices__item:hover{ background:rgba(196,222,122,.08); box-shadow:var(--d8-glow-neon); }

  /* ===== FAQ ===== */
  .d8-efaq__grid{ display:grid; grid-template-columns:.7fr 1fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:start; }
  .d8-efaq__title{ font-size:var(--d8-s-2); font-weight:700; margin-top:.4em; }
  .d8-faq{ border-top:1px solid var(--d8-hair); }
  .d8-faq:last-child{ border-bottom:1px solid var(--d8-hair); }
  .d8-faq__q{ display:flex; align-items:center; justify-content:space-between; gap:1.2em; padding:1.3rem 0; cursor:pointer; list-style:none; font-family:var(--d8-display); font-weight:600; font-size:var(--d8-s-1); color:var(--d8-white); }
  .d8-faq__q::-webkit-details-marker{ display:none; }
  .d8-faq__icon{ position:relative; flex:0 0 auto; width:16px; height:16px; }
  .d8-faq__icon::before,.d8-faq__icon::after{ content:''; position:absolute; background:var(--d8-neon); transition:transform var(--d8-t-med) var(--d8-ease); }
  .d8-faq__icon::before{ left:0; top:7px; width:16px; height:2px; }
  .d8-faq__icon::after{ left:7px; top:0; width:2px; height:16px; }
  .d8-faq[open] .d8-faq__icon::after{ transform:scaleY(0); }
  .d8-faq__a{ color:var(--d8-mist); margin:0 0 1.4rem; font-size:var(--d8-s-0); max-width:64ch; }
  @media(max-width:820px){ .d8-efaq__grid{ grid-template-columns:1fr; gap:1.5rem; } }

  /* ===== FINAL ===== */
  .d8-efinal{ text-align:center; background:radial-gradient(120% 140% at 50% 0%, var(--d8-base-3) 0%, var(--d8-base) 62%); }
  .d8-efinal__inner{ max-width:640px; margin-inline:auto; }
  .d8-efinal__title{ font-size:var(--d8-s-3); font-weight:700; max-width:16ch; margin:.4em auto .5em; }
  .d8-efinal__lede{ color:var(--d8-mist); margin:0 auto 2rem; max-width:52ch; }
  .d8-efinal__cta{ display:flex; flex-wrap:wrap; gap:14px; justify-content:center; }
</style>
