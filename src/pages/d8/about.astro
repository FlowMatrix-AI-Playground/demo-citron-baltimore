---
import Base from '../../layouts/D8Base.astro';
import { Image } from 'astro:assets';
import couple from '../../assets/img/charles-susan.jpg';
import exterior from '../../assets/img/exterior.jpg';
import mainEntry from '../../assets/img/main-entry.jpg';
import wine from '../../assets/img/wine.jpg';
import charles from '../../assets/img/charles.jpg';

const awards = [
  { k: 'Wine Spectator', v: 'Award of Excellence, every year 2019–2025' },
  { k: 'Best of Baltimore', v: 'A city favorite on the water' },
  { k: "OpenTable Diner's Choice", v: 'Voted by the guests themselves' },
  { k: 'Restaurateur of the Year', v: 'Charles Levine, nominee · 2018' },
];

const timeline = [
  { t: '1980s–2016', h: 'A catering heritage', b: 'Charles Levine founds his off-premise catering company and spends four decades setting Baltimore, DC, and Northern Virginia tables.' },
  { t: 'Nov 2016', h: 'Citron & The Cove open', b: 'A 300-seat waterfront restaurant and event venue rises on Quarry Lake, a permanent home for the standard.' },
  { t: '2018', h: 'Restaurateur of the Year', b: 'One of five restaurateurs nominated by the Restaurant Association of Maryland at the Stars of the Industry Gala.' },
  { t: '2019–2025', h: 'Wine Spectator, seven times', b: 'The wine program earns the Award of Excellence every single year, without a gap.' },
  { t: 'Nov 2026', h: 'Ten years on the water', b: 'A decade of dinners, weddings, and celebrations at the lake, and counting.' },
];
---
<Base
  title="Our Story, Citron Baltimore"
  description="How Charles and Susan Levine built a waterfront restaurant and event venue at Quarry Lake, four decades in the making.">

  <!-- ===== HERO ===== -->
  <header class="d8-ahero">
    <div class="d8-ahero__media" aria-hidden="true">
      <Image src={couple} alt="" widths={[900, 1300, 1500]} sizes="100vw" loading="eager" fetchpriority="high" format="avif" quality={54} class="d8-ahero__img" />
      <div class="d8-ahero__scrim"></div>
    </div>
    <div class="d8-wrap d8-ahero__inner">
      <p class="d8-label d8-label--neon">Est. 2016 · Quarry Lake</p>
      <h1 class="d8-ahero__title">Four decades,<br /><span class="d8-h-accent">one standard.</span></h1>
      <p class="d8-ahero__deck">Charles and Susan Levine spent a lifetime perfecting hospitality in other people’s rooms. In 2016 they built one of their own, on the water, and gave Baltimore a place to come back to.</p>
    </div>
  </header>

  <!-- ===== FOUNDER NARRATIVE ===== -->
  <section class="d8-section d8-story">
    <div class="d8-wrap d8-story__grid">
      <div class="d8-story__lead">
        <p class="d8-label d8-label--mag d8-rv">The story</p>
        <p class="d8-story__drop d8-rv" data-delay="1"><span class="d8-dropcap">C</span>harles Levine learned hospitality the old-fashioned way, on the floor of the old Pimlico Hotel, where a room full of guests was a promise to keep. What he took from those years he turned into a calling: his own off-premise catering company, formerly Charles Levine Caterers, built one event at a time.</p>
        <p class="d8-story__p d8-rv" data-delay="2">Over forty years the company served something close to fourteen thousand events across Baltimore, Washington, and Northern Virginia. The guest list read like the century itself, five U.S. presidents, the NFL, the Rolling Stones, Oprah. The rooms changed every night; the standard never did.</p>
      </div>
      <figure class="d8-story__figure d8-rv" data-delay="2">
        <Image src={exterior} alt="Citron Baltimore at the edge of Quarry Lake" widths={[500, 760, 900]} sizes="(max-width:860px) 90vw, 42vw" loading="lazy" format="avif" quality={54} class="d8-story__img" />
        <figcaption class="d8-story__cap">Citron Restaurant &amp; Bar, on Quarry Lake.</figcaption>
      </figure>
    </div>

    <div class="d8-wrap d8-story__second d8-rv">
      <p class="d8-story__p d8-story__p--wide">In November of 2016, Charles and Susan Levine opened Citron Restaurant &amp; Bar and The Cove at Quarry Lake, a 300-seat waterfront restaurant and event venue, to stand alongside the catering business that made it possible. For the first time, the standard had a permanent address on the water. Two years later, the industry took note: in 2018 Charles was one of five restaurateurs nominated by the Restaurant Association of Maryland for Restaurateur of the Year at the Stars of the Industry Gala.</p>
    </div>
  </section>

  <!-- ===== KITCHEN ===== -->
  <section class="d8-section d8-section--tint d8-kitchen">
    <div class="d8-wrap d8-kitchen__grid">
      <div class="d8-kitchen__media d8-rv">
        <Image src={mainEntry} alt="The entrance to Citron Baltimore" widths={[500, 760, 900]} sizes="(max-width:860px) 90vw, 45vw" loading="lazy" format="avif" quality={54} class="d8-kitchen__img" />
        <span class="d8-charm__frame" aria-hidden="true"></span>
      </div>
      <div class="d8-kitchen__copy d8-rv" data-delay="1">
        <p class="d8-label d8-label--neon">In the kitchen</p>
        <h2 class="d8-kitchen__title">A seasonal, scratch kitchen, <span class="d8-h-accent">led with intent.</span></h2>
        <p class="d8-p">Executive Chef Mary Hersh runs a Modern American kitchen that cooks with the seasons and from scratch, Chesapeake dishes drawn from the bay, prime steaks, day-boat seafood, house-made pastas and desserts. A full sushi bar rounds out the room, built to stand on its own.</p>
        <ul class="d8-chips">
          <li>Modern American</li>
          <li>Chesapeake &amp; the bay</li>
          <li>Prime steaks</li>
          <li>Day-boat seafood</li>
          <li>House-made pastas</li>
          <li>Full sushi bar</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== WINE ===== -->
  <section class="d8-section d8-winesec">
    <div class="d8-wrap d8-winesec__grid">
      <div class="d8-winesec__copy d8-rv">
        <p class="d8-label d8-label--mag">Wine &amp; spirits</p>
        <h2 class="d8-winesec__title">An award-winning list, and a <span class="d8-h-accent">top shelf to match.</span></h2>
        <p class="d8-p">The cellar has earned the Wine Spectator Award of Excellence every year since 2019, through 2025, a list built to travel with the menu rather than sit apart from it. Alongside it runs an extensive selection of top-shelf spirits, poured for the celebration the night calls for.</p>
        <p class="d8-winesec__mark">Wine Spectator Award of Excellence · 2019–2025</p>
      </div>
      <figure class="d8-winesec__figure d8-rv" data-delay="1">
        <Image src={wine} alt="A glass of red wine on the bar at Citron" widths={[440, 680, 820]} sizes="(max-width:860px) 80vw, 40vw" loading="lazy" format="avif" quality={54} class="d8-winesec__img" />
      </figure>
    </div>
  </section>

  <!-- ===== AWARDS ===== -->
  <section class="d8-section d8-section--tint d8-awards" id="press">
    <div class="d8-wrap">
      <header class="d8-sechead d8-rv">
        <p class="d8-label d8-label--neon">Recognition</p>
        <h2>A decade of <span class="d8-h-accent">standing out.</span></h2>
      </header>
      <ul class="d8-awards__grid">
        {awards.map((a, i) => (
          <li class="d8-card d8-award d8-rv" data-delay={String((i % 3) + 1)}>
            <span class="d8-award__k">{a.k}</span>
            <span class="d8-award__v">{a.v}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== TIMELINE ===== -->
  <section class="d8-section d8-timeline">
    <div class="d8-wrap">
      <header class="d8-sechead d8-rv">
        <p class="d8-label d8-label--mag">The long story short</p>
        <h2>Four decades, told in <span class="d8-h-accent">five moments.</span></h2>
      </header>
      <ol class="d8-tl">
        {timeline.map((e, i) => (
          <li class="d8-tlrow d8-rv" data-delay={String((i % 3) + 1)}>
            <span class="d8-tlrow__dot" aria-hidden="true"></span>
            <span class="d8-tlrow__t">{e.t}</span>
            <h3 class="d8-tlrow__h">{e.h}</h3>
            <p class="d8-tlrow__b">{e.b}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== CHARM ===== -->
  <section class="d8-section d8-section--tint d8-charm2">
    <div class="d8-wrap d8-charm2__grid">
      <figure class="d8-charm2__media d8-rv">
        <Image src={charles} alt="Charles Levine, founder of Citron Baltimore" widths={[420, 640, 820]} sizes="(max-width:820px) 80vw, 38vw" loading="lazy" format="avif" quality={56} class="d8-charm2__img" />
        <span class="d8-charm__frame" aria-hidden="true"></span>
      </figure>
      <div class="d8-charm2__copy d8-rv" data-delay="1">
        <p class="d8-label d8-label--neon">Charm City, on the water</p>
        <h2 class="d8-charm2__title">Baltimore raised us. Pimlico taught us. <span class="d8-h-accent">Quarry Lake is home.</span></h2>
        <p class="d8-p">The roots run through the old Pimlico Hotel and four decades of Maryland celebrations, Preakness weeks, blue-crab summers, and the kind of hospitality a city only trusts to its own. We are proud to be Baltimore’s table.</p>
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="d8-section d8-final2">
    <div class="d8-wrap d8-final2__inner d8-rv">
      <p class="d8-label d8-label--mag">Come see for yourself</p>
      <h2 class="d8-final2__title">Ten years in, <span class="d8-h-accent">the welcome is the same.</span></h2>
      <button class="d8-btn d8-final2__btn" data-cta>Reserve · Pick-Up · Events</button>
    </div>
  </section>
</Base>

<style>
  .d8-p{ color:var(--d8-mist); max-width:56ch; }
  .d8-chips{ display:flex; flex-wrap:wrap; gap:10px; margin-top:1.8em; }
  .d8-chips li{ font-family:var(--d8-mono); font-size:.7rem; letter-spacing:.05em; text-transform:uppercase; color:var(--d8-neon); border:1px solid color-mix(in oklab, var(--d8-neon) 34%, transparent); border-radius:999px; padding:8px 14px; }
  .d8-charm__frame{ position:absolute; inset:14px -14px -14px 14px; border:1px solid color-mix(in oklab, var(--d8-neon) 40%, transparent); border-radius:var(--d8-radius); z-index:-1; }

  /* ===== HERO ===== */
  .d8-ahero{ position:relative; min-height:clamp(60vh, 40vh + 18rem, 80vh); display:flex; align-items:flex-end; overflow:hidden; }
  .d8-ahero__media{ position:absolute; inset:0; }
  .d8-ahero__img{ width:100%; height:100%; object-fit:cover; opacity:.52; }
  .d8-ahero__scrim{ position:absolute; inset:0; background:
    radial-gradient(90% 70% at 80% 6%, rgba(196,222,122,.1) 0%, transparent 45%),
    linear-gradient(180deg, rgba(10,10,12,.5) 0%, rgba(10,10,12,.28) 42%, rgba(10,10,12,.97) 100%); }
  .d8-ahero__inner{ position:relative; z-index:2; padding-block:clamp(3rem, 2rem + 6vw, 6rem); max-width:760px; }
  .d8-ahero__title{ font-size:var(--d8-s-4); font-weight:700; color:var(--d8-white); line-height:1; margin:.28em 0 .3em; }
  .d8-ahero__deck{ color:var(--d8-mist); font-size:var(--d8-s-1); max-width:52ch; }

  /* ===== STORY ===== */
  .d8-story__grid{ display:grid; grid-template-columns:1.15fr .85fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:start; }
  .d8-story__drop{ font-family:var(--d8-display); font-weight:500; font-size:var(--d8-s-1); line-height:1.5; color:var(--d8-white); }
  .d8-dropcap{ float:left; font-family:var(--d8-display); font-weight:700; font-size:3.4em; line-height:.72; padding:.06em .12em 0 0; margin-left:-.02em; color:var(--d8-neon); text-shadow:0 0 14px rgba(196,222,122,.16); }
  .d8-story__p{ color:var(--d8-mist); margin-top:1.4rem; }
  .d8-story__figure{ margin:0; position:sticky; top:6rem; }
  .d8-story__img{ width:100%; aspect-ratio:4/5; object-fit:cover; border-radius:var(--d8-radius); border:1px solid var(--d8-hair); }
  .d8-story__cap{ margin-top:.8rem; font-family:var(--d8-mono); font-size:var(--d8-s--1); color:var(--d8-dim); }
  .d8-story__second{ margin-top:clamp(2.4rem, 1.5rem + 3vw, 4rem); }
  .d8-story__p--wide{ max-width:76ch; margin-top:0; }
  @media(max-width:860px){ .d8-story__grid{ grid-template-columns:1fr; } .d8-story__figure{ position:static; order:-1; } .d8-story__img{ aspect-ratio:16/10; } }

  /* ===== KITCHEN ===== */
  .d8-kitchen__grid{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:center; }
  .d8-kitchen__media{ position:relative; }
  .d8-kitchen__img{ width:100%; aspect-ratio:4/5; object-fit:cover; border-radius:var(--d8-radius); }
  .d8-kitchen__title{ font-size:var(--d8-s-2); font-weight:700; margin:.4em 0 .55em; }
  @media(max-width:820px){ .d8-kitchen__grid{ grid-template-columns:1fr; } .d8-kitchen__media{ order:-1; } .d8-kitchen__img{ aspect-ratio:16/10; } }

  /* ===== WINE ===== */
  .d8-winesec__grid{ display:grid; grid-template-columns:1fr .8fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:center; }
  .d8-winesec__title{ font-size:var(--d8-s-2); font-weight:700; margin:.4em 0 .55em; }
  .d8-winesec__mark{ margin-top:1.6rem; font-family:var(--d8-mono); font-weight:700; font-size:.78rem; letter-spacing:.1em; text-transform:uppercase; color:var(--d8-neon); }
  .d8-winesec__figure{ margin:0; }
  .d8-winesec__img{ width:100%; aspect-ratio:3/4; object-fit:cover; border-radius:var(--d8-radius); border:1px solid var(--d8-hair); }
  @media(max-width:860px){ .d8-winesec__grid{ grid-template-columns:1fr; } .d8-winesec__figure{ order:-1; } .d8-winesec__img{ aspect-ratio:16/10; } }

  /* ===== AWARDS ===== */
  .d8-awards__grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:clamp(1.2rem, .8rem + 1.5vw, 1.8rem); margin-top:clamp(2.2rem, 1.4rem + 3vw, 3.2rem); }
  .d8-award{ display:flex; flex-direction:column; gap:.5rem; padding:1.6rem 1.6rem; }
  .d8-award__k{ font-family:var(--d8-display); font-weight:700; font-size:var(--d8-s-1); color:var(--d8-white); position:relative; z-index:1; }
  .d8-award__v{ font-size:var(--d8-s-0); color:var(--d8-mist); line-height:1.5; position:relative; z-index:1; }
  @media(max-width:640px){ .d8-awards__grid{ grid-template-columns:1fr; } }

  /* ===== TIMELINE ===== */
  .d8-tl{ position:relative; display:grid; gap:clamp(1.8rem, 1rem + 2vw, 2.8rem); padding-left:2rem; margin-top:clamp(2.4rem, 1.5rem + 3vw, 3.4rem); }
  .d8-tl::before{ content:''; position:absolute; left:5px; top:.5rem; bottom:.5rem; width:1px; background:var(--d8-hair-2); }
  .d8-tlrow{ position:relative; }
  .d8-tlrow__dot{ position:absolute; left:-2rem; top:.4rem; width:11px; height:11px; border-radius:50%; background:var(--d8-neon); box-shadow:0 0 0 4px var(--d8-base), var(--d8-glow-neon); }
  .d8-tlrow__t{ display:block; font-family:var(--d8-mono); font-weight:700; font-size:.76rem; letter-spacing:.1em; text-transform:uppercase; color:var(--d8-magenta); }
  .d8-tlrow__h{ font-size:var(--d8-s-1); color:var(--d8-white); margin:.4rem 0 .5rem; }
  .d8-tlrow__b{ color:var(--d8-mist); max-width:60ch; margin:0; }

  /* ===== CHARM 2 ===== */
  .d8-charm2__grid{ display:grid; grid-template-columns:.8fr 1fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:center; }
  .d8-charm2__media{ margin:0; position:relative; }
  .d8-charm2__img{ width:100%; aspect-ratio:4/5; object-fit:cover; border-radius:var(--d8-radius); }
  .d8-charm2__title{ font-size:var(--d8-s-2); font-weight:700; margin:.4em 0 .55em; }
  @media(max-width:820px){ .d8-charm2__grid{ grid-template-columns:1fr; } .d8-charm2__media{ order:-1; } .d8-charm2__img{ aspect-ratio:16/10; } }

  /* ===== FINAL ===== */
  .d8-final2{ text-align:center; background:radial-gradient(120% 140% at 50% 0%, var(--d8-base-3) 0%, var(--d8-base) 60%); }
  .d8-final2__inner{ max-width:640px; margin-inline:auto; }
  .d8-final2__title{ font-size:var(--d8-s-3); font-weight:700; max-width:18ch; margin:.4em auto .9em; }
  .d8-final2__btn{ min-height:60px; font-size:var(--d8-s-0); }
</style>
