---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import couple from '../assets/img/charles-susan.jpg';
import exterior from '../assets/img/exterior.jpg';
import mainEntry from '../assets/img/main-entry.jpg';
import wine from '../assets/img/wine.jpg';
import charles from '../assets/img/charles.jpg';
import { SITE } from '../data/site.js';

const awards = [
  { k: 'Wine Spectator', v: 'Award of Excellence, every year 2019–2025' },
  { k: 'Best of Baltimore', v: 'A city favorite on the water' },
  { k: "OpenTable Diner's Choice", v: 'Voted by the guests themselves' },
  { k: 'Restaurateur of the Year', v: 'Charles Levine, nominee · 2018' },
];

const timeline = [
  { t: '1980s–2016', h: 'A catering heritage', b: 'Charles Levine founds his off-premise catering company and spends four decades setting Baltimore, DC, and Northern Virginia tables.' },
  { t: 'Nov 2016', h: 'Citron & The Cove open', b: 'A 300-seat waterfront restaurant and event venue rises on Quarry Lake, a permanent home for the standard.' },
  { t: '2018', h: 'Restaurateur of the Year', b: 'One of five restaurateurs nominated by the Restaurant Association of Maryland at the Stars of the Industry Gala.' },
  { t: '2019–2025', h: 'Wine Spectator, seven times', b: 'The wine program earns the Award of Excellence every single year, without a gap.' },
  { t: 'Nov 2026', h: 'Ten years on the water', b: 'A decade of dinners, weddings, and celebrations at the lake, and counting.' },
];
---
<Base
  title="Our Story, Citron Baltimore"
  description="How Charles and Susan Levine built a waterfront restaurant and event venue at Quarry Lake, four decades in the making.">

  <!-- ===== HERO ===== -->
  <header class="hero">
    <div class="hero__media" aria-hidden="true">
      <Image src={couple} alt="" widths={[900, 1300, 1600]} sizes="100vw" loading="eager" fetchpriority="high" format="avif" quality={58} class="hero__img" />
      <div class="hero__scrim"></div>
    </div>
    <div class="wrap hero__inner cluster">
      <p class="eyebrow">Est. 2016 &middot; Quarry Lake</p>
      <h1 class="hero__title">Four decades,<br />one standard.</h1>
      <p class="hero__deck measure">Charles and Susan Levine spent a lifetime perfecting hospitality in other people's rooms. In 2016 they built one of their own, on the water, and gave Baltimore a place to come back to.</p>
    </div>
  </header>

  <!-- ===== FOUNDER NARRATIVE ===== -->
  <section class="section story">
    <div class="wrap story__grid">
      <div class="story__lead">
        <p class="eyebrow reveal">The story</p>
        <p class="story__drop reveal" data-delay="1">
          <span class="dropcap">C</span>harles Levine learned hospitality the old-fashioned way, on the floor of the old Pimlico Hotel, where a room full of guests was a promise to keep. What he took from those years he turned into a calling: his own off-premise catering company, formerly Charles Levine Caterers, built one event at a time.
        </p>
        <p class="story__p reveal" data-delay="2">
          Over forty years the company served something close to fourteen thousand events across Baltimore, Washington, and Northern Virginia. The guest list read like the century itself, five U.S. presidents, the NFL, the Rolling Stones, Oprah. The rooms changed every night; the standard never did.
        </p>
      </div>
      <figure class="story__figure reveal" data-delay="2">
        <Image src={exterior} alt="Citron Baltimore at the edge of Quarry Lake" widths={[500, 760, 900]} sizes="(max-width:860px) 90vw, 42vw" loading="lazy" format="avif" quality={55} class="story__img" />
        <figcaption class="story__cap">Citron Restaurant &amp; Bar, on Quarry Lake.</figcaption>
      </figure>
    </div>

    <div class="wrap story__second reveal">
      <p class="story__p measure-wide">
        In November of 2016, Charles and Susan Levine opened Citron Restaurant &amp; Bar and The Cove at Quarry Lake, a 300-seat waterfront restaurant and event venue, to stand alongside the catering business that made it possible. For the first time, the standard had a permanent address on the water. Two years later, the industry took note: in 2018 Charles was one of five restaurateurs nominated by the Restaurant Association of Maryland for Restaurateur of the Year at the Stars of the Industry Gala.
      </p>
    </div>
  </section>

  <!-- ===== KITCHEN ===== -->
  <section class="section kitchen on-light">
    <div class="wrap kitchen__grid">
      <div class="kitchen__media reveal">
        <Image src={mainEntry} alt="The entrance to Citron Baltimore" widths={[500, 760, 900]} sizes="(max-width:860px) 90vw, 45vw" loading="lazy" format="avif" quality={55} class="kitchen__img" />
      </div>
      <div class="kitchen__copy reveal" data-delay="1">
        <p class="eyebrow">In the kitchen</p>
        <h2 class="kitchen__title">A seasonal, scratch kitchen, led with intent.</h2>
        <p class="measure">Executive Chef Mary Hersh runs a Modern American kitchen that cooks with the seasons and from scratch, Chesapeake dishes drawn from the bay, prime steaks, day-boat seafood, house-made pastas and desserts. A full sushi bar rounds out the room, built to stand on its own.</p>
        <ul class="kitchen__chips">
          <li>Modern American</li>
          <li>Chesapeake &amp; the bay</li>
          <li>Prime steaks</li>
          <li>Day-boat seafood</li>
          <li>House-made pastas &amp; desserts</li>
          <li>Full sushi bar</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== WINE & SPIRITS ===== -->
  <section class="section wine">
    <div class="wrap wine__grid">
      <div class="wine__copy reveal">
        <p class="eyebrow eyebrow--brass">Wine &amp; spirits</p>
        <h2 class="wine__title">An award-winning list, and a top shelf to match.</h2>
        <p class="measure">The cellar has earned the Wine Spectator Award of Excellence every year since 2019, through 2025, a list built to travel with the menu rather than sit apart from it. Alongside it runs an extensive selection of top-shelf spirits, poured for the celebration the night calls for.</p>
        <p class="wine__mark">Wine Spectator Award of Excellence &middot; 2019–2025</p>
      </div>
      <figure class="wine__figure reveal" data-delay="1">
        <Image src={wine} alt="A glass of red wine on the bar at Citron" widths={[440, 680, 820]} sizes="(max-width:860px) 80vw, 40vw" loading="lazy" format="avif" quality={56} class="wine__img" />
      </figure>
    </div>
  </section>

  <!-- ===== AWARDS / RECOGNITION ===== -->
  <section class="section awards on-light">
    <div class="wrap">
      <header class="awards__head reveal">
        <p class="eyebrow">Recognition</p>
        <h2 class="awards__title">A decade of standing out.</h2>
      </header>
      <ul class="awards__grid">
        {awards.map((a, i) => (
          <li class="award reveal" data-delay={String((i % 3) + 1)}>
            <span class="award__k">{a.k}</span>
            <span class="award__v">{a.v}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===== TIMELINE ===== -->
  <section class="section timeline">
    <div class="wrap">
      <header class="timeline__head reveal">
        <p class="eyebrow">The long story short</p>
        <h2 class="timeline__title">Four decades, told in five moments.</h2>
      </header>
      <ol class="timeline__list">
        {timeline.map((e, i) => (
          <li class="tl reveal" data-delay={String((i % 3) + 1)}>
            <span class="tl__dot" aria-hidden="true"></span>
            <span class="tl__t">{e.t}</span>
            <h3 class="tl__h">{e.h}</h3>
            <p class="tl__b">{e.b}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== CHARM CITY ===== -->
  <section class="section charm on-light">
    <div class="wrap charm__grid">
      <figure class="charm__media reveal">
        <Image src={charles} alt="Charles Levine, founder of Citron Baltimore" widths={[420, 640, 820]} sizes="(max-width:820px) 80vw, 38vw" loading="lazy" format="avif" quality={58} class="charm__img" />
      </figure>
      <div class="charm__copy reveal" data-delay="1">
        <p class="eyebrow">Charm City, on the water</p>
        <h2 class="charm__title">Baltimore raised us. Pimlico taught us. Quarry Lake is home.</h2>
        <p class="measure">The roots run through the old Pimlico Hotel and four decades of Maryland celebrations, Preakness weeks, blue-crab summers, and the kind of hospitality a city only trusts to its own. We are proud to be Baltimore's table.</p>
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="section final-cta">
    <div class="wrap final-cta__inner reveal">
      <p class="eyebrow">Come see for yourself</p>
      <h2 class="final-cta__title">Ten years in, the welcome is the same.</h2>
      <button class="btn final-cta__btn" data-cta data-magnetic>Reserve &middot; Pick-Up &middot; Events</button>
    </div>
  </section>
</Base>

<style>
  /* ===== hero ===== */
  .hero{ position:relative; min-height:clamp(62vh, 40vh + 18rem, 82vh); display:flex; align-items:flex-end; overflow:hidden; }
  .hero__media{ position:absolute; inset:0; }
  .hero__img{ width:100%; height:100%; object-fit:cover; }
  .hero__scrim{ position:absolute; inset:0; background:linear-gradient(180deg, rgba(8,12,10,.55) 0%, rgba(8,12,10,.28) 42%, rgba(8,12,10,.9) 100%); }
  .hero__inner{ position:relative; z-index:2; padding-block: clamp(3rem, 2rem + 6vw, 6rem); }
  .hero__title{ font-size:var(--step-4); font-weight:600; color:var(--cream); line-height:.98; margin-top:.1em; }
  .hero__deck{ color:var(--mist); font-size:var(--step-1); margin-top:1.1rem; }

  /* ===== story ===== */
  .story__grid{ display:grid; grid-template-columns:1.15fr .85fr; gap:clamp(2rem,1rem + 4vw,5rem); align-items:start; }
  .story__drop{ font-family:var(--serif); font-size:var(--step-1); line-height:1.5; color:var(--cream); }
  .dropcap{ float:left; font-family:var(--serif); font-weight:600; font-size:3.4em; line-height:.72; padding:.06em .1em 0 0; margin-left:-.02em; color:var(--citron); }
  .story__p{ color:var(--mist); margin-top:1.4rem; }
  .story__figure{ margin:0; position:sticky; top:2rem; }
  .story__img{ width:100%; aspect-ratio:4/5; object-fit:cover; border-radius:4px; }
  .story__cap{ margin-top:.7rem; font-size:var(--step--1); color:var(--mist-dim); letter-spacing:.02em; }
  .story__second{ margin-top:clamp(2.4rem,1.5rem + 3vw,4rem); }
  .measure-wide{ max-width:74ch; }
  @media(max-width:860px){
    .story__grid{ grid-template-columns:1fr; }
    .story__figure{ position:static; order:-1; }
    .story__img{ aspect-ratio:16/10; }
  }

  /* ===== kitchen ===== */
  .kitchen__grid{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(2rem,1rem + 4vw,5rem); align-items:center; }
  .kitchen__img{ width:100%; aspect-ratio:4/5; object-fit:cover; border-radius:4px; }
  .kitchen__title{ font-size:var(--step-2); margin:.35em 0 .6em; }
  .kitchen__copy p{ color:var(--ink-soft); }
  .kitchen__chips{ display:flex; flex-wrap:wrap; gap:10px; margin-top:1.8em; }
  .kitchen__chips li{ font-size:.74rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--olive-dark); border:1px solid color-mix(in oklab, var(--olive) 40%, transparent); border-radius:40px; padding:8px 14px; }
  @media(max-width:820px){ .kitchen__grid{ grid-template-columns:1fr; } .kitchen__media{ order:-1; } .kitchen__img{ aspect-ratio:16/10; } }

  /* ===== wine ===== */
  .wine__grid{ display:grid; grid-template-columns:1fr .8fr; gap:clamp(2rem,1rem + 4vw,5rem); align-items:center; }
  .wine__title{ font-size:var(--step-2); margin:.35em 0 .6em; }
  .wine__copy p{ color:var(--mist); }
  .wine__mark{ margin-top:1.6rem; font-size:.78rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:var(--brass-light); }
  .wine__figure{ margin:0; }
  .wine__img{ width:100%; aspect-ratio:3/4; object-fit:cover; border-radius:4px; }
  @media(max-width:860px){ .wine__grid{ grid-template-columns:1fr; } .wine__figure{ order:-1; } .wine__img{ aspect-ratio:16/10; } }

  /* ===== awards ===== */
  .awards__head{ max-width:34ch; margin-bottom:clamp(2rem,1rem + 3vw,3.2rem); }
  .awards__title{ font-size:var(--step-2); margin-top:.3em; }
  .awards__grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:clamp(1.4rem,.8rem + 2vw,2.4rem); }
  .award{ display:flex; flex-direction:column; gap:.4rem; padding-top:1.4rem; border-top:1px solid color-mix(in oklab, var(--olive) 28%, transparent); }
  .award__k{ font-family:var(--serif); font-size:var(--step-1); color:var(--ink); }
  .award__v{ font-size:var(--step-0); color:var(--ink-soft); line-height:1.5; }
  @media(max-width:640px){ .awards__grid{ grid-template-columns:1fr; } }

  /* ===== timeline ===== */
  .timeline__head{ max-width:34ch; margin-bottom:clamp(2.4rem,1.5rem + 3vw,3.6rem); }
  .timeline__title{ font-size:var(--step-2); margin-top:.3em; }
  .timeline__list{ position:relative; display:grid; gap:clamp(1.8rem,1rem + 2vw,2.8rem); padding-left:2rem; }
  .timeline__list::before{ content:''; position:absolute; left:5px; top:.5rem; bottom:.5rem; width:1px; background:var(--hair-strong); }
  .tl{ position:relative; }
  .tl__dot{ position:absolute; left:-2rem; top:.35rem; width:11px; height:11px; border-radius:50%; background:var(--citron); box-shadow:0 0 0 4px var(--abyss); }
  .tl__t{ display:block; font-size:.76rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:var(--brass-light); }
  .tl__h{ font-size:var(--step-1); color:var(--cream); margin:.35rem 0 .5rem; }
  .tl__b{ color:var(--mist); max-width:60ch; margin:0; }

  /* ===== charm ===== */
  .charm__grid{ display:grid; grid-template-columns:.8fr 1fr; gap:clamp(2rem,1rem + 4vw,5rem); align-items:center; }
  .charm__media{ margin:0; }
  .charm__img{ width:100%; aspect-ratio:4/5; object-fit:cover; border-radius:4px; }
  .charm__title{ font-size:var(--step-2); margin:.4em 0 .6em; }
  .charm__copy p{ color:var(--ink-soft); }
  @media(max-width:820px){ .charm__grid{ grid-template-columns:1fr; } .charm__media{ order:-1; } .charm__img{ aspect-ratio:16/10; } }

  /* ===== final cta ===== */
  .final-cta{ text-align:center; background:radial-gradient(120% 140% at 50% 0%, var(--night) 0%, var(--abyss) 60%); }
  .final-cta__title{ font-size:var(--step-3); font-weight:500; max-width:18ch; margin:.35em auto .9em; }
  .final-cta__btn{ min-height:58px; font-size:var(--step-0); }
</style>
