---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../data/site.js';
import cove from '../assets/img/room-cove.jpg';
import courtyard from '../assets/img/courtyard-gathering.jpg';
import terrace from '../assets/img/terrace-event.jpg';
import venue from '../assets/img/room-venue.jpg';
import offpremise from '../assets/img/room-offpremise.jpg';

// Marquee spaces only, the full nine-space inventory lives in the portal.
const spaces = [
  { name: 'The Cove', cap: 'Up to 200', img: cove, blurb: 'Our signature indoor room, staged for galas, weddings, and speaker dinners.' },
  { name: 'Waterfront Courtyard', cap: 'Up to 200', img: courtyard, blurb: 'Open sky and the lake as backdrop for the largest outdoor celebrations.' },
  { name: 'Waterfront Terrace', cap: 'Up to 50', img: terrace, blurb: 'A heated, open-air terrace at the water’s edge where the sunset does the decorating.' },
  { name: 'The Entire Venue', cap: 'Up to 500', img: venue, blurb: 'The whole property, indoors and out, given over to your night.' },
];

const services = [
  'Floral & Decor', 'Linens & Tabletop', 'AV & Production (Savant)',
  'Event Planning', 'Photography', 'Entertainment',
];

const faqs = [
  { q: 'How many guests can you host?', a: 'From a fireside twenty to five hundred across the whole property. Nine private spaces in total, the Planning Portal shows each room, its capacity, and live availability so you can match the space to your headcount.' },
  { q: 'How far ahead should we book?', a: 'For weddings and large galas, six to twelve months is ideal, especially May through October and December. Corporate dinners and smaller celebrations often come together in a few weeks. When a date matters, start early in the portal to hold it.' },
  { q: 'Can we bring outside vendors?', a: 'Absolutely. We partner with your florist, planner, band, or photographer, and we can bring our own preferred teams if you’d rather we handle everything. Catering and bar service stay in-house so the food and wine hold to our standard.' },
  { q: 'Do you offer PhRMA-compliant menus?', a: 'Yes. We build fully PhRMA-compliant corporate and pharmaceutical menus with the documentation your compliance team needs, without sacrificing the Citron kitchen’s standard.' },
];
---
<Base
  title="Events & Private Dining, Citron Baltimore"
  description="Waterfront private events and off-premise catering in Baltimore, from a fireside twenty to five hundred guests."
>
  <!-- ===== HERO ===== -->
  <section class="ev-hero" aria-label="Events & Private Dining">
    <div class="ev-hero__bg" aria-hidden="true">
      <Image src={cove} alt="" widths={[768, 1200, 1500]} sizes="100vw" loading="eager" fetchpriority="high" format="avif" quality={48} class="ev-hero__img" />
      <div class="ev-hero__scrim"></div>
    </div>
    <div class="wrap ev-hero__content cluster">
      <p class="eyebrow">Events &amp; Private Dining</p>
      <h1 class="ev-hero__title">Baltimore celebrates on the water.</h1>
      <p class="ev-hero__lede measure">One waterfront venue, one catering house, one kitchen, from a fireside twenty to five hundred guests, on-site or wherever your day takes place.</p>
      <div class="ev-hero__cta cluster-cta">
        <a class="btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <button class="btn btn--ghost" data-cta data-magnetic>Reserve &middot; Pick-Up &middot; Events</button>
      </div>
    </div>
  </section>

  <!-- ===== INTRO / STORY ===== -->
  <section class="section ev-intro">
    <div class="wrap ev-intro__grid">
      <p class="eyebrow reveal">The venue &amp; the catering house</p>
      <h2 class="ev-intro__head reveal" data-delay="1">Forty years of celebrations, and a room on Quarry Lake to hold them.</h2>
      <div class="ev-intro__body reveal measure" data-delay="2">
        <p>Before The Cove opened its doors in 2016, we spent four decades as one of Baltimore’s trusted off-premise caterers, first as Charles Levine Caterers, with roughly fourteen thousand events behind us. That experience runs through every celebration we host today.</p>
        <p>Seasonal Modern American menus, a full sushi bar, and a Wine Spectator–honored list. Fully PhRMA-compliant corporate programs. Full-service events, seven days a week, at whatever scale your day requires.</p>
      </div>
    </div>
  </section>

  <!-- ===== MARQUEE SPACES (a curated few, the full nine live in the portal) ===== -->
  <section class="section ev-spaces on-light" id="spaces">
    <div class="wrap">
      <header class="ev-spaces__head reveal">
        <p class="eyebrow">A few of our rooms</p>
        <h2 class="ev-spaces__title">Spaces made for the moment.</h2>
        <p class="ev-spaces__note measure">Nine spaces in total, explore and book them all in the portal. Here are four that show the range.</p>
      </header>
      <div class="ev-spaces__grid">
        {spaces.map((s, i) => (
          <article class="space reveal" data-delay={String((i % 3) + 1)}>
            <div class="space__media">
              <Image src={s.img} alt={`${s.name} set for a private event at Citron Baltimore`} widths={[400, 700, 900]} sizes="(max-width:900px) 90vw, 30vw" loading="lazy" format="avif" quality={56} class="space__img" />
              <span class="space__cap">{s.cap}</span>
            </div>
            <h3 class="space__name">{s.name}</h3>
            <p class="space__blurb">{s.blurb}</p>
            <a class="space__cta" href={SITE.portalUrl}>Plan in the Portal <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
      <p class="ev-spaces__all reveal">
        <a class="btn btn--ghost on-light-btn" href={SITE.portalUrl}>Explore all nine spaces in the portal</a>
      </p>
    </div>
  </section>

  <!-- ===== CATERING (off-premise) ===== -->
  <section class="section ev-cater">
    <div class="wrap ev-cater__grid">
      <div class="ev-cater__media reveal">
        <Image src={offpremise} alt="Tented off-premise catering by Citron" widths={[500, 800, 900]} sizes="(max-width:820px) 90vw, 48vw" loading="lazy" format="avif" quality={58} class="ev-cater__img" />
      </div>
      <div class="ev-cater__copy reveal" data-delay="1">
        <p class="eyebrow eyebrow--brass">Off-premise catering</p>
        <h2 class="ev-cater__title">We’ll bring the restaurant to you.</h2>
        <p class="measure">Your tent, your home, your office, a hillside, or a ballroom across town, the Citron kitchen travels, and the standard travels with it. Four decades of off-premise experience means we’ve solved the logistics before you’ve thought to ask, at any scale from an intimate dinner to a several-hundred-guest gala.</p>
        <a class="btn" href={SITE.portalUrl}>Start Your Catering Plan</a>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="section ev-services on-light">
    <div class="wrap ev-services__inner reveal">
      <p class="eyebrow">Everything under one roof</p>
      <h2 class="ev-services__title">A full-service team, so you host and we handle the rest.</h2>
      <ul class="ev-services__list">
        {services.map((s) => (<li class="ev-services__item">{s}</li>))}
      </ul>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section ev-faq">
    <div class="wrap ev-faq__grid">
      <header class="ev-faq__head reveal">
        <p class="eyebrow">Good to know</p>
        <h2 class="ev-faq__title">Questions, answered.</h2>
      </header>
      <div class="ev-faq__list reveal" data-delay="1">
        {faqs.map((f) => (
          <details class="faq">
            <summary class="faq__q">
              <span>{f.q}</span>
              <span class="faq__icon" aria-hidden="true"></span>
            </summary>
            <p class="faq__a measure">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="section ev-final">
    <div class="wrap ev-final__inner reveal">
      <p class="eyebrow">Let’s plan your day</p>
      <h2 class="ev-final__title">Your celebration starts in the portal.</h2>
      <p class="ev-final__lede measure">Browse every space, check dates, and share the shape of your event, we’ll take it from there.</p>
      <div class="ev-final__cta">
        <a class="btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <button class="btn btn--ghost" data-cta data-magnetic>Reserve &middot; Pick-Up &middot; Events</button>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== hero ===== */
  .ev-hero{ position:relative; min-height:clamp(66vh, 60vh + 8vw, 82vh); display:flex; align-items:flex-end; overflow:hidden; color:var(--cream); }
  .ev-hero__bg{ position:absolute; inset:0; }
  .ev-hero__img{ width:100%; height:100%; object-fit:cover; }
  .ev-hero__scrim{ position:absolute; inset:0; background:linear-gradient(180deg, rgba(8,12,10,.55) 0%, rgba(8,12,10,.32) 40%, rgba(8,12,10,.9) 100%); }
  .ev-hero__content{ position:relative; z-index:2; max-width:720px; padding-block:clamp(3rem, 2rem + 6vw, 6rem); }
  .ev-hero__title{ font-size:var(--step-4); font-weight:600; margin:0; max-width:14ch; }
  .ev-hero__lede{ color:var(--mist); font-size:var(--step-1); margin-top:1rem; }
  .ev-hero__cta{ display:flex; flex-wrap:wrap; gap:14px; }

  /* ===== intro ===== */
  .ev-intro__grid{ display:grid; grid-template-columns:1fr; gap:.4rem; }
  .ev-intro__head{ font-size:var(--step-3); font-weight:500; max-width:20ch; margin:.35em 0 .7em; }
  .ev-intro__body{ color:var(--mist); font-size:var(--step-1); }
  .ev-intro__body p + p{ margin-top:1.1em; }

  /* ===== spaces ===== */
  .ev-spaces__head{ max-width:44ch; margin-bottom:clamp(2rem,1rem + 3vw,3.4rem); }
  .ev-spaces__title{ font-size:var(--step-2); margin-top:.3em; }
  .ev-spaces__note{ margin-top:.9em; color:var(--ink-soft); font-size:var(--step-0); }
  .ev-spaces__grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:clamp(1.2rem,.6rem + 2vw,2rem); }
  .space{ display:flex; flex-direction:column; }
  .space__media{ position:relative; aspect-ratio:4/5; overflow:hidden; border-radius:4px; margin-bottom:1.1rem; }
  .space__img{ width:100%; height:100%; object-fit:cover; transition:transform var(--t-slow) var(--ease); }
  .space:hover .space__img{ transform:scale(1.06); }
  .space__cap{ position:absolute; left:12px; top:12px; font-size:.66rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--abyss); background:var(--citron); padding:6px 11px; border-radius:40px; }
  .space__name{ font-family:var(--serif); font-size:var(--step-1); color:var(--ink); }
  .space__blurb{ color:var(--ink-soft); font-size:var(--step--1); margin:.4em 0 1em; line-height:1.55; }
  .space__cta{ margin-top:auto; font-weight:700; font-size:var(--step--1); letter-spacing:.1em; text-transform:uppercase; color:var(--olive-dark); }
  .space__cta span{ display:inline-block; transition:transform var(--t-fast) var(--ease); }
  .space__cta:hover span{ transform:translateX(5px); }
  .ev-spaces__all{ margin-top:clamp(2.4rem,1.5rem + 3vw,3.6rem); }
  .on-light-btn{ --fg:var(--ink); border-color:color-mix(in oklab, var(--ink) 26%, transparent); }
  .on-light-btn:hover{ --fg:var(--cream); background:var(--ink); border-color:var(--ink); }
  @media(max-width:980px){ .ev-spaces__grid{ grid-template-columns:1fr 1fr; gap:2rem; } }
  @media(max-width:560px){ .ev-spaces__grid{ grid-template-columns:1fr; } .space__media{ aspect-ratio:16/10; } }

  /* ===== catering ===== */
  .ev-cater__grid{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(2rem,1rem + 4vw,5rem); align-items:center; }
  .ev-cater__img{ width:100%; aspect-ratio:5/4; object-fit:cover; border-radius:4px; }
  .ev-cater__title{ font-size:var(--step-2); margin:.35em 0 .6em; }
  .ev-cater__copy p{ color:var(--mist); }
  .ev-cater__copy .btn{ margin-top:2rem; }
  @media(max-width:820px){ .ev-cater__grid{ grid-template-columns:1fr; gap:2.4rem; } }

  /* ===== services ===== */
  .ev-services__inner{ max-width:820px; }
  .ev-services__title{ font-size:var(--step-2); margin-top:.3em; max-width:22ch; }
  .ev-services__list{ display:flex; flex-wrap:wrap; gap:12px; margin-top:2rem; }
  .ev-services__item{ font-size:.78rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--olive-dark); border:1px solid color-mix(in oklab, var(--olive) 40%, transparent); border-radius:40px; padding:10px 18px; }

  /* ===== faq ===== */
  .ev-faq__grid{ display:grid; grid-template-columns:.7fr 1fr; gap:clamp(2rem,1rem + 4vw,5rem); align-items:start; }
  .ev-faq__title{ font-size:var(--step-2); margin-top:.3em; }
  .faq{ border-top:1px solid var(--hair); }
  .faq:last-child{ border-bottom:1px solid var(--hair); }
  .faq__q{ display:flex; align-items:center; justify-content:space-between; gap:1.2em; padding:1.25rem 0; cursor:pointer; list-style:none; font-family:var(--serif); font-size:var(--step-1); color:var(--cream); }
  .faq__q::-webkit-details-marker{ display:none; }
  .faq__icon{ position:relative; flex:0 0 auto; width:16px; height:16px; }
  .faq__icon::before,.faq__icon::after{ content:''; position:absolute; background:var(--citron); transition:transform var(--t-med) var(--ease); }
  .faq__icon::before{ left:0; top:7px; width:16px; height:2px; }
  .faq__icon::after{ left:7px; top:0; width:2px; height:16px; }
  .faq[open] .faq__icon::after{ transform:scaleY(0); }
  .faq__a{ color:var(--mist); margin:0 0 1.4rem; font-size:var(--step-0); }
  @media(max-width:820px){ .ev-faq__grid{ grid-template-columns:1fr; gap:1.5rem; } }

  /* ===== final cta ===== */
  .ev-final{ text-align:center; background:radial-gradient(120% 140% at 50% 0%, var(--night) 0%, var(--abyss) 62%); }
  .ev-final__inner{ max-width:640px; margin-inline:auto; }
  .ev-final__title{ font-size:var(--step-3); font-weight:500; max-width:16ch; margin:.35em auto .5em; }
  .ev-final__lede{ color:var(--mist); margin:0 auto 2rem; }
  .ev-final__cta{ display:flex; flex-wrap:wrap; gap:14px; justify-content:center; }
</style>
