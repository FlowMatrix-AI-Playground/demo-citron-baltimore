---
import D3Base from '../../layouts/D3Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';
import exterior from '../../assets/img/exterior.jpg';
import dining from '../../assets/img/dining-room.jpg';
import offpremise from '../../assets/img/room-offpremise.jpg';
import coveGala from '../../assets/img/cove-gala.jpg';
import crab from '../../assets/img/food-crabcake.jpg';
import tuna from '../../assets/img/food-tuna.jpg';
import courtyard from '../../assets/img/courtyard-gathering.jpg';
import terrace from '../../assets/img/terrace-event.jpg';
import venue from '../../assets/img/room-venue.jpg';
import couple from '../../assets/img/charles-susan.jpg';

// signature scroll reel: three ways to gather, crossfading full-bleed chapters
const reel = [
  { key: 'dine', idx: '01', tag: 'Dine', img: dining, alt: 'The main dining room at Citron, dusk light on the lake',
    title: 'Dinner as the light leaves the water.', href: '/d3/menu', cta: 'The Menu',
    copy: 'Seasonal Modern American and a full sushi bar, three hundred seats turned toward Quarry Lake as the evening settles in.' },
  { key: 'cater', idx: '02', tag: 'Cater', img: offpremise, alt: 'Tented off-premise catering by Citron at dusk',
    title: 'The restaurant, brought to you.', href: '/d3/events', cta: 'Catering',
    copy: 'Four decades of off-premise catering, your tent, home, or office, at any scale. The kitchen travels and the standard travels with it.' },
  { key: 'celebrate', idx: '03', tag: 'Celebrate', img: coveGala, alt: 'A gala set in The Cove event space',
    title: 'Nights the room remembers.', href: '/d3/events', cta: 'Private Events',
    copy: 'Nine private spaces on the water, from a fireside twenty to the whole venue at five hundred, staged for the evening you have in mind.' },
];

// interactive events showcase (booking lives in the portal)
const spaces = [
  { key: 'cove', name: 'The Cove', cap: 'Up to 200', img: coveGala, blurb: 'Our signature indoor room, staged for galas, weddings, and speaker dinners.' },
  { key: 'courtyard', name: 'Waterfront Courtyard', cap: 'Up to 200', img: courtyard, blurb: 'Open sky and the lake as backdrop for the largest outdoor celebrations.' },
  { key: 'terrace', name: 'Waterfront Terrace', cap: 'Up to 50', img: terrace, blurb: 'A heated, open-air terrace at the water’s edge where the sunset does the decorating.' },
  { key: 'venue', name: 'The Entire Venue', cap: 'Up to 500', img: venue, blurb: 'The whole property, indoors and out, given over to your night.' },
];
const spacesMeta = spaces.map(({ key, name, cap, blurb }) => ({ key, name, cap, blurb }));
const reelMeta = reel.map(({ key, idx }) => ({ key, idx }));

const stats = [
  { n: '10', l: 'years on the water' },
  { n: '~14,000', l: 'events catered' },
  { n: '7', l: 'Wine Spectator awards' },
  { n: '500', l: 'guests, at the largest' },
];
---
<D3Base title="Citron Baltimore, Lakeside Dining, Catering & Events at Quarry Lake">
  <!-- ===== HERO (Ken-Burns, full-bleed dusk) ===== -->
  <section class="d3-hero">
    <div class="d3-hero__media" aria-hidden="true">
      <Image src={exterior} alt="" widths={[900, 1300, 1500]} sizes="100vw" loading="eager" fetchpriority="high" format="avif" quality={56} class="d3-hero__img" />
      <div class="d3-hero__scrim"></div>
    </div>
    <div class="d3-wrap d3-hero__inner">
      <p class="d3-eyebrow">Quarry Lake &middot; Baltimore County</p>
      <h1 class="d3-hero__title">Where Baltimore<br/>meets the water<br/><em>at dusk.</em></h1>
      <p class="d3-hero__lede d3-measure">An upscale waterfront restaurant, catering house, and event venue. Seasonal Modern American, a full sushi bar, and a Wine Spectator honored list, all against the fading light.</p>
      <div class="d3-hero__cta">
        <button class="d3-btn" data-cta>Reserve &middot; Pick-Up &middot; Events</button>
        <a class="d3-btn d3-btn--ghost" href="/d3/menu">See the Menu</a>
      </div>
    </div>
    <span class="d3-hero__scroll" aria-hidden="true"><span>Scroll</span></span>
  </section>

  <!-- ===== STATEMENT + STATS ===== -->
  <section class="d3-section d3-intro">
    <div class="d3-wrap d3-intro__grid">
      <p class="d3-eyebrow d3-reveal">Est. 2016</p>
      <h2 class="d3-intro__head d3-reveal" data-delay="1">A caterer from Pimlico built a restaurant on the water, and the city has been celebrating here ever since.</h2>
      <p class="d3-intro__body d3-reveal d3-measure" data-delay="2">Charles and Susan Levine spent thirty years bringing a fine-dining standard to other people’s rooms. In 2016 they finally built one of their own on Quarry Lake, with a kitchen good enough to stand on its own every night. This November marks ten years.</p>
      <a class="d3-arrow d3-reveal" data-delay="3" href="/d3/about">Read our story <span aria-hidden="true">→</span></a>
    </div>

    <ul class="d3-stats d3-wrap" aria-label="By the numbers">
      {stats.map((s, i) => (
        <li class="d3-stats__item d3-reveal" data-delay={String((i % 3) + 1)}>
          <span class="d3-stats__n" data-count={s.n}>{s.n}</span>
          <span class="d3-stats__l">{s.l}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ===== SIGNATURE: SCROLL-DRIVEN CROSSFADING CHAPTERS ===== -->
  <section class="d3-reel" aria-label="Three ways to gather">
    <div class="d3-reel__media" aria-hidden="true">
      {reel.map((c, i) => (
        <Image src={c.img} alt="" data-reel-layer={c.key} decoding="async" fetchpriority="low" widths={[720, 1100, 1200]} sizes="100vw" loading="lazy" format="avif" quality={42} class:list={["d3-reel__layer", { 'is-active': i === 0 }]} />
      ))}
      <div class="d3-reel__scrim"></div>
      <span class="d3-reel__kicker"><span id="d3-reel-idx">01</span> / 03 &middot; Three ways to gather</span>
    </div>
    <div class="d3-reel__steps">
      {reel.map((c) => (
        <article class="d3-reel__step" data-reel-step={c.key}>
          <div class="d3-wrap">
            <div class="d3-reel__card d3-reveal">
              <span class="d3-reel__idx">{c.idx}</span>
              <p class="d3-eyebrow">{c.tag}</p>
              <h2 class="d3-reel__title">{c.title}</h2>
              <p class="d3-reel__copy">{c.copy}</p>
              <a class="d3-arrow" href={c.href}>{c.cta} <span aria-hidden="true">→</span></a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ===== MENU TEASER ===== -->
  <section class="d3-section d3-menu">
    <div class="d3-wrap d3-menu__grid">
      <div class="d3-menu__media d3-reveal">
        <Image src={crab} alt="Maryland style jumbo lump crab cake at Citron" widths={[500, 800]} sizes="(max-width:820px) 90vw, 46vw" loading="lazy" format="avif" quality={58} class="d3-menu__img d3-menu__img--lg" />
        <div class="d3-menu__inset">
          <Image src={tuna} alt="Ahi tuna tartare from the raw bar" widths={[300, 460]} sizes="38vw" loading="lazy" format="avif" quality={56} class="d3-menu__img" />
        </div>
      </div>
      <div class="d3-menu__copy d3-reveal" data-delay="1">
        <p class="d3-eyebrow d3-eyebrow--citron">From the kitchen &amp; the raw bar</p>
        <h2 class="d3-menu__title">Center-cut steaks, day-boat seafood, and a sushi bar built to stand on its own.</h2>
        <p class="d3-measure">Executive Chef Mary Hersh runs a seasonal scratch kitchen. A Maryland crab cake with more crab than binder, a raw bar that surprises the table, and a Wine Spectator honored list built to travel with the menu, not sit apart from it.</p>
        <div class="d3-menu__cta">
          <a class="d3-btn" href="/d3/menu">See the Full Menu</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== INTERACTIVE EVENTS SHOWCASE ===== -->
  <section class="d3-events" id="events-teaser">
    <div class="d3-events__bg" aria-hidden="true">
      {spaces.map((s, i) => (
        <Image src={s.img} alt="" data-ev-layer={s.key} decoding="async" fetchpriority="low" widths={[720, 1000]} sizes="100vw" loading="lazy" format="avif" quality={40} class:list={["d3-events__layer", { 'is-active': i === 0 }]} />
      ))}
      <div class="d3-events__scrim"></div>
    </div>
    <div class="d3-wrap d3-events__content">
      <p class="d3-eyebrow d3-reveal">Events &amp; Private Dining</p>
      <h2 class="d3-events__title d3-reveal" data-delay="1">From a fireside twenty <em>to five hundred</em> on the water.</h2>
      <div class="d3-events__feature d3-reveal" data-delay="1">
        <div class="d3-events__meta">
          <span class="d3-events__name" id="d3-ev-name">{spaces[0].name}</span>
          <span class="d3-events__cap" id="d3-ev-cap">{spaces[0].cap}</span>
        </div>
        <p class="d3-events__blurb d3-measure" id="d3-ev-blurb">{spaces[0].blurb}</p>
      </div>
      <div class="d3-events__thumbs d3-reveal" data-delay="2" aria-label="Featured spaces">
        {spaces.map((s, i) => (
          <button class:list={["d3-thumb", { 'is-active': i === 0 }]} data-space={s.key} aria-pressed={i === 0 ? 'true' : 'false'}>
            <Image src={s.img} alt="" decoding="async" widths={[160, 320]} sizes="120px" loading="lazy" format="avif" quality={48} class="d3-thumb__img" />
            <span class="d3-thumb__label">{s.name}</span>
          </button>
        ))}
      </div>
      <div class="d3-events__ctas d3-reveal" data-delay="3">
        <a class="d3-btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <a class="d3-btn d3-btn--ghost" href="/d3/events">See the Spaces</a>
      </div>
    </div>
  </section>

  <!-- ===== CHARM CITY NOTE ===== -->
  <section class="d3-section d3-charm">
    <div class="d3-wrap d3-charm__grid">
      <div class="d3-charm__media d3-reveal">
        <Image src={couple} alt="Charles and Susan Levine, owners of Citron Baltimore" widths={[400, 680]} sizes="(max-width:820px) 80vw, 36vw" loading="lazy" format="avif" quality={60} class="d3-charm__img" />
      </div>
      <div class="d3-charm__copy d3-reveal" data-delay="1">
        <p class="d3-eyebrow">Charm City, on the water</p>
        <h2 class="d3-charm__title">Baltimore raised us. Pimlico taught us. Quarry Lake is home.</h2>
        <p class="d3-measure">The story starts at the old Pimlico Hotel and runs through four decades of Maryland celebrations, Preakness weeks, blue-crab summers, and the kind of hospitality a city only trusts to its own. We are proud to be Baltimore’s table.</p>
        <ul class="d3-charm__chips">
          <li>Wine Spectator 2019–2025</li>
          <li>Full sushi bar</li>
          <li>PhRMA-compliant menus</li>
          <li>Off-premise catering</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="d3-section d3-final">
    <div class="d3-wrap d3-final__inner d3-reveal">
      <p class="d3-eyebrow">Pull up a chair</p>
      <h2 class="d3-final__title">However you’d like to be hosted, it starts here.</h2>
      <button class="d3-btn d3-final__btn" data-cta>Reserve &middot; Pick-Up &middot; Events</button>
    </div>
  </section>

  <script define:vars={{ spacesMeta, reelMeta }}>
    // --- scroll-driven reel: activate the layer for the centered step ---
    (() => {
      const layers = document.querySelectorAll('.d3-reel__layer');
      const steps = document.querySelectorAll('.d3-reel__step');
      const idxEl = document.getElementById('d3-reel-idx');
      if (!steps.length || !('IntersectionObserver' in window)) return;
      const setActive = (key) => {
        layers.forEach((l) => l.classList.toggle('is-active', l.getAttribute('data-reel-layer') === key));
        const m = reelMeta.find((d) => d.key === key);
        if (m && idxEl) idxEl.textContent = m.idx;
      };
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => { if (en.isIntersecting) setActive(en.target.getAttribute('data-reel-step')); });
      }, { rootMargin: '-45% 0px -45% 0px', threshold: 0 });
      steps.forEach((s) => io.observe(s));
    })();

    // --- interactive events showcase ---
    (() => {
      const layers = document.querySelectorAll('.d3-events__layer');
      const thumbs = document.querySelectorAll('.d3-thumb');
      const nameEl = document.getElementById('d3-ev-name');
      const capEl = document.getElementById('d3-ev-cap');
      const blurbEl = document.getElementById('d3-ev-blurb');
      if (!thumbs.length) return;
      const select = (key) => {
        const s = spacesMeta.find((d) => d.key === key);
        if (!s) return;
        layers.forEach((l) => l.classList.toggle('is-active', l.getAttribute('data-ev-layer') === key));
        thumbs.forEach((t) => { const on = t.getAttribute('data-space') === key; t.classList.toggle('is-active', on); t.setAttribute('aria-pressed', on ? 'true' : 'false'); });
        nameEl.textContent = s.name; capEl.textContent = s.cap; blurbEl.textContent = s.blurb;
      };
      thumbs.forEach((t) => {
        const key = t.getAttribute('data-space');
        t.addEventListener('mouseenter', () => select(key));
        t.addEventListener('focus', () => select(key));
        t.addEventListener('click', () => select(key));
      });
    })();
  </script>

  <style>
    /* ===== HERO ===== */
    .d3-hero{ position:relative; min-height:100svh; display:flex; align-items:flex-end; overflow:hidden; color:var(--d3-cream); }
    .d3-hero__media{ position:absolute; inset:0; }
    .d3-hero__img{ width:100%; height:100%; object-fit:cover; object-position:50% 46%; transform-origin:50% 54%; animation:d3-ken 30s ease-in-out infinite alternate; }
    @keyframes d3-ken{ from{ transform:scale(1.03); } to{ transform:scale(1.09); } }
    /* graded into the indigo/amber twilight, building stays clearly readable */
    .d3-hero__scrim{ position:absolute; inset:0; background:
      radial-gradient(130% 92% at 50% 118%, color-mix(in oklab, var(--d3-amber) 26%, transparent) 0%, transparent 54%),
      linear-gradient(180deg, rgba(16,21,28,.44) 0%, rgba(16,21,28,.14) 30%, rgba(16,21,28,.52) 62%, rgba(16,21,28,.9) 100%),
      linear-gradient(92deg, rgba(16,21,28,.72) 0%, rgba(16,21,28,.36) 34%, rgba(16,21,28,.06) 66%); }
    .d3-hero__inner{ position:relative; z-index:2; padding-block:clamp(3rem, 2rem + 7vw, 7rem); max-width:880px; }
    .d3-hero__title{ font-size:var(--d3-hero); line-height:1.03; letter-spacing:.004em; }
    .d3-hero__title em{ font-style:normal; color:var(--d3-amber); }
    .d3-hero__lede{ color:var(--d3-cream-dim); font-size:var(--d3-s-1); margin-top:1.7rem; max-width:56ch; }
    .d3-hero__cta{ display:flex; flex-wrap:wrap; gap:14px; margin-top:2.5rem; }
    .d3-hero__scroll{ position:absolute; left:50%; bottom:22px; transform:translateX(-50%); z-index:2; display:flex; flex-direction:column; align-items:center; gap:10px; }
    .d3-hero__scroll span{ font-family:var(--d3-body); font-weight:700; font-size:.6rem; letter-spacing:.3em; text-transform:uppercase; color:var(--d3-mist); }
    .d3-hero__scroll::after{ content:""; width:1px; height:44px; background:linear-gradient(var(--d3-amber), transparent); animation:d3-drop 2.4s ease-in-out infinite; }
    @keyframes d3-drop{ 0%,100%{ opacity:.4; transform:scaleY(.6); transform-origin:top; } 50%{ opacity:1; transform:scaleY(1); transform-origin:top; } }
    @media (max-width:640px){
      .d3-hero__scroll{ display:none; }
      /* keep the lit building framed and the type crisp on a tall portrait viewport */
      .d3-hero__img{ object-position:50% 40%; }
      .d3-hero__scrim{ background:
        radial-gradient(160% 78% at 50% 116%, color-mix(in oklab, var(--d3-amber) 22%, transparent) 0%, transparent 56%),
        linear-gradient(180deg, rgba(16,21,28,.5) 0%, rgba(16,21,28,.26) 34%, rgba(16,21,28,.66) 66%, rgba(16,21,28,.95) 100%); }
      .d3-hero__inner{ max-width:none; }
    }

    /* ===== INTRO / STATS ===== */
    .d3-intro__grid{ display:grid; grid-template-columns:1fr; gap:0; }
    .d3-intro__head{ font-size:var(--d3-s-3); max-width:22ch; margin:0 0 .55em; color:var(--d3-cream); line-height:1.08; }
    .d3-intro__body{ color:var(--d3-mist); font-size:var(--d3-s-1); }
    .d3-intro__grid .d3-arrow{ margin-top:2em; }
    .d3-stats{ display:grid; grid-template-columns:repeat(4,1fr); gap:2rem; margin-top:clamp(3rem, 2rem + 4vw, 5rem); padding-top:2.4rem; border-top:1px solid var(--d3-hair); }
    .d3-stats__item{ display:flex; flex-direction:column; gap:.35rem; }
    .d3-stats__n{ font-family:var(--d3-display); font-size:var(--d3-s-3); color:var(--d3-amber); line-height:1; }
    .d3-stats__l{ font-size:var(--d3-s--1); color:var(--d3-mist-dim); letter-spacing:.02em; }
    @media (max-width:720px){ .d3-stats{ grid-template-columns:1fr 1fr; gap:1.8rem 2rem; } }

    /* ===== SIGNATURE REEL ===== */
    .d3-reel{ position:relative; background:var(--d3-ink); }
    .d3-reel__media{ position:sticky; top:0; height:100svh; margin-bottom:-100svh; overflow:hidden; }
    .d3-reel__layer{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0; transform:scale(1.06); transition:opacity 900ms var(--d3-ease), transform 1700ms var(--d3-ease); }
    .d3-reel__layer.is-active{ opacity:1; transform:scale(1); }
    .d3-reel__scrim{ position:absolute; inset:0; background:
      linear-gradient(90deg, rgba(8,11,16,.9) 0%, rgba(8,11,16,.55) 46%, rgba(8,11,16,.12) 100%),
      linear-gradient(0deg, rgba(8,11,16,.72) 0%, transparent 40%); }
    .d3-reel__kicker{ position:absolute; left:var(--d3-gutter); top:calc(80px + 1.4rem); z-index:2; font-family:var(--d3-body); font-weight:700; font-size:.66rem; letter-spacing:.22em; text-transform:uppercase; color:var(--d3-amber); }
    .d3-reel__kicker span{ color:var(--d3-cream); }
    .d3-reel__steps{ position:relative; z-index:2; }
    .d3-reel__step{ min-height:100svh; display:flex; align-items:center; }
    .d3-reel__card{ max-width:520px; }
    .d3-reel__idx{ font-family:var(--d3-display); font-size:var(--d3-s-4); color:color-mix(in oklab, var(--d3-amber) 42%, transparent); line-height:.8; display:block; margin-bottom:.2em; }
    .d3-reel__title{ font-size:var(--d3-s-3); color:var(--d3-cream); line-height:1.06; margin-bottom:.4em; }
    .d3-reel__copy{ color:var(--d3-cream-dim); font-size:var(--d3-s-1); margin-bottom:1.6em; }

    /* ===== MENU TEASER ===== */
    .d3-menu__grid{ display:grid; grid-template-columns:1.05fr 1fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:center; }
    .d3-menu__media{ position:relative; }
    .d3-menu__img{ border-radius:var(--d3-radius-md); width:100%; object-fit:cover; }
    .d3-menu__img--lg{ aspect-ratio:4/5; }
    .d3-menu__inset{ position:absolute; left:-7%; bottom:-9%; width:42%; border:6px solid var(--d3-bg); border-radius:var(--d3-radius-md); overflow:hidden; box-shadow:0 34px 80px -34px rgba(0,0,0,.8); }
    .d3-menu__inset .d3-menu__img{ aspect-ratio:1/1; }
    .d3-menu__title{ font-size:var(--d3-s-2); margin:0 0 .6em; line-height:1.12; }
    .d3-menu__copy p{ color:var(--d3-mist); }
    .d3-menu__cta{ margin-top:2.2rem; }
    @media (max-width:820px){
      .d3-menu__grid{ grid-template-columns:1fr; gap:3.4rem; }
      .d3-menu__inset{ left:auto; right:4%; bottom:-7%; width:38%; }
    }

    /* ===== EVENTS SHOWCASE ===== */
    .d3-events{ position:relative; color:var(--d3-cream); overflow:hidden; padding-block:clamp(4.5rem, 3rem + 8vw, 9rem); }
    .d3-events__bg{ position:absolute; inset:0; }
    .d3-events__layer{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0; transform:scale(1.05); transition:opacity 900ms var(--d3-ease), transform 1500ms var(--d3-ease); }
    .d3-events__layer.is-active{ opacity:1; transform:scale(1); }
    .d3-events__scrim{ position:absolute; inset:0; background:linear-gradient(100deg, rgba(8,11,16,.94) 8%, rgba(8,11,16,.66) 52%, rgba(8,11,16,.34) 100%); }
    .d3-events__content{ position:relative; z-index:2; max-width:680px; }
    .d3-events__title{ font-size:var(--d3-s-3); line-height:1.06; margin-bottom:.5em; }
    .d3-events__title em{ font-style:normal; color:var(--d3-amber); }
    .d3-events__feature{ min-height:8.5em; }
    .d3-events__meta{ display:flex; align-items:baseline; gap:1em; }
    .d3-events__name{ font-family:var(--d3-display); font-size:var(--d3-s-2); color:var(--d3-cream); }
    .d3-events__cap{ font-size:.72rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:var(--d3-amber); }
    .d3-events__blurb{ color:var(--d3-mist); font-size:var(--d3-s-0); margin-top:.5em; }
    .d3-events__thumbs{ display:flex; gap:12px; margin-top:1.8rem; flex-wrap:wrap; }
    .d3-thumb{ position:relative; width:120px; height:80px; padding:0; border:1px solid var(--d3-hair); border-radius:var(--d3-radius); overflow:hidden; cursor:pointer; background:none; transition:border-color var(--d3-med), transform var(--d3-fast) var(--d3-ease); }
    .d3-thumb__img{ width:100%; height:100%; object-fit:cover; opacity:.5; transition:opacity var(--d3-med), transform var(--d3-slow) var(--d3-ease); }
    .d3-thumb:hover{ transform:translateY(-3px); }
    .d3-thumb:hover .d3-thumb__img{ transform:scale(1.08); }
    .d3-thumb.is-active{ border-color:var(--d3-amber); }
    .d3-thumb.is-active .d3-thumb__img{ opacity:1; }
    .d3-thumb__label{ position:absolute; left:0; right:0; bottom:0; padding:14px 8px 5px; font-size:.58rem; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--d3-cream); background:linear-gradient(to top, rgba(8,11,16,.92), transparent); text-align:center; }
