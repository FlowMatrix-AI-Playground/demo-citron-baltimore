---
import D3Base from '../../layouts/D3Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';
import coveWedding from '../../assets/img/cove-wedding.jpg';
import cove from '../../assets/img/room-cove.jpg';
import courtyard from '../../assets/img/courtyard-gathering.jpg';
import terrace from '../../assets/img/terrace-event.jpg';
import venue from '../../assets/img/room-venue.jpg';
import offpremise from '../../assets/img/room-offpremise.jpg';

// marquee spaces only, the full nine-space inventory lives in the portal
const spaces = [
  { name: 'The Cove', cap: 'Up to 200', img: cove, blurb: 'Our signature indoor room, staged for galas, weddings, and speaker dinners.' },
  { name: 'Waterfront Courtyard', cap: 'Up to 200', img: courtyard, blurb: 'Open sky and the lake as backdrop for the largest outdoor celebrations.' },
  { name: 'Waterfront Terrace', cap: 'Up to 50', img: terrace, blurb: 'A heated, open-air terrace at the water’s edge where the sunset does the decorating.' },
  { name: 'The Entire Venue', cap: 'Up to 500', img: venue, blurb: 'The whole property, indoors and out, given over to your night.' },
];

const services = ['Floral & Decor', 'Linens & Tabletop', 'AV & Production (Savant)', 'Event Planning', 'Photography', 'Entertainment'];

const faqs = [
  { q: 'How many guests can you host?', a: 'From a fireside twenty to five hundred across the whole property. Nine private spaces in total, the Planning Portal shows each room, its capacity, and live availability so you can match the space to your headcount.' },
  { q: 'How far ahead should we book?', a: 'For weddings and large galas, six to twelve months is ideal, especially May through October and December. Corporate dinners and smaller celebrations often come together in a few weeks. When a date matters, start early in the portal to hold it.' },
  { q: 'Can we bring outside vendors?', a: 'Absolutely. We partner with your florist, planner, band, or photographer, and we can bring our own preferred teams if you would rather we handle everything. Catering and bar service stay in-house so the food and wine hold to our standard.' },
  { q: 'Do you offer PhRMA-compliant menus?', a: 'Yes. We build fully PhRMA-compliant corporate and pharmaceutical menus with the documentation your compliance team needs, without sacrificing the Citron kitchen’s standard.' },
];
---
<D3Base
  title="Events & Private Dining, Citron Baltimore"
  description="Waterfront private events and off-premise catering in Baltimore, from a fireside twenty to five hundred guests."
>
  <!-- ===== HERO ===== -->
  <section class="d3-ehero" aria-label="Events & Private Dining">
    <div class="d3-ehero__bg" aria-hidden="true">
      <Image src={coveWedding} alt="" widths={[900, 1300, 1500]} sizes="100vw" loading="eager" fetchpriority="high" format="avif" quality={52} class="d3-ehero__img" />
      <div class="d3-ehero__scrim"></div>
    </div>
    <div class="d3-wrap d3-ehero__content">
      <p class="d3-eyebrow">Events &amp; Private Dining</p>
      <h1 class="d3-ehero__title">Baltimore celebrates on the water.</h1>
      <p class="d3-ehero__lede d3-measure">One waterfront venue, one catering house, one kitchen, from a fireside twenty to five hundred guests, on-site or wherever your day takes place.</p>
      <div class="d3-ehero__cta">
        <a class="d3-btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <button class="d3-btn d3-btn--ghost" data-cta>Reserve &middot; Pick-Up &middot; Events</button>
      </div>
    </div>
  </section>

  <!-- ===== INTRO ===== -->
  <section class="d3-section d3-eintro">
    <div class="d3-wrap d3-eintro__grid">
      <p class="d3-eyebrow d3-reveal">The venue &amp; the catering house</p>
      <h2 class="d3-eintro__head d3-reveal" data-delay="1">Forty years of celebrations, and a room on Quarry Lake to hold them.</h2>
      <div class="d3-eintro__body d3-reveal d3-measure" data-delay="2">
        <p>Before The Cove opened its doors in 2016, we spent four decades as one of Baltimore’s trusted off-premise caterers, first as Charles Levine Caterers, with roughly fourteen thousand events behind us. That experience runs through every celebration we host today.</p>
        <p>Seasonal Modern American menus, a full sushi bar, and a Wine Spectator honored list. Fully PhRMA-compliant corporate programs. Full-service events, seven days a week, at whatever scale your day requires.</p>
      </div>
    </div>
  </section>

  <!-- ===== MARQUEE SPACES ===== -->
  <section class="d3-section d3-spaces" id="spaces">
    <div class="d3-wrap">
      <header class="d3-spaces__head d3-reveal">
        <p class="d3-eyebrow">A few of our rooms</p>
        <h2 class="d3-spaces__title">Spaces made for the moment.</h2>
        <p class="d3-spaces__note d3-measure">Nine spaces in total, explore and book them all in the portal. Here are four that show the range.</p>
      </header>
      <div class="d3-spaces__grid">
        {spaces.map((s, i) => (
          <article class="d3-space d3-reveal" data-delay={String((i % 3) + 1)}>
            <div class="d3-space__media">
              <Image src={s.img} alt={`${s.name} set for a private event at Citron Baltimore`} widths={[400, 700, 900]} sizes="(max-width:900px) 90vw, 30vw" loading="lazy" format="avif" quality={54} class="d3-space__img" />
              <span class="d3-space__cap">{s.cap}</span>
            </div>
            <h3 class="d3-space__name">{s.name}</h3>
            <p class="d3-space__blurb">{s.blurb}</p>
            <a class="d3-arrow d3-space__cta" href={SITE.portalUrl}>Plan in the Portal <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
      <p class="d3-spaces__all d3-reveal">
        <a class="d3-btn d3-btn--ghost" href={SITE.portalUrl}>Explore all nine spaces in the portal</a>
      </p>
    </div>
  </section>

  <!-- ===== CATERING ===== -->
  <section class="d3-section d3-cater">
    <div class="d3-wrap d3-cater__grid">
      <div class="d3-cater__media d3-reveal">
        <Image src={offpremise} alt="Tented off-premise catering by Citron at dusk" widths={[500, 800, 900]} sizes="(max-width:820px) 90vw, 48vw" loading="lazy" format="avif" quality={56} class="d3-cater__img" />
      </div>
      <div class="d3-cater__copy d3-reveal" data-delay="1">
        <p class="d3-eyebrow d3-eyebrow--citron">Off-premise catering</p>
        <h2 class="d3-cater__title">We’ll bring the restaurant to you.</h2>
        <p class="d3-measure">Your tent, your home, your office, a hillside, or a ballroom across town, the Citron kitchen travels, and the standard travels with it. Four decades of off-premise experience means we have solved the logistics before you have thought to ask, at any scale from an intimate dinner to a several-hundred-guest gala.</p>
        <div class="d3-cater__cta">
          <a class="d3-btn" href={SITE.portalUrl}>Start Your Catering Plan</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="d3-section d3-services">
    <div class="d3-wrap d3-services__inner d3-reveal">
      <p class="d3-eyebrow">Everything under one roof</p>
      <h2 class="d3-services__title">A full-service team, so you host and we handle the rest.</h2>
      <ul class="d3-services__list">
        {services.map((s) => (<li class="d3-services__item">{s}</li>))}
      </ul>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="d3-section d3-faq">
    <div class="d3-wrap d3-faq__grid">
      <header class="d3-faq__head d3-reveal">
        <p class="d3-eyebrow">Good to know</p>
        <h2 class="d3-faq__title">Questions, answered.</h2>
      </header>
      <div class="d3-faq__list d3-reveal" data-delay="1">
        {faqs.map((f) => (
          <details class="d3-faqi">
            <summary class="d3-faqi__q">
              <span>{f.q}</span>
              <span class="d3-faqi__icon" aria-hidden="true"></span>
            </summary>
            <p class="d3-faqi__a d3-measure">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="d3-section d3-efinal">
    <div class="d3-wrap d3-efinal__inner d3-reveal">
      <p class="d3-eyebrow">Let’s plan your day</p>
      <h2 class="d3-efinal__title">Your celebration starts in the portal.</h2>
      <p class="d3-efinal__lede d3-measure">Browse every space, check dates, and share the shape of your event, we will take it from there.</p>
      <div class="d3-efinal__cta">
        <a class="d3-btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <button class="d3-btn d3-btn--ghost" data-cta>Reserve &middot; Pick-Up &middot; Events</button>
      </div>
    </div>
  </section>

  <style>
    /* hero */
    .d3-ehero{ position:relative; min-height:clamp(66vh, 60vh + 8vw, 84vh); display:flex; align-items:flex-end; overflow:hidden; color:var(--d3-cream); }
    .d3-ehero__bg{ position:absolute; inset:0; }
    .d3-ehero__img{ width:100%; height:100%; object-fit:cover; }
    .d3-ehero__scrim{ position:absolute; inset:0; background:linear-gradient(180deg, rgba(16,21,28,.55) 0%, rgba(16,21,28,.28) 40%, rgba(16,21,28,.92) 100%); }
    .d3-ehero__content{ position:relative; z-index:2; max-width:760px; padding-block:clamp(3rem, 2rem + 6vw, 6rem); }
    .d3-ehero__title{ font-size:var(--d3-s-4); line-height:1.03; max-width:14ch; }
    .d3-ehero__lede{ color:var(--d3-cream-dim); font-size:var(--d3-s-1); margin-top:1.1rem; }
    .d3-ehero__cta{ display:flex; flex-wrap:wrap; gap:14px; margin-top:2.2rem; }

    /* intro */
    .d3-eintro__grid{ display:grid; grid-template-columns:1fr; gap:0; }
    .d3-eintro__head{ font-size:var(--d3-s-3); max-width:20ch; margin:0 0 .6em; line-height:1.08; }
    .d3-eintro__body{ color:var(--d3-mist); font-size:var(--d3-s-1); }
    .d3-eintro__body p + p{ margin-top:1.1em; }

    /* spaces */
    .d3-spaces{ background:var(--d3-bg-2); }
    .d3-spaces__head{ max-width:44ch; margin-bottom:clamp(2rem, 1rem + 3vw, 3.4rem); }
    .d3-spaces__title{ font-size:var(--d3-s-2); }
    .d3-spaces__note{ margin-top:.7em; color:var(--d3-mist); font-size:var(--d3-s-0); }
    .d3-spaces__grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:clamp(1.2rem, .6rem + 2vw, 2rem); }
    .d3-space{ display:flex; flex-direction:column; }
    .d3-space__media{ position:relative; aspect-ratio:4/5; overflow:hidden; border-radius:var(--d3-radius-md); margin-bottom:1.2rem; }
    .d3-space__img{ width:100%; height:100%; object-fit:cover; transition:transform var(--d3-slow) var(--d3-ease); }
    .d3-space:hover .d3-space__img{ transform:scale(1.06); }
    .d3-space__cap{ position:absolute; left:12px; top:12px; font-size:.64rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--d3-ink); background:var(--d3-amber); padding:6px 11px; border-radius:40px; }
    .d3-space__name{ font-family:var(--d3-display); font-size:var(--d3-s-1); color:var(--d3-cream); }
    .d3-space__blurb{ color:var(--d3-mist); font-size:var(--d3-s--1); margin:.4em 0 1em; line-height:1.6; }
    .d3-space__cta{ margin-top:auto; }
    .d3-spaces__all{ margin-top:clamp(2.4rem, 1.5rem + 3vw, 3.6rem); }
    @media (max-width:980px){ .d3-spaces__grid{ grid-template-columns:1fr 1fr; gap:2rem; } }
    @media (max-width:560px){ .d3-spaces__grid{ grid-template-columns:1fr; } .d3-space__media{ aspect-ratio:16/10; } }

    /* catering */
    .d3-cater__grid{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:center; }
    .d3-cater__img{ width:100%; aspect-ratio:5/4; object-fit:cover; border-radius:var(--d3-radius-md); }
    .d3-cater__title{ font-size:var(--d3-s-2); margin:0 0 .6em; line-height:1.12; }
    .d3-cater__copy p{ color:var(--d3-mist); }
    .d3-cater__cta{ margin-top:2rem; }
    @media (max-width:820px){ .d3-cater__grid{ grid-template-columns:1fr; gap:2.4rem; } }

    /* services */
    .d3-services{ background:var(--d3-bg-2); }
    .d3-services__inner{ max-width:820px; }
    .d3-services__title{ font-size:var(--d3-s-2); max-width:22ch; }
    .d3-services__list{ display:flex; flex-wrap:wrap; gap:12px; margin-top:2rem; }
    .d3-services__item{ font-size:.78rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--d3-amber-soft); border:1px solid color-mix(in oklab, var(--d3-amber) 40%, transparent); border-radius:40px; padding:10px 18px; }

    /* faq */
    .d3-faq__grid{ display:grid; grid-template-columns:.7fr 1fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:start; }
    .d3-faq__title{ font-size:var(--d3-s-2); }
    .d3-faqi{ border-top:1px solid var(--d3-hair); }
    .d3-faqi:last-child{ border-bottom:1px solid var(--d3-hair); }
    .d3-faqi__q{ display:flex; align-items:center; justify-content:space-between; gap:1.2em; padding:1.3rem 0; cursor:pointer; list-style:none; font-family:var(--d3-display); font-size:var(--d3-s-1); color:var(--d3-cream); }
    .d3-faqi__q::-webkit-details-marker{ display:none; }
    .d3-faqi__icon{ position:relative; flex:0 0 auto; width:16px; height:16px; }
    .d3-faqi__icon::before,.d3-faqi__icon::after{ content:''; position:absolute; background:var(--d3-amber); transition:transform var(--d3-med) var(--d3-ease); }
    .d3-faqi__icon::before{ left:0; top:7px; width:16px; height:2px; }
    .d3-faqi__icon::after{ left:7px; top:0; width:2px; height:16px; }
    .d3-faqi[open] .d3-faqi__icon::after{ transform:scaleY(0); }
    .d3-faqi__a{ color:var(--d3-mist); margin:0 0 1.4rem; font-size:var(--d3-s-0); }
    @media (max-width:820px){ .d3-faq__grid{ grid-template-columns:1fr; gap:1.5rem; } }

    /* final */
    .d3-efinal{ text-align:center; background:radial-gradient(120% 150% at 50% 0%, var(--d3-bg-3) 0%, var(--d3-bg) 62%); }
    .d3-efinal__inner{ max-width:640px; margin-inline:auto; }
    .d3-efinal__title{ font-size:var(--d3-s-3); max-width:16ch; margin:0 auto .55em; line-height:1.1; }
    .d3-efinal__lede{ color:var(--d3-mist); margin:0 auto 2.2rem; }
    .d3-efinal__cta{ display:flex; flex-wrap:wrap; gap:14px; justify-content:center; }
  </style>
</D3Base>
