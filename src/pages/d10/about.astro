---
import D10Base from '../../layouts/D10Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';
import couple from '../../assets/img/charles-susan.jpg';
import charles from '../../assets/img/charles.jpg';
import dining from '../../assets/img/dining-room.jpg';
import exterior from '../../assets/img/exterior.jpg';

const desc = 'The story of Citron Baltimore: from the old Pimlico Hotel to a waterfront kitchen on Quarry Lake, family-owned by Charles and Susan Levine, ten years this November.';

const timeline = [
  { year: '1980s', h: 'A start at the Pimlico Hotel', d: 'The Levines learn the trade in one of Baltimore’s great old rooms, cooking for a city that takes its celebrations seriously.' },
  { year: 'The catering years', h: 'Forty years on the road', d: 'Citron Caterers brings a fine-dining standard to other people’s tents, homes, and ballrooms, roughly fourteen thousand events across Maryland.' },
  { year: '2016', h: 'A kitchen of their own', d: 'Charles and Susan build a waterfront restaurant on Quarry Lake, with a kitchen good enough to stand on its own every night.' },
  { year: '2019–2025', h: 'Seven straight awards', d: 'The wine list holds the Wine Spectator Award of Excellence every year running, seven in a row and counting.' },
  { year: 'Nov 2026', h: 'Ten years on the water', d: 'A decade of weddings, galas, blue-crab summers, and Wednesday-night regulars. The anniversary lands this November.' },
];

const values = [
  { k: 'More crab than binder', d: 'The 8 oz jumbo lump crab cake is the house test. If it holds together with technique instead of filler, we did it right.' },
  { k: 'The list travels with the plate', d: 'A Wine Spectator honored cellar built to pour alongside the menu, not sit apart from it in a leather folder.' },
  { k: 'Hospitality Baltimore trusts', d: 'Forty years of Preakness weeks and family milestones taught us that the room matters as much as the food.' },
];
---
<D10Base title="About, Citron Baltimore" description={desc}>
  <!-- ===================== HERO ===================== -->
  <section class="d10-ahero">
    <div class="d10-ahero__glow" aria-hidden="true"></div>
    <div class="d10-wrap d10-ahero__inner">
      <div class="d10-ahero__copy">
        <p class="d10-eyebrow d10-eyebrow--citron d10-rv">Our story</p>
        <h1 class="d10-ahero__title d10-rv" data-delay="1">Baltimore raised us. Pimlico taught us. <em>Quarry Lake is home.</em></h1>
        <p class="d10-ahero__lede d10-rv" data-delay="2">Citron is a family restaurant in the truest sense: Charles and Susan Levine at the front, a forty-year catering company behind the kitchen, and a city that has been celebrating with them since the Pimlico Hotel. This November marks ten years on the water.</p>
      </div>
      <div class="d10-ahero__media d10-rv" data-delay="2">
        <div class="d10-media">
          <Image src={couple} alt="Charles and Susan Levine, owners of Citron Baltimore" widths={[420, 680]} sizes="(max-width:900px) 80vw, 40vw" loading="eager" fetchpriority="high" format="avif" quality={56} />
        </div>
        <span class="d10-ahero__tag">Charles &amp; Susan Levine · Owners</span>
      </div>
    </div>
  </section>

  <!-- ===================== STATEMENT ===================== -->
  <section class="d10-section d10-section--wine d10-astate">
    <div class="d10-wrap">
      <p class="d10-astate__lead d10-rv">
        <span class="d10-astate__drop" aria-hidden="true">F</span>orty years ago, a caterer from Pimlico set out to bring a fine-dining standard to other people’s rooms. In 2016 that caterer finally built one of his own, on Quarry Lake, and gave it a kitchen, a full sushi bar, and a wine list that would go on to win seven straight awards. <em>Everything you taste here was earned on the road first.</em>
      </p>
    </div>
  </section>

  <!-- ===================== TIMELINE ===================== -->
  <section class="d10-section d10-atime">
    <div class="d10-wrap d10-atime__grid">
      <header class="d10-atime__head">
        <p class="d10-eyebrow d10-rv">Four decades, one family</p>
        <h2 class="d10-atime__title d10-rv" data-delay="1">The road to the water.</h2>
        <div class="d10-atime__media d10-rv" data-delay="2">
          <div class="d10-media"><Image src={exterior} alt="The waterfront exterior of Citron at Quarry Lake" widths={[420, 680]} sizes="(max-width:900px) 90vw, 40vw" loading="lazy" format="avif" quality={54} /></div>
        </div>
      </header>
      <ol class="d10-atime__list">
        {timeline.map((t, i) => (
          <li class="d10-tl d10-rv" data-delay={String((i % 3) + 1)}>
            <span class="d10-tl__year">{t.year}</span>
            <div class="d10-tl__body">
              <h3 class="d10-tl__h">{t.h}</h3>
              <p class="d10-tl__d">{t.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===================== VALUES ===================== -->
  <section class="d10-section d10-section--cream d10-vals">
    <div class="d10-wrap">
      <header class="d10-vals__head d10-rv">
        <p class="d10-eyebrow">What we hold to</p>
        <h2 class="d10-vals__title">Three things we refuse to compromise.</h2>
      </header>
      <div class="d10-vals__grid">
        {values.map((v, i) => (
          <article class="d10-val d10-rv" data-delay={String(i + 1)}>
            <span class="d10-val__no" aria-hidden="true">0{i + 1}</span>
            <h3 class="d10-val__k">{v.k}</h3>
            <p class="d10-val__d">{v.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CHEF / KITCHEN ===================== -->
  <section class="d10-section d10-chef">
    <div class="d10-wrap d10-chef__grid">
      <div class="d10-chef__media d10-rv">
        <div class="d10-media d10-chef__lg"><Image src={dining} alt="The main dining room at Citron Baltimore" widths={[440, 720]} sizes="(max-width:820px) 90vw, 46vw" loading="lazy" format="avif" quality={54} /></div>
        <div class="d10-media d10-chef__inset"><Image src={charles} alt="Charles Levine in the dining room" widths={[220, 380]} sizes="26vw" loading="lazy" format="avif" quality={52} /></div>
      </div>
      <div class="d10-chef__copy">
        <p class="d10-eyebrow d10-eyebrow--citron d10-rv">In the kitchen</p>
        <h2 class="d10-chef__title d10-rv" data-delay="1">A seasonal scratch kitchen, run by <em>Executive Chef Mary Hersh.</em></h2>
        <p class="d10-measure d10-rv" data-delay="2">The menu turns with the season and the day-boat catch: prime center-cut steaks, a designer sushi bar that stands on its own, and Maryland seafood plated with more generosity than restraint. Three hundred seats, a full raw bar, and a cellar that has held the Award of Excellence every year since 2019.</p>
        <ul class="d10-chef__facts d10-rv" data-delay="2">
          <li><span data-count="300">300</span> seats at the lake</li>
          <li><span data-count="10">10</span> years this November</li>
          <li><span data-count="7">7</span> Wine Spectator awards</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="d10-section d10-final2">
    <div class="d10-wrap d10-final2__inner">
      <p class="d10-eyebrow d10-eyebrow--citron d10-rv">Come see the water</p>
      <h2 class="d10-final2__title d10-rv" data-delay="1">Ten years in, and still <em>setting the table.</em></h2>
      <div class="d10-final2__row d10-rv" data-delay="2">
        <button class="d10-btn" data-cta>Reserve · Pick-Up · Events</button>
        <a class="d10-btn d10-btn--ghost" href="/d10/contact">Find Us</a>
      </div>
    </div>
  </section>

  <style>
    /* ===================== HERO ===================== */
    .d10-ahero{ position:relative; overflow:hidden; padding-top:clamp(2rem, 1rem + 3vw, 4rem); }
    .d10-ahero__glow{ position:absolute; top:-20%; right:-8%; width:52vw; height:52vw; max-width:640px; max-height:640px; background:radial-gradient(circle, rgba(220,228,63,.14), transparent 62%); pointer-events:none; }
    .d10-ahero__inner{ display:grid; grid-template-columns:1.1fr 0.9fr; gap:clamp(1.6rem, 0.6rem + 4vw, 4rem); align-items:center; padding-block:clamp(2rem, 1.2rem + 3vw, 4rem); }
    .d10-ahero__title{ font-size:var(--d10-s-4); line-height:0.98; margin:0.3em 0 0.5em; }
    .d10-ahero__title em{ color:var(--d10-citron); }
    .d10-ahero__lede{ color:var(--d10-cream-2); font-size:var(--d10-s-1); max-width:52ch; line-height:1.5; }
    .d10-ahero__media{ position:relative; }
    .d10-ahero__media .d10-media{ aspect-ratio:4/5; box-shadow:0 40px 80px -36px rgba(0,0,0,.85); }
    .d10-ahero__tag{ position:absolute; left:-4%; bottom:6%; background:var(--d10-ink-2); border:1px solid var(--d10-line-2); border-radius:10px; padding:11px 16px; font-family:var(--d10-display); font-size:0.95rem; color:var(--d10-cream); box-shadow:0 20px 40px -22px rgba(0,0,0,.8); }
    @media (max-width:820px){ .d10-ahero__inner{ grid-template-columns:1fr; } .d10-ahero__media{ max-width:400px; } }

    /* ===================== STATEMENT ===================== */
    .d10-astate__lead{ font-family:var(--d10-display); font-size:var(--d10-s-2); line-height:1.28; color:var(--d10-cream); max-width:34ch; margin-inline:auto; }
    .d10-astate__lead em{ color:var(--d10-citron); }
    .d10-astate__drop{ float:left; font-size:2.4em; line-height:0.72; padding:0.05em 0.12em 0 0; color:var(--d10-citron); }

    /* ===================== TIMELINE ===================== */
    .d10-atime__grid{ display:grid; grid-template-columns:0.85fr 1.15fr; gap:clamp(1.6rem, 0.6rem + 4vw, 4.5rem); align-items:start; }
    .d10-atime__head{ position:sticky; top:100px; }
    .d10-atime__title{ font-size:var(--d10-s-2); margin:0.4em 0 1.4rem; }
    .d10-atime__media .d10-media{ aspect-ratio:5/4; }
    .d10-atime__list{ display:flex; flex-direction:column; }
    .d10-tl{ display:grid; grid-template-columns:auto 1fr; gap:clamp(1rem, 0.4rem + 2vw, 2rem); padding:clamp(1.4rem, 1rem + 1.5vw, 2.2rem) 0; border-top:1px solid var(--d10-line); }
    .d10-tl:last-child{ border-bottom:1px solid var(--d10-line); }
    .d10-tl__year{ font-family:var(--d10-sans); font-weight:800; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--d10-citron); padding-top:0.35em; min-width:6.5em; }
    .d10-tl__h{ font-size:var(--d10-s-1); color:var(--d10-cream); }
    .d10-tl__d{ color:var(--d10-cream-2); font-size:var(--d10-s-0); margin-top:0.4em; max-width:52ch; }
    @media (max-width:820px){ .d10-atime__grid{ grid-template-columns:1fr; } .d10-atime__head{ position:static; } .d10-tl{ grid-template-columns:1fr; gap:0.4rem; } }

    /* ===================== VALUES ===================== */
    .d10-vals__head{ margin-bottom:clamp(2rem, 1rem + 3vw, 3.4rem); }
    .d10-vals__title{ font-size:var(--d10-s-2); margin-top:0.35em; }
    .d10-vals__grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:clamp(1.4rem, 0.6rem + 2.4vw, 2.8rem); }
    .d10-val{ border-top:2px solid var(--d10-burgundy); padding-top:1.4rem; }
    .d10-val__no{ font-family:var(--d10-display); font-size:var(--d10-s-2); color:var(--d10-wine-2); display:block; margin-bottom:0.2em; }
    .d10-val__k{ font-size:var(--d10-s-1); color:var(--d10-ink); }
    .d10-val__d{ color:#4A3B32; font-size:var(--d10-s-0); margin-top:0.5em; line-height:1.6; }
    @media (max-width:820px){ .d10-vals__grid{ grid-template-columns:1fr; gap:2rem; } }

    /* ===================== CHEF ===================== */
    .d10-chef__grid{ display:grid; grid-template-columns:1fr 1.02fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:center; }
    .d10-chef__media{ position:relative; }
    .d10-chef__lg{ aspect-ratio:4/5; }
    .d10-chef__inset{ position:absolute; right:-6%; bottom:-8%; width:42%; aspect-ratio:3/4; border:6px solid var(--d10-ink); box-shadow:0 30px 60px -28px rgba(0,0,0,.8); }
    .d10-chef__title{ font-size:var(--d10-s-2); margin:0.4em 0 0.6em; }
    .d10-chef__title em{ color:var(--d10-citron); }
    .d10-chef__copy > p{ color:var(--d10-cream-2); }
    .d10-chef__facts{ display:flex; flex-wrap:wrap; gap:1.6rem 2.4rem; margin-top:1.8rem; }
    .d10-chef__facts li{ font-size:var(--d10-s--1); color:var(--d10-cream-3); }
    .d10-chef__facts span{ font-family:var(--d10-display); font-size:var(--d10-s-2); color:var(--d10-citron); display:block; line-height:1; margin-bottom:0.1em; }
    @media (max-width:820px){ .d10-chef__grid{ grid-template-columns:1fr; gap:3rem; } .d10-chef__inset{ right:4%; bottom:-7%; width:38%; } }

    /* ===================== CTA ===================== */
    .d10-final2{ text-align:center; background:radial-gradient(120% 150% at 50% 0%, var(--d10-ink-3) 0%, var(--d10-ink) 62%); }
    .d10-final2__inner{ display:flex; flex-direction:column; align-items:center; }
    .d10-final2__title{ font-size:var(--d10-s-3); max-width:18ch; margin:0.4em 0 1em; line-height:1.04; }
    .d10-final2__title em{ color:var(--d10-citron); }
    .d10-final2__row{ display:flex; flex-wrap:wrap; gap:14px; justify-content:center; }
  </style>
</D10Base>
