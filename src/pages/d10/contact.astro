---
import D10Base from '../../layouts/D10Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';
import entry from '../../assets/img/main-entry.jpg';

const desc = 'Contact Citron Baltimore: reservations, pick-up, and private events at 2605 Quarry Lake Dr, Baltimore, MD 21209. Dinner Wednesday through Sunday from 4 PM.';

const details = [
  { k: 'Address', v: '2605 Quarry Lake Dr<br />Baltimore, MD 21209', href: 'https://maps.google.com/?q=2605+Quarry+Lake+Dr+Baltimore+MD+21209', label: 'Get directions' },
  { k: 'Phone', v: SITE.phone, href: SITE.phoneHref, label: 'Call the house' },
  { k: 'Email', v: SITE.email, href: `mailto:${SITE.email}`, label: 'Email the events team' },
];

const hours = [
  { d: 'Wednesday – Thursday', h: '4:00 PM – 9:00 PM' },
  { d: 'Friday – Saturday', h: '4:00 PM – 10:00 PM' },
  { d: 'Sunday', h: '4:00 PM – 9:00 PM' },
  { d: 'Monday – Tuesday', h: 'Private events only' },
];
---
<D10Base title="Contact & Visit, Citron Baltimore" description={desc}>
  <!-- ===================== HERO ===================== -->
  <section class="d10-chero">
    <div class="d10-wrap d10-chero__inner">
      <p class="d10-eyebrow d10-eyebrow--citron d10-rv">Contact &amp; Visit</p>
      <h1 class="d10-chero__title d10-rv" data-delay="1">Come find us <em>on the water.</em></h1>
      <p class="d10-chero__lede d10-rv" data-delay="2">Reservations run through OpenTable, pick-up through Toast, and private events through our planning team. For anything else, the note below lands straight in the inbox.</p>
    </div>
  </section>

  <!-- ===================== MAIN ===================== -->
  <section class="d10-section d10-cmain">
    <div class="d10-wrap d10-cmain__grid">
      <!-- FORM -->
      <div class="d10-cform d10-rv">
        <h2 class="d10-cform__h">Send us a note</h2>
        <p class="d10-cform__sub">Tell us what you have in mind, a table, a pick-up order, or an event, and we will write back.</p>
        <form class="d10-form" id="d10-contact" novalidate>
          <div class="d10-field">
            <label for="c-name">Name</label>
            <input id="c-name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="d10-field">
            <label for="c-email">Email</label>
            <input id="c-email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="d10-field">
            <label for="c-topic">I'm writing about</label>
            <select id="c-topic" name="topic">
              <option>A dinner reservation</option>
              <option>A private event or catering</option>
              <option>A pick-up order</option>
              <option>Press or general</option>
            </select>
          </div>
          <div class="d10-field">
            <label for="c-msg">Message</label>
            <textarea id="c-msg" name="message" rows="5" required></textarea>
          </div>
          <button class="d10-btn d10-form__btn" type="submit">Send the Note</button>
          <p class="d10-form__note" id="d10-form-note" role="status"></p>
          <p class="d10-form__fine">This opens your email app addressed to {SITE.email}. For live tables, use OpenTable; for pick-up, use Toast.</p>
        </form>
      </div>

      <!-- DETAILS -->
      <aside class="d10-cdetails">
        <div class="d10-media d10-cdetails__media d10-rv">
          <Image src={entry} alt="The entrance to Citron Baltimore at Quarry Lake" widths={[420, 680]} sizes="(max-width:820px) 90vw, 40vw" loading="eager" fetchpriority="high" format="avif" quality={54} />
        </div>

        <ul class="d10-cdetails__list d10-rv" data-delay="1">
          {details.map((d) => (
            <li class="d10-cd">
              <span class="d10-cd__k">{d.k}</span>
              <span class="d10-cd__v" set:html={d.v}></span>
              <a class="d10-cd__link" href={d.href} target={d.href.startsWith('http') ? '_blank' : undefined} rel={d.href.startsWith('http') ? 'noopener' : undefined}>{d.label} <span aria-hidden="true">→</span></a>
            </li>
          ))}
        </ul>

        <div class="d10-hours d10-rv" data-delay="2">
          <h2 class="d10-hours__h">Kitchen hours</h2>
          <ul class="d10-hours__list">
            {hours.map((h) => (
              <li class="d10-hours__row"><span>{h.d}</span><span>{h.h}</span></li>
            ))}
          </ul>
          <p class="d10-hours__note">Private events are hosted seven days a week by arrangement.</p>
        </div>

        <div class="d10-quick d10-rv" data-delay="2">
          <a class="d10-btn d10-btn--sm" href={SITE.reserveUrl} target="_blank" rel="noopener">Reserve</a>
          <a class="d10-btn d10-btn--sm d10-btn--wine" href={SITE.pickupUrl} target="_blank" rel="noopener">Pick-Up</a>
          <a class="d10-btn d10-btn--sm d10-btn--ghost" href={SITE.portalUrl}>Events</a>
        </div>
      </aside>
    </div>
  </section>

  <script define:vars={{ email: SITE.email }}>
    const form = document.getElementById('d10-contact');
    const note = document.getElementById('d10-form-note');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = (data.get('name') || '').toString().trim();
      const from = (data.get('email') || '').toString().trim();
      const topic = (data.get('topic') || '').toString();
      const msg = (data.get('message') || '').toString().trim();
      if (!name || !from || !msg){
        if (note) note.textContent = 'Please add your name, email, and a short message.';
        return;
      }
      const subject = encodeURIComponent('Citron inquiry: ' + topic);
      const body = encodeURIComponent('Name: ' + name + '\nEmail: ' + from + '\nTopic: ' + topic + '\n\n' + msg);
      window.location.href = 'mailto:' + email + '?subject=' + subject + '&body=' + body;
      if (note) note.textContent = 'Opening your email app, addressed to us. Thank you.';
    });
  </script>

  <style>
    /* ===================== HERO ===================== */
    .d10-chero{ padding-top:clamp(2.5rem, 1.5rem + 4vw, 5rem); }
    .d10-chero__inner{ padding-block:clamp(1.5rem, 1rem + 2vw, 3rem); max-width:760px; }
    .d10-chero__title{ font-size:var(--d10-s-4); line-height:0.98; margin:0.3em 0 0.5em; }
    .d10-chero__title em{ color:var(--d10-citron); }
    .d10-chero__lede{ color:var(--d10-cream-2); font-size:var(--d10-s-1); max-width:56ch; line-height:1.5; }

    /* ===================== MAIN ===================== */
    .d10-cmain{ padding-top:clamp(1rem, 0.5rem + 2vw, 2rem); }
    .d10-cmain__grid{ display:grid; grid-template-columns:1.05fr 0.95fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:start; }

    .d10-cform{ background:var(--d10-ink-2); border:1px solid var(--d10-line); border-radius:20px; padding:clamp(1.6rem, 1rem + 2.4vw, 2.8rem); }
    .d10-cform__h{ font-size:var(--d10-s-2); }
    .d10-cform__sub{ color:var(--d10-cream-3); font-size:var(--d10-s--1); margin:0.5em 0 1.6em; max-width:46ch; }
    .d10-form{ display:flex; flex-direction:column; gap:1.1rem; }
    .d10-field{ display:flex; flex-direction:column; gap:0.5em; }
    .d10-field label{ font-size:0.72rem; font-weight:800; letter-spacing:0.14em; text-transform:uppercase; color:var(--d10-cream-2); }
    .d10-field input, .d10-field select, .d10-field textarea{
      width:100%; background:var(--d10-ink); border:1px solid var(--d10-line-2); border-radius:12px;
      padding:14px 16px; color:var(--d10-cream); font-family:var(--d10-sans); font-size:var(--d10-s-0);
      transition:border-color var(--d10-t-fast);
    }
    .d10-field textarea{ resize:vertical; min-height:120px; }
    .d10-field input:focus, .d10-field select:focus, .d10-field textarea:focus{ border-color:var(--d10-citron); outline:none; }
    .d10-form__btn{ margin-top:0.4rem; align-self:flex-start; }
    .d10-form__note{ color:var(--d10-citron); font-weight:700; font-size:var(--d10-s--1); min-height:1.2em; }
    .d10-form__fine{ color:var(--d10-cream-3); font-size:0.76rem; line-height:1.6; }

    .d10-cdetails{ display:flex; flex-direction:column; gap:clamp(1.6rem, 1rem + 2vw, 2.4rem); }
    .d10-cdetails__media{ aspect-ratio:16/11; }
    .d10-cdetails__list{ display:flex; flex-direction:column; }
    .d10-cd{ display:flex; flex-direction:column; gap:0.25em; padding:1.1rem 0; border-top:1px solid var(--d10-line); }
    .d10-cd:last-child{ border-bottom:1px solid var(--d10-line); }
    .d10-cd__k{ font-size:0.68rem; font-weight:800; letter-spacing:0.2em; text-transform:uppercase; color:var(--d10-citron); }
    .d10-cd__v{ font-family:var(--d10-display); font-size:var(--d10-s-1); color:var(--d10-cream); line-height:1.25; }
    .d10-cd__link{ font-size:var(--d10-s--1); font-weight:700; color:var(--d10-cream-3); margin-top:0.3em; transition:color var(--d10-t-fast); }
    .d10-cd__link span{ display:inline-block; transition:transform var(--d10-t-fast) var(--d10-ease); }
    .d10-cd__link:hover{ color:var(--d10-citron); }
    .d10-cd__link:hover span{ transform:translateX(4px); }

    .d10-hours{ background:var(--d10-wine); border-radius:16px; padding:clamp(1.4rem, 1rem + 1.5vw, 2rem); }
    .d10-hours__h{ font-family:var(--d10-sans); font-weight:800; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--d10-citron); margin-bottom:1em; }
    .d10-hours__list{ display:flex; flex-direction:column; }
    .d10-hours__row{ display:flex; justify-content:space-between; gap:1rem; padding:0.7rem 0; border-top:1px solid var(--d10-line); font-size:var(--d10-s--1); }
    .d10-hours__row:first-child{ border-top:none; }
    .d10-hours__row span:first-child{ color:var(--d10-cream); }
    .d10-hours__row span:last-child{ color:var(--d10-cream-2); font-weight:700; }
    .d10-hours__note{ color:var(--d10-cream-3); font-size:0.78rem; margin-top:1em; line-height:1.6; }

    .d10-quick{ display:flex; flex-wrap:wrap; gap:10px; }

    @media (max-width:820px){ .d10-cmain__grid{ grid-template-columns:1fr; } }
  </style>
</D10Base>
