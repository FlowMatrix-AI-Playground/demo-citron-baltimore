---
import D10Base from '../../layouts/D10Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';
import coveGala from '../../assets/img/cove-gala.jpg';
import cove from '../../assets/img/room-cove.jpg';
import courtyard from '../../assets/img/courtyard-lakefront.jpg';
import terrace from '../../assets/img/terrace-event.jpg';
import tent from '../../assets/img/room-offpremise.jpg';
import decor from '../../assets/img/decor-food.jpg';

const desc = 'Waterfront private events and off-premise catering by Citron Baltimore. Marquee spaces from an intimate twenty to the whole venue at five hundred, plus forty years of catering.';

const marquee = [
  { name: 'The Cove', cap: 'Up to 200 guests', img: cove, alt: 'The Cove event space staged for a celebration', copy: 'Our signature indoor room, staged for galas, weddings, and speaker dinners with the lake just beyond the glass.' },
  { name: 'Waterfront Courtyard', cap: 'Up to 200 guests', img: courtyard, alt: 'The waterfront courtyard at Citron', copy: 'Open sky and the water as your backdrop, built for the largest outdoor celebrations of the season.' },
  { name: 'Waterfront Terrace', cap: 'Up to 50 guests', img: terrace, alt: 'The heated waterfront terrace', copy: 'A heated, open-air terrace at the water’s edge, where the sunset does most of the decorating.' },
];

const formats = [
  { k: 'Weddings', d: 'Ceremony and reception on the water, from the first look to the last dance.' },
  { k: 'Galas & Fundraisers', d: 'Seated dinners and receptions for causes that fill the room.' },
  { k: 'Corporate & Speaker Dinners', d: 'Board dinners, launches, and PhRMA-compliant programs.' },
  { k: 'Milestones', d: 'Anniversaries, birthdays, and the celebrations a family remembers.' },
];
---
<D10Base title="Events & Private Dining, Citron Baltimore" description={desc}>
  <!-- ===================== HERO ===================== -->
  <section class="d10-ehero">
    <div class="d10-ehero__media">
      <Image src={coveGala} alt="A gala dinner staged in The Cove at Citron Baltimore" widths={[900, 1300, 1600]} sizes="100vw" loading="eager" fetchpriority="high" format="avif" quality={52} class="d10-ehero__img" />
      <div class="d10-ehero__scrim" aria-hidden="true"></div>
    </div>
    <div class="d10-wrap d10-ehero__content">
      <p class="d10-eyebrow d10-eyebrow--citron d10-rv">Events &amp; Private Dining</p>
      <h1 class="d10-ehero__title d10-rv" data-delay="1">From a fireside twenty <em>to five hundred</em> on the water.</h1>
      <p class="d10-ehero__lede d10-rv" data-delay="2">Nine private spaces at Quarry Lake and forty years of off-premise catering, run by the family that has been hosting Baltimore since the Pimlico Hotel. Booking and full availability live in the planning portal.</p>
      <div class="d10-ehero__cta d10-rv" data-delay="3">
        <a class="d10-btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <a class="d10-btn d10-btn--ghost" href={`mailto:${SITE.email}`}>Email the Events Team</a>
      </div>
    </div>
  </section>

  <!-- ===================== INTRO ===================== -->
  <section class="d10-section d10-eintro">
    <div class="d10-wrap d10-eintro__grid">
      <h2 class="d10-eintro__head d10-rv">Catering is <em>65% of what we do.</em> It is the engine of the house.</h2>
      <div class="d10-eintro__body d10-rv" data-delay="1">
        <p>Long before the restaurant, there was the catering company: four decades and roughly fourteen thousand events, from tented weddings to corporate galas across Maryland. That experience runs every private event on the lake, and travels to your room when you would rather host at home.</p>
        <p>What follows is a taste of the marquee spaces. The full nine-space inventory, dates, and pricing live in the planning portal.</p>
      </div>
    </div>
  </section>

  <!-- ===================== MARQUEE SPACES ===================== -->
  <section class="d10-section d10-section--cream d10-spaces">
    <div class="d10-wrap">
      <header class="d10-spaces__head d10-rv">
        <p class="d10-eyebrow">A few of the rooms</p>
        <h2 class="d10-spaces__title">Marquee spaces on the lake.</h2>
      </header>
      <div class="d10-spaces__list">
        {marquee.map((s, i) => (
          <article class:list={["d10-space d10-rv", { 'is-rev': i % 2 === 1 }]} data-delay="1">
            <div class="d10-media d10-space__media">
              <Image src={s.img} alt={s.alt} widths={[440, 720, 900]} sizes="(max-width:820px) 90vw, 48vw" loading="lazy" format="avif" quality={52} />
              <span class="d10-space__cap">{s.cap}</span>
            </div>
            <div class="d10-space__copy">
              <span class="d10-space__no" aria-hidden="true">0{i + 1}</span>
              <h3 class="d10-space__name">{s.name}</h3>
              <p class="d10-space__blurb">{s.copy}</p>
              <a class="d10-space__link" href={SITE.portalUrl}>Check dates <span aria-hidden="true">→</span></a>
            </div>
          </article>
        ))}
      </div>
      <p class="d10-spaces__more d10-rv">Plus five more, from a fireside private room to the entire venue at 500. <a href={SITE.portalUrl}>See them all in the portal →</a></p>
    </div>
  </section>

  <!-- ===================== CATERING ===================== -->
  <section class="d10-section d10-cater">
    <div class="d10-wrap d10-cater__grid">
      <div class="d10-cater__media d10-rv">
        <div class="d10-media d10-cater__lg" data-parallax="0.04">
          <Image src={tent} alt="A tented off-premise catering event by Citron" widths={[440, 720]} sizes="(max-width:820px) 90vw, 46vw" loading="lazy" format="avif" quality={54} />
        </div>
        <div class="d10-media d10-cater__inset">
          <Image src={decor} alt="Plated catering by Citron" widths={[240, 400]} sizes="28vw" loading="lazy" format="avif" quality={52} />
        </div>
      </div>
      <div class="d10-cater__copy">
        <p class="d10-eyebrow d10-eyebrow--citron d10-rv">Off-premise catering</p>
        <h2 class="d10-cater__title d10-rv" data-delay="1">Your tent, your home, your office. <em>Our kitchen, on the road.</em></h2>
        <p class="d10-measure d10-rv" data-delay="2">Citron Caterers has been packing the fine-dining standard into a truck for forty years. Full-service planning, staffing, rentals, and a kitchen that scales from an intimate dinner to a five-hundred-guest gala, wherever you are hosting.</p>
        <ul class="d10-cater__list d10-rv" data-delay="2">
          {formats.map((f) => (
            <li class="d10-cater__item">
              <span class="d10-cater__k">{f.k}</span>
              <span class="d10-cater__d">{f.d}</span>
            </li>
          ))}
        </ul>
        <a class="d10-btn d10-cater__btn d10-rv" data-delay="3" href={SITE.portalUrl}>Start Planning</a>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="d10-section d10-section--wine d10-ecta">
    <div class="d10-wrap d10-ecta__inner">
      <p class="d10-eyebrow d10-eyebrow--citron d10-rv">Let's put a date on it</p>
      <h2 class="d10-ecta__title d10-rv" data-delay="1">Tell us the guest count, and we'll <em>find you the room.</em></h2>
      <div class="d10-ecta__row d10-rv" data-delay="2">
        <a class="d10-btn" href={SITE.portalUrl}>Enter the Planning Portal</a>
        <a class="d10-btn d10-btn--ghost" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
    </div>
  </section>

  <style>
    /* ===================== HERO ===================== */
    .d10-ehero{ position:relative; min-height:clamp(72vh, 60vh + 8vw, 88vh); display:flex; align-items:flex-end; overflow:hidden; }
    .d10-ehero__media{ position:absolute; inset:0; }
    .d10-ehero__img{ width:100%; height:100%; object-fit:cover; }
    .d10-ehero__scrim{ position:absolute; inset:0; background:linear-gradient(to top, rgba(23,18,16,.97) 6%, rgba(23,18,16,.6) 42%, rgba(23,18,16,.28) 100%); }
    .d10-ehero__content{ position:relative; z-index:2; padding-block:clamp(2.4rem, 1.4rem + 4vw, 4.5rem); max-width:820px; }
    .d10-ehero__title{ font-size:var(--d10-s-4); line-height:0.98; margin:0.35em 0 0.5em; }
    .d10-ehero__title em{ color:var(--d10-citron); font-style:italic; }
    .d10-ehero__lede{ color:var(--d10-cream-2); font-size:var(--d10-s-1); max-width:56ch; line-height:1.5; }
    .d10-ehero__cta{ display:flex; flex-wrap:wrap; gap:14px; margin-top:2rem; }

    /* ===================== INTRO ===================== */
    .d10-eintro__grid{ display:grid; grid-template-columns:1.1fr 0.9fr; gap:clamp(1.6rem, 0.6rem + 4vw, 4.5rem); align-items:start; }
    .d10-eintro__head{ font-size:var(--d10-s-3); line-height:1.05; }
    .d10-eintro__head em{ color:var(--d10-citron); }
    .d10-eintro__body p{ color:var(--d10-cream-2); margin-bottom:1.1em; }
    @media (max-width:820px){ .d10-eintro__grid{ grid-template-columns:1fr; } }

    /* ===================== SPACES ===================== */
    .d10-spaces__head{ margin-bottom:clamp(2rem, 1rem + 3vw, 3.4rem); }
    .d10-spaces__title{ font-size:var(--d10-s-2); margin-top:0.35em; }
    .d10-spaces__list{ display:flex; flex-direction:column; gap:clamp(2rem, 1rem + 4vw, 4rem); }
    .d10-space{ display:grid; grid-template-columns:1.1fr 0.9fr; gap:clamp(1.4rem, 0.6rem + 3vw, 3.4rem); align-items:center; }
    .d10-space.is-rev .d10-space__media{ order:2; }
    .d10-space__media{ aspect-ratio:16/11; }
    .d10-space__cap{ position:absolute; top:14px; left:14px; z-index:2; background:var(--d10-citron); color:var(--d10-ink); font-size:0.66rem; font-weight:800; letter-spacing:0.06em; text-transform:uppercase; padding:8px 13px; border-radius:40px; }
    .d10-space__no{ font-family:var(--d10-display); font-size:var(--d10-s-2); color:var(--d10-wine-2); line-height:0.9; }
    .d10-space__name{ font-size:var(--d10-s-2); color:var(--d10-ink); margin:0.15em 0 0.4em; }
    .d10-space__blurb{ color:#4A3B32; font-size:var(--d10-s-0); line-height:1.6; max-width:44ch; }
    .d10-space__link{ display:inline-flex; gap:0.5em; margin-top:1.2em; color:var(--d10-burgundy); font-weight:800; font-size:var(--d10-s--1); letter-spacing:0.08em; text-transform:uppercase; }
    .d10-space__link span{ transition:transform var(--d10-t-fast) var(--d10-ease); }
    .d10-space__link:hover span{ transform:translateX(5px); }
    .d10-spaces__more{ margin-top:clamp(2rem, 1.2rem + 2vw, 3rem); padding-top:1.6rem; border-top:1px solid rgba(23,18,16,.14); color:#4A3B32; font-size:var(--d10-s-0); }
    .d10-spaces__more a{ color:var(--d10-burgundy); font-weight:800; }
    @media (max-width:820px){ .d10-space{ grid-template-columns:1fr; } .d10-space.is-rev .d10-space__media{ order:0; } }

    /* ===================== CATERING ===================== */
    .d10-cater__grid{ display:grid; grid-template-columns:1fr 1.02fr; gap:clamp(2rem, 1rem + 4vw, 5rem); align-items:center; }
    .d10-cater__media{ position:relative; }
    .d10-cater__lg{ aspect-ratio:4/5; will-change:transform; }
    .d10-cater__inset{ position:absolute; right:-6%; bottom:-8%; width:44%; aspect-ratio:1/1; border:6px solid var(--d10-ink); box-shadow:0 30px 60px -28px rgba(0,0,0,.8); }
    .d10-cater__title{ font-size:var(--d10-s-2); margin:0.4em 0 0.6em; }
    .d10-cater__title em{ color:var(--d10-citron); }
    .d10-cater__copy > p{ color:var(--d10-cream-2); }
    .d10-cater__list{ display:grid; grid-template-columns:1fr 1fr; gap:1.2rem 1.8rem; margin-top:1.8rem; }
    .d10-cater__item{ display:flex; flex-direction:column; gap:0.25em; border-top:1px solid var(--d10-line); padding-top:0.9rem; }
    .d10-cater__k{ font-family:var(--d10-display); font-size:var(--d10-s-1); color:var(--d10-cream); }
    .d10-cater__d{ color:var(--d10-cream-3); font-size:var(--d10-s--1); line-height:1.55; }
    .d10-cater__btn{ margin-top:2rem; }
    @media (max-width:820px){ .d10-cater__grid{ grid-template-columns:1fr; gap:3rem; } .d10-cater__inset{ right:4%; bottom:-7%; width:40%; } .d10-cater__list{ grid-template-columns:1fr; } }

    /* ===================== CTA ===================== */
    .d10-ecta__inner{ text-align:center; display:flex; flex-direction:column; align-items:center; }
    .d10-ecta__title{ font-size:var(--d10-s-3); max-width:22ch; margin:0.4em 0 1em; line-height:1.04; }
    .d10-ecta__title em{ color:var(--d10-citron); }
    .d10-ecta__row{ display:flex; flex-wrap:wrap; gap:14px; justify-content:center; }
  </style>
</D10Base>
