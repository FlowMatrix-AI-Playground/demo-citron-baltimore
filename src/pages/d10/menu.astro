---
import D10Base from '../../layouts/D10Base.astro';
import { Image } from 'astro:assets';
import { SITE } from '../../data/site.js';
import { MENU, MENU_NOTES } from '../../data/menu.js';
import crab from '../../assets/img/food-crabcake.jpg';
import tuna from '../../assets/img/food-tuna.jpg';
import wine from '../../assets/img/wine.jpg';

const desc = 'The Citron Baltimore menu: seasonal Modern American plates, a full designer sushi bar, prime center-cut steaks, and day-boat seafood, with a Wine Spectator honored list.';
---
<D10Base title="Menu, Citron Baltimore" description={desc}>
  <!-- ===================== MENU HERO ===================== -->
  <section class="d10-mhero">
    <div class="d10-mhero__glow" aria-hidden="true"></div>
    <div class="d10-wrap d10-mhero__inner">
      <div class="d10-mhero__copy">
        <p class="d10-eyebrow d10-eyebrow--citron d10-rv">The Bill of Fare</p>
        <h1 class="d10-mhero__title d10-rv" data-delay="1">Read it like a <em>tasting menu.</em></h1>
        <p class="d10-mhero__lede d10-rv" data-delay="2">A seasonal scratch kitchen under Executive Chef Mary Hersh: first plates and a designer sushi bar, then prime steaks and day-boat fish, all built to travel with a Wine Spectator honored list. Dinner Wednesday through Sunday from 4 PM.</p>
        <div class="d10-mhero__jump d10-rv" data-delay="3" aria-label="Jump to a course">
          {MENU.map((sec) => (<a href={`#${sec.id}`} class="d10-chip">{sec.title}</a>))}
        </div>
      </div>
      <div class="d10-mhero__media d10-rv" data-delay="2">
        <div class="d10-media">
          <Image src={crab} alt="Citron 8 oz jumbo lump crab cake with asparagus" widths={[420, 680]} sizes="(max-width:900px) 80vw, 38vw" loading="eager" fetchpriority="high" format="avif" quality={58} />
        </div>
        <span class="d10-mhero__tag">8 oz Jumbo Lump Crab Cake · $64</span>
      </div>
    </div>
  </section>

  <!-- ===================== MENU COURSES ===================== -->
  <section class="d10-section d10-menu">
    <div class="d10-wrap">
      {MENU.map((sec, si) => (
        <div class="d10-course-sec" id={sec.id}>
          <header class="d10-course-sec__head d10-rv">
            <span class="d10-course-sec__no" aria-hidden="true">{String(si + 1).padStart(2, '0')}</span>
            <div>
              <h2 class="d10-course-sec__title">{sec.title}</h2>
              {sec.note && <p class="d10-course-sec__note">{sec.note}</p>}
            </div>
            <span class="d10-course-sec__rule" aria-hidden="true"></span>
          </header>
          <ul class="d10-dishes">
            {sec.items.map((it, ii) => (
              <li class="d10-dish d10-rv" data-delay={String((ii % 3) + 1)}>
                <div class="d10-dish__top">
                  <h3 class="d10-dish__name">{it.name}</h3>
                  {it.price != null && <span class="d10-dish__dots" aria-hidden="true"></span>}
                  {it.price != null && <span class="d10-dish__price">${it.price}</span>}
                  <a class="d10-dish__cart" href={SITE.pickupUrl} target="_blank" rel="noopener" aria-label={`Add ${it.name} to pick-up order`}>
                    <svg class="d10-dish__cart-ic" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                      <circle cx="9" cy="20" r="1.15"></circle>
                      <circle cx="17.5" cy="20" r="1.15"></circle>
                      <path d="M2.5 3h2l2.2 11.2a1.4 1.4 0 0 0 1.4 1.1h8.3a1.4 1.4 0 0 0 1.37-1.06L21 6.5H6"></path>
                    </svg>
                  </a>
                </div>
                {it.desc && <p class="d10-dish__desc">{it.desc}</p>}
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Wine + raw bar interlude -->
      <div class="d10-menu-band">
        <div class="d10-menu-band__media d10-rv">
          <div class="d10-media"><Image src={tuna} alt="Ahi tuna tartare from the Citron raw bar" widths={[360, 560]} sizes="(max-width:820px) 90vw, 40vw" loading="lazy" format="avif" quality={54} /></div>
          <div class="d10-media"><Image src={wine} alt="A pour from the Wine Spectator honored list" widths={[300, 480]} sizes="(max-width:820px) 90vw, 34vw" loading="lazy" format="avif" quality={54} /></div>
        </div>
        <div class="d10-menu-band__copy d10-rv" data-delay="1">
          <p class="d10-eyebrow d10-eyebrow--citron">The cellar</p>
          <h2 class="d10-menu-band__title">A wine list built to <em>travel with the plate.</em></h2>
          <p class="d10-measure">Seven straight years of the Wine Spectator Award of Excellence, 2019 through 2025. Ask your server for the by-the-glass flights, or let us pair a bottle to the table. The raw bar and the cellar were made for each other.</p>
        </div>
      </div>

      <div class="d10-notes d10-rv">
        <h2 class="d10-notes__h">Good to know</h2>
        <ul class="d10-notes__list">
          {MENU_NOTES.map((n) => (<li>{n}</li>))}
          <li>Menu is seasonal and subject to change. Prices in US dollars. Full sushi bar nightly.</li>
        </ul>
      </div>

      <div class="d10-menu-cta d10-rv">
        <p class="d10-menu-cta__k">Ready when you are</p>
        <div class="d10-menu-cta__row">
          <a class="d10-btn" href={SITE.reserveUrl} target="_blank" rel="noopener">Reserve a Table</a>
          <a class="d10-btn d10-btn--wine" href={SITE.pickupUrl} target="_blank" rel="noopener">Order Pick-Up</a>
          <button class="d10-btn d10-btn--ghost" data-cta>Plan an Event</button>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ===================== MENU HERO ===================== */
    .d10-mhero{ position:relative; overflow:hidden; padding-top:clamp(2rem, 1rem + 3vw, 4rem); }
    .d10-mhero__glow{ position:absolute; top:-25%; left:-10%; width:55vw; height:55vw; max-width:680px; max-height:680px; background:radial-gradient(circle, rgba(138,34,51,.28), transparent 62%); pointer-events:none; }
    .d10-mhero__inner{ display:grid; grid-template-columns:1.15fr 0.85fr; gap:clamp(1.6rem, 0.6rem + 4vw, 4rem); align-items:center; padding-block:clamp(2rem, 1.2rem + 3vw, 4rem); }
    .d10-mhero__title{ font-size:var(--d10-s-4); line-height:0.98; margin:0.3em 0 0.5em; }
    .d10-mhero__title em{ color:var(--d10-citron); }
    .d10-mhero__lede{ color:var(--d10-cream-2); font-size:var(--d10-s-1); max-width:52ch; line-height:1.5; }
    .d10-mhero__jump{ display:flex; flex-wrap:wrap; gap:10px; margin-top:2rem; }
    .d10-chip{ font-size:0.72rem; font-weight:800; letter-spacing:0.08em; text-transform:uppercase; color:var(--d10-cream-2); border:1px solid var(--d10-line-2); border-radius:40px; padding:9px 16px; transition:color var(--d10-t-fast), border-color var(--d10-t-fast), background var(--d10-t-fast); }
    .d10-chip:hover{ color:var(--d10-ink); background:var(--d10-citron); border-color:var(--d10-citron); }
    .d10-mhero__media{ position:relative; }
    .d10-mhero__media .d10-media{ aspect-ratio:4/5; box-shadow:0 40px 80px -36px rgba(0,0,0,.85); }
    .d10-mhero__tag{ position:absolute; left:-4%; bottom:6%; background:var(--d10-ink-2); border:1px solid var(--d10-line-2); border-radius:10px; padding:11px 16px; font-family:var(--d10-display); font-size:0.98rem; color:var(--d10-cream); box-shadow:0 20px 40px -22px rgba(0,0,0,.8); }
    @media (max-width:820px){ .d10-mhero__inner{ grid-template-columns:1fr; } .d10-mhero__media{ order:-1; max-width:400px; } }

    /* ===================== COURSES ===================== */
    .d10-course-sec{ scroll-margin-top:100px; padding-block:clamp(2.4rem, 1.4rem + 3vw, 4rem); border-top:1px solid var(--d10-line); }
    .d10-course-sec:first-of-type{ border-top:none; padding-top:0; }
    .d10-course-sec__head{ display:flex; align-items:center; gap:clamp(0.8rem, 0.4rem + 1.5vw, 1.6rem); margin-bottom:clamp(1.6rem, 1rem + 2vw, 2.6rem); }
    .d10-course-sec__no{ font-family:var(--d10-display); font-size:var(--d10-s-2); color:var(--d10-wine-2); line-height:0.8; flex:none; }
    .d10-course-sec__title{ font-size:var(--d10-s-2); }
    .d10-course-sec__note{ font-size:0.72rem; font-weight:800; letter-spacing:0.18em; text-transform:uppercase; color:var(--d10-citron); margin-top:0.3em; }
    .d10-course-sec__rule{ flex:1; height:1px; background:var(--d10-line-2); }
    .d10-dishes{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(1.2rem, 0.6rem + 2vw, 2.4rem) clamp(2rem, 1rem + 3vw, 4rem); }
    .d10-dish{ padding-bottom:0.2em; }
    .d10-dish__top{ display:flex; align-items:baseline; gap:0.6rem; }
    .d10-dish__name{ font-family:var(--d10-display); font-size:var(--d10-s-1); color:var(--d10-cream); line-height:1.15; }
    .d10-dish__dots{ flex:1; border-bottom:1px dotted var(--d10-line-2); transform:translateY(-0.25em); min-width:1.5rem; }
    .d10-dish__price{ font-family:var(--d10-sans); font-weight:800; font-size:var(--d10-s-0); color:var(--d10-citron); flex:none; }
    .d10-dish__cart{ flex:none; align-self:center; margin-left:auto; display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; margin-top:-8px; margin-bottom:-8px; margin-right:-6px; border-radius:50%; color:var(--d10-cream-3); opacity:0.55; transition:color var(--d10-t-fast), opacity var(--d10-t-fast), background var(--d10-t-fast); }
    .d10-dish__cart:hover{ color:var(--d10-citron); opacity:1; background:rgba(138,34,51,.16); }
    .d10-dish__cart:focus-visible{ color:var(--d10-citron); opacity:1; outline:2px solid var(--d10-citron); outline-offset:2px; }
    .d10-dish__cart-ic{ display:block; }
    .d10-dish__desc{ color:var(--d10-cream-3); font-size:var(--d10-s--1); margin-top:0.4em; line-height:1.55; max-width:48ch; }
    @media (max-width:720px){ .d10-dishes{ grid-template-columns:1fr; } }

    /* ===================== WINE BAND ===================== */
    .d10-menu-band{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(1.6rem, 0.8rem + 3vw, 3.5rem); align-items:center; margin-top:clamp(2rem, 1rem + 3vw, 4rem); padding:clamp(1.8rem, 1rem + 3vw, 3rem); background:var(--d10-wine); border-radius:20px; }
    .d10-menu-band__media{ display:grid; grid-template-columns:1.1fr 0.9fr; gap:12px; }
    .d10-menu-band__media .d10-media{ aspect-ratio:3/4; }
    .d10-menu-band__title{ font-size:var(--d10-s-2); margin:0.3em 0 0.6em; }
    .d10-menu-band__title em{ color:var(--d10-citron); }
    .d10-menu-band__copy p{ color:var(--d10-cream-2); }
    @media (max-width:820px){ .d10-menu-band{ grid-template-columns:1fr; } }

    /* ===================== NOTES + CTA ===================== */
    .d10-notes{ margin-top:clamp(2.4rem, 1.4rem + 3vw, 4rem); padding-top:clamp(1.6rem, 1rem + 2vw, 2.4rem); border-top:1px solid var(--d10-line); }
    .d10-notes__h{ font-family:var(--d10-sans); font-weight:800; font-size:0.7rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--d10-citron); margin-bottom:1em; }
    .d10-notes__list{ display:flex; flex-direction:column; gap:0.7em; max-width:82ch; }
    .d10-notes__list li{ position:relative; padding-left:1.4em; color:var(--d10-cream-3); font-size:var(--d10-s--1); line-height:1.6; }
    .d10-notes__list li::before{ content:"✦"; position:absolute; left:0; color:var(--d10-wine-2); font-size:0.7em; top:0.35em; }
    .d10-menu-cta{ margin-top:clamp(2.4rem, 1.4rem + 3vw, 4rem); text-align:center; }
    .d10-menu-cta__k{ font-family:var(--d10-display); font-size:var(--d10-s-2); color:var(--d10-cream); margin-bottom:1em; }
    .d10-menu-cta__row{ display:flex; flex-wrap:wrap; gap:14px; justify-content:center; }
  </style>
</D10Base>
