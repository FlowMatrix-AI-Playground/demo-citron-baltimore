---
// Next Steps section + a right slide-in "Book a call" panel (live Google Calendar).
---

<section class="ns" aria-labelledby="ns-title">
  <div class="ns__wrap">
    <h2 class="ns__title" id="ns-title">Next Steps</h2>
    <p class="ns__lead">Book your follow-up call to lock in a final design.</p>
    <div class="ns__actions">
      <button type="button" class="btn btn--primary" id="fm-open-call">Book a call</button>
    </div>
  </div>
</section>

<!-- Backdrop -->
<div class="fm-backdrop" id="fm-backdrop" hidden></div>

<!-- Panel - Book a call -->
<aside
  class="fm-panel fm-panel--call"
  id="fm-panel-call"
  role="dialog"
  aria-modal="true"
  aria-labelledby="fm-call-title"
  aria-hidden="true"
  inert
>
  <header class="fm-panel__head">
    <h3 class="fm-panel__title" id="fm-call-title">Book a call</h3>
    <button type="button" class="fm-close" data-fm-close aria-label="Close booking panel">&times;</button>
  </header>
  <div class="fm-panel__body fm-panel__body--flush">
    <iframe
      class="fm-cal"
      id="fm-cal-iframe"
      data-src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ2ltBnOZRoXf-MooGc4ac0roHsjC3KkkGEzDKPkL80oZ5SGT6YvkgFM3HLlPUU3z-nmL9WKShdc?gv=true"
      style="border:0"
      loading="lazy"
      title="Book a call"
    ></iframe>
  </div>
</aside>

<style>
  .ns {
    --paper: oklch(0.97 0.003 100);
    --white: #ffffff;
    --ink: oklch(0.10 0.01 255);
    --blue: oklch(0.50 0.07 235);
    --blue-deep: oklch(0.38 0.06 245);
    --slate-2: oklch(0.446 0 0);
    --line: oklch(0.90 0.02 230);
    --sky-tint: oklch(0.95 0.02 233);

    background: var(--paper);
    border-top: 1px solid var(--line);
    padding-block: clamp(3.5rem, 2.5rem + 5vw, 6rem);
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--ink);
  }

  .ns__wrap {
    max-width: 1220px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 0.8rem + 2vw, 2.6rem);
    text-align: center;
  }

  .ns__title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.9rem, 1.4rem + 2vw, 2.9rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .ns__lead {
    margin: 0 auto 2rem;
    max-width: 46ch;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--slate-2);
  }

  .ns__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
  }

  /* ---- Button ---- */
  .btn {
    font-family: inherit;
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1;
    border-radius: 9px;
    padding: 0.9rem 1.6rem;
    min-height: 44px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.06s ease;
  }
  .btn:active { transform: translateY(1px); }
  .btn:focus-visible {
    outline: 2px solid var(--blue);
    outline-offset: 2px;
  }
  .btn--primary {
    background: var(--blue);
    color: var(--white);
  }
  .btn--primary:hover { background: var(--blue-deep); }

  /* ---- Backdrop ---- */
  .fm-backdrop {
    position: fixed;
    inset: 0;
    background: oklch(0.10 0.01 255 / 0.42);
    opacity: 0;
    z-index: 1000;
    transition: opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .fm-backdrop.is-open { opacity: 1; }

  /* ---- Panel ---- */
  .fm-panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    max-width: 100vw;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    color: oklch(0.10 0.01 255);
    box-shadow: -20px 0 60px oklch(0.10 0.01 255 / 0.22);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 1001;
    font-family: 'Inter', system-ui, sans-serif;
  }
  .fm-panel--call { width: min(520px, 100vw); }
  .fm-panel.is-open { transform: translateX(0); }

  .fm-panel__head {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 1.35rem;
    border-bottom: 1px solid oklch(0.90 0.02 230);
  }
  .fm-panel__title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: oklch(0.10 0.01 255);
  }
  .fm-close {
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid oklch(0.90 0.02 230);
    background: #ffffff;
    color: oklch(0.446 0 0);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background-color 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }
  .fm-close:hover {
    background: oklch(0.95 0.02 233);
    border-color: oklch(0.50 0.07 235);
    color: oklch(0.38 0.06 245);
  }
  .fm-close:focus-visible {
    outline: 2px solid oklch(0.50 0.07 235);
    outline-offset: 2px;
  }

  .fm-panel__body {
    flex: 1 1 auto;
    overflow-y: auto;
  }
  .fm-panel__body--flush { padding: 0; }

  .fm-cal {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100%;
  }

  /* body scroll lock */
  :global(html.fm-lock),
  :global(html.fm-lock body) {
    overflow: hidden;
  }

  @media (max-width: 520px) {
    .fm-panel--call { width: 100vw; }
    .ns__actions .btn { flex: 1 1 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .fm-panel,
    .fm-backdrop { transition: none; }
  }
</style>

<script>
  const $ = (id) => document.getElementById(id);

  const backdrop = $('fm-backdrop');
  const panelCall = $('fm-panel-call');
  const openCall = $('fm-open-call');
  const calIframe = $('fm-cal-iframe');

  let activePanel = null;
  let lastFocused = null;
  let calLoaded = false;

  function openPanel(panel) {
    if (!panel || !backdrop) return;
    lastFocused = document.activeElement;
    activePanel = panel;

    if (panel === panelCall && !calLoaded && calIframe) {
      calIframe.src = calIframe.dataset.src;
      calLoaded = true;
    }

    backdrop.hidden = false;
    void backdrop.offsetWidth; // force reflow so the transition runs
    backdrop.classList.add('is-open');
    panel.classList.add('is-open');
    panel.setAttribute('aria-hidden', 'false');
    panel.removeAttribute('inert');
    document.documentElement.classList.add('fm-lock');

    const focusTarget = panel.querySelector('[data-fm-close]');
    if (focusTarget) focusTarget.focus();
  }

  function closePanel() {
    if (!activePanel || !backdrop) return;
    const panel = activePanel;
    panel.classList.remove('is-open');
    panel.setAttribute('aria-hidden', 'true');
    panel.setAttribute('inert', '');
    backdrop.classList.remove('is-open');
    document.documentElement.classList.remove('fm-lock');

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      backdrop.hidden = true;
    } else {
      const onEnd = () => { backdrop.hidden = true; backdrop.removeEventListener('transitionend', onEnd); };
      backdrop.addEventListener('transitionend', onEnd);
    }

    activePanel = null;
    if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
  }

  function init() {
    if (openCall) openCall.addEventListener('click', () => openPanel(panelCall));
    document.querySelectorAll('[data-fm-close]').forEach((btn) => btn.addEventListener('click', closePanel));
    if (backdrop) backdrop.addEventListener('click', closePanel);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && activePanel) closePanel(); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
