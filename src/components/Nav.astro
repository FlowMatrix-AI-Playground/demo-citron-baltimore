---
import { NAV } from '../data/site.js';
const path = Astro.url.pathname;
---
<header class="nav" id="site-nav" data-at-top>
  <div class="wrap nav__inner">
    <a href="/" class="nav__brand">
      <span class="nav__wordmark">Citron</span>
      <span class="nav__sub">Baltimore</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {NAV.map((item) => (
        <a href={item.href} class:list={["nav__link", { 'is-current': path === item.href }]} aria-current={path === item.href ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <div class="nav__actions">
      <button class="btn nav__cta" data-cta>Reserve<span class="nav__cta-plus" aria-hidden="true"> / Plan</span></button>
      <button class="nav__burger" id="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-drawer">
        <span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav__drawer" id="nav-drawer" hidden>
    <nav aria-label="Mobile">
      {NAV.map((item) => (<a href={item.href} class="nav__drawer-link">{item.label}</a>))}
      <a href="/journal" class="nav__drawer-link nav__drawer-link--muted">Journal</a>
      <button class="btn nav__drawer-cta" data-cta>Reserve · Pick-Up · Events</button>
    </nav>
  </div>
</header>

<style>
  .nav{ position:fixed; top:0; left:0; right:0; z-index:1000; transition:background var(--t-med), border-color var(--t-med), backdrop-filter var(--t-med); border-bottom:1px solid transparent; }
  .nav:not([data-at-top]){ background:color-mix(in oklab, var(--abyss) 82%, transparent); backdrop-filter:blur(12px); border-bottom-color:var(--hair); }
  .nav__inner{ display:flex; align-items:center; justify-content:space-between; height:78px; gap:24px; }
  .nav__brand{ display:flex; align-items:baseline; gap:.4em; line-height:1; }
  .nav__wordmark{ font-family:var(--serif); font-weight:600; font-size:1.7rem; color:var(--cream); letter-spacing:.01em; }
  .nav__sub{ font-family:var(--sans); font-weight:700; font-size:.62rem; letter-spacing:.34em; text-transform:uppercase; color:var(--citron); }
  .nav__links{ display:flex; align-items:center; gap:30px; }
  .nav__link{ font-family:var(--sans); font-weight:600; font-size:.78rem; letter-spacing:.13em; text-transform:uppercase; color:var(--mist); padding:6px 0; position:relative; transition:color var(--t-fast); }
  .nav__link::after{ content:""; position:absolute; left:0; right:100%; bottom:-2px; height:1.5px; background:var(--citron); transition:right var(--t-med) var(--ease); }
  .nav__link:hover{ color:var(--cream); }
  .nav__link:hover::after,.nav__link.is-current::after{ right:0; }
  .nav__link.is-current{ color:var(--cream); }
  .nav__actions{ display:flex; align-items:center; gap:14px; }
  .nav__cta{ min-height:46px; }
  .nav__burger{ display:none; width:44px; height:44px; background:none; border:1px solid var(--hair-strong); border-radius:4px; cursor:pointer; flex-direction:column; align-items:center; justify-content:center; gap:5px; }
  .nav__burger span{ width:18px; height:1.6px; background:var(--cream); transition:transform var(--t-fast), opacity var(--t-fast); }
  .nav__burger[aria-expanded="true"] span:first-child{ transform:translateY(3.3px) rotate(45deg); }
  .nav__burger[aria-expanded="true"] span:last-child{ transform:translateY(-3.3px) rotate(-45deg); }

  .nav__drawer{ overflow:hidden; background:var(--abyss-2); border-top:1px solid var(--hair); }
  .nav__drawer nav{ display:flex; flex-direction:column; padding:12px var(--gutter) 22px; }
  .nav__drawer-link{ padding:16px 2px; font-family:var(--sans); font-weight:700; font-size:1rem; letter-spacing:.1em; text-transform:uppercase; color:var(--mist); border-bottom:1px solid var(--hair); }
  .nav__drawer-link--muted{ color:var(--mist-dim); }
  .nav__drawer-cta{ margin-top:18px; justify-content:center; }

  @media (max-width:960px){
    .nav__links, .nav__cta{ display:none; }
    .nav__burger{ display:flex; }
  }
</style>

<script>
  // solid-on-scroll
  const nav = document.getElementById('site-nav');
  const onScroll = () => { if (window.scrollY > 40) nav.removeAttribute('data-at-top'); else nav.setAttribute('data-at-top',''); };
  window.addEventListener('scroll', onScroll, { passive: true }); onScroll();

  // mobile drawer
  const burger = document.getElementById('nav-burger');
  const drawer = document.getElementById('nav-drawer');
  const setOpen = (open) => {
    burger.setAttribute('aria-expanded', String(open));
    if (open) { drawer.hidden = false; } else {
      const done = () => { drawer.hidden = true; };
      // allow transition then hide
      setTimeout(done, 10);
    }
  };
  burger?.addEventListener('click', () => setOpen(burger.getAttribute('aria-expanded') !== 'true'));
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
</script>
