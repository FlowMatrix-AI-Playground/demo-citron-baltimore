---
// ============================================================
// Citron Baltimore, Design d6 "Deco Quarry"
// 1920s-30s Art Deco glamour, tied to Citron's own identity:
// midnight-emerald ground, CITRON-GREEN as the primary accent (buttons,
// wordmark ring, kickers, prices, data), with gilt brass demoted to a
// secondary metallic role for deco linework (sunbursts, gilt rules,
// frames, roman numerals, wax seal). Lowercase "citron" wordmark with a
// citron-green ring "o". Bodoni Moda display + geometric Jost.
// All CSS is namespaced under `.d6` so nothing leaks to the flagship.
// ============================================================
import '@fontsource/bodoni-moda/400.css';
import '@fontsource/bodoni-moda/500.css';
import '@fontsource/bodoni-moda/600.css';
import '@fontsource/bodoni-moda/700.css';
import '@fontsource/bodoni-moda/400-italic.css';
import '@fontsource/bodoni-moda/500-italic.css';
import '@fontsource/jost/300.css';
import '@fontsource/jost/400.css';
import '@fontsource/jost/500.css';
import '@fontsource/jost/600.css';
import { SITE } from '../data/site.js';

const {
  title = 'Citron Baltimore, Waterfront Dining, Catering & Events at Quarry Lake',
  description = 'An upscale waterfront restaurant and event venue on Quarry Lake in Baltimore County. Seasonal Modern American cuisine, a full sushi bar, a Wine Spectator honored list, and private events from 20 to 500 guests.',
  ogImage = '/lake-poster.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname.replace(/\/$/, '') || '/d6';

const NAV = [
  { label: 'Home', href: '/d6/' },
  { label: 'Menu', href: '/d6/menu' },
  { label: 'Events & Private Dining', href: '/d6/events' },
  { label: 'About', href: '/d6/about' },
  { label: 'Contact', href: '/d6/contact' },
];
const isCurrent = (href) => {
  const clean = href.replace(/\/$/, '') || '/d6';
  return clean === path;
};
---
<!doctype html>
<html lang="en" class="d6-html">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#0C1414" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:site_name" content="Citron Baltimore" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"Restaurant",
    "name":"Citron Baltimore","servesCuisine":"Modern American",
    "priceRange":"$$$","telephone":SITE.phone,
    "address":{"@type":"PostalAddress","streetAddress":"2605 Quarry Lake Dr","addressLocality":"Baltimore","addressRegion":"MD","postalCode":"21209"},
    "url":"https://citronbaltimore.com","acceptsReservations":"True"
  })} />
</head>
<body class="d6">
  <a class="d6-skip" href="#main">Skip to content</a>

  <!-- ===================== NAV ===================== -->
  <header class="d6-nav" id="d6-nav" data-at-top>
    <div class="d6-nav__rule" aria-hidden="true"></div>
    <div class="d6-wrap d6-nav__bar">
      <a href="/d6/" class="d6-brand">
        <span class="d6-brand__word">
          <span class="d6-brand__name" aria-hidden="true">citr<span class="d6-brand__o"></span>n</span>
          <span class="d6-brand__sub" aria-hidden="true">Baltimore &middot; Est. 2016</span>
        </span>
        <span style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;">Citron Baltimore, home</span>
      </a>

      <nav class="d6-nav__links" aria-label="Primary">
        {NAV.map((item) => (
          <a
            href={item.href}
            class:list={["d6-nav__link", { 'is-current': isCurrent(item.href) }]}
            aria-current={isCurrent(item.href) ? 'page' : undefined}
          >{item.label}</a>
        ))}
      </nav>

      <div class="d6-nav__actions">
        <button class="d6-btn d6-btn--sm" data-cta>Reserve</button>
        <button class="d6-burger" id="d6-burger" aria-label="Open menu" aria-expanded="false" aria-controls="d6-drawer">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
    <div class="d6-nav__rule d6-nav__rule--hair" aria-hidden="true"></div>

    <div class="d6-drawer" id="d6-drawer" hidden>
      <nav aria-label="Mobile">
        {NAV.map((item) => (<a href={item.href} class="d6-drawer__link">{item.label}</a>))}
        <a href="/d6/#press" class="d6-drawer__link d6-drawer__link--muted">The Gilded Journal</a>
        <button class="d6-btn d6-drawer__cta" data-cta>Reserve &middot; Pick-Up &middot; Events</button>
      </nav>
    </div>
  </header>

  <main id="main"><slot /></main>

  <!-- ===================== FOOTER ===================== -->
  <footer class="d6-foot">
    <div class="d6-foot__crest" aria-hidden="true">
      <svg viewBox="0 0 120 40" width="120" height="40" fill="none">
        <path d="M0 20 H44" stroke="currentColor" stroke-width="1"/>
        <path d="M76 20 H120" stroke="currentColor" stroke-width="1"/>
        <path d="M60 6 L70 20 L60 34 L50 20 Z" stroke="currentColor" stroke-width="1"/>
        <path d="M60 12 L64 20 L60 28 L56 20 Z" stroke="currentColor" stroke-width="1" opacity=".7"/>
        <circle cx="60" cy="20" r="1.6" fill="currentColor"/>
      </svg>
    </div>
    <div class="d6-wrap">
      <div class="d6-foot__grid">
        <div class="d6-foot__brand">
          <a href="/d6/" class="d6-foot__word"><span class="d6-foot__logo" aria-hidden="true">citr<span class="d6-brand__o"></span>n</span> <em aria-hidden="true">Baltimore</em><span style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;">Citron Baltimore, home</span></a>
          <p class="d6-foot__blurb">An upscale waterfront restaurant, catering house, and event venue on Quarry Lake. Family owned by Charles and Susan Levine since 2016. Ten years on the water this November.</p>
          <div class="d6-foot__news">
            <p class="d6-kicker">Join the guest list</p>
            <form class="d6-foot__form" id="d6-news">
              <label class="d6-sr" for="d6-news-email">Email address</label>
              <input id="d6-news-email" name="email" type="email" placeholder="you@example.com" autocomplete="email" required />
              <button class="d6-btn d6-btn--sm" type="submit">Subscribe</button>
            </form>
            <p class="d6-foot__note" id="d6-news-note">Seasonal menus, wine dinners, and first word on Cove availability. No mass mail.</p>
          </div>
        </div>

        <nav class="d6-foot__col" aria-label="Explore">
          <h2 class="d6-foot__h">Explore</h2>
          <a href="/d6/" class="d6-foot__link">Home</a>
          <a href="/d6/menu" class="d6-foot__link">The Menu</a>
          <a href="/d6/events" class="d6-foot__link">Events &amp; Private Dining</a>
          <a href="/d6/about" class="d6-foot__link">About</a>
          <a href="/d6/contact" class="d6-foot__link">Contact</a>
        </nav>

        <nav class="d6-foot__col" aria-label="The Gilded Journal">
          <h2 class="d6-foot__h">The Journal</h2>
          <a href="/d6/#press" class="d6-foot__link">Press &amp; Honors</a>
          <a href="/d6/#seasonal" class="d6-foot__link">Seasonal Notes</a>
          <a href={SITE.reserveUrl} class="d6-foot__link" target="_blank" rel="noopener">Reserve on OpenTable</a>
          <a href={SITE.pickupUrl} class="d6-foot__link" target="_blank" rel="noopener">Order Pick-Up</a>
          <a href={SITE.portalUrl} class="d6-foot__link">Plan an Event</a>
        </nav>

        <div class="d6-foot__col">
          <h2 class="d6-foot__h">Visit</h2>
          <address class="d6-foot__addr">
            2605 Quarry Lake Dr<br />Baltimore, MD 21209<br />
            <a href={SITE.phoneHref} class="d6-foot__link">{SITE.phone}</a><br />
            <a href={`mailto:${SITE.email}`} class="d6-foot__link">{SITE.email}</a>
          </address>
          <p class="d6-foot__hours">Dinner: Wed–Sun from 4 PM<br />Private Events: 7 days</p>
        </div>
      </div>

      <div class="d6-foot__bottom">
        <span>© 2026 Citron Baltimore. Quarry Lake, Baltimore County.</span>
        <span class="d6-foot__award">Wine Spectator Award of Excellence · 2019–2025</span>
      </div>
    </div>
  </footer>

  <!-- ===================== CTA POPUP ===================== -->
  <div class="d6-modal" id="d6-modal" role="dialog" aria-modal="true" aria-labelledby="d6-modal-title" hidden>
    <div class="d6-modal__scrim" data-cta-close></div>
    <div class="d6-modal__panel" role="document">
      <span class="d6-modal__fan d6-modal__fan--tl" aria-hidden="true"></span>
      <span class="d6-modal__fan d6-modal__fan--br" aria-hidden="true"></span>
      <button class="d6-modal__close" data-cta-close aria-label="Close">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      </button>
      <p class="d6-kicker d6-kicker--center">How may we host you?</p>
      <h2 id="d6-modal-title" class="d6-modal__title">Reserve a table, or plan a night.</h2>
      <div class="d6-modal__rule" aria-hidden="true"></div>
      <div class="d6-modal__grid">
        <a class="d6-choice" href={SITE.reserveUrl} target="_blank" rel="noopener">
          <span class="d6-choice__no" aria-hidden="true">I</span>
          <span class="d6-choice__body">
            <span class="d6-choice__k">Reserve a Table</span>
            <span class="d6-choice__d">Dinner on the water. Wed–Sun from 4 PM.</span>
          </span>
          <span class="d6-choice__arrow" aria-hidden="true">→</span>
        </a>
        <a class="d6-choice" href={SITE.pickupUrl} target="_blank" rel="noopener">
          <span class="d6-choice__no" aria-hidden="true">II</span>
          <span class="d6-choice__body">
            <span class="d6-choice__k">Order Pick-Up</span>
            <span class="d6-choice__d">The kitchen, to go. Powered by Toast.</span>
          </span>
          <span class="d6-choice__arrow" aria-hidden="true">→</span>
        </a>
        <a class="d6-choice d6-choice--feature" href={SITE.portalUrl}>
          <span class="d6-choice__no" aria-hidden="true">III</span>
          <span class="d6-choice__body">
            <span class="d6-choice__k">Events &amp; Private Dining</span>
            <span class="d6-choice__d">From 20 to 500 guests. Enter the planning portal.</span>
          </span>
          <span class="d6-choice__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>

  <style is:global>
    /* ============================================================
       d6 "Deco Quarry": tokens + base (scoped under .d6)
       ============================================================ */
    .d6{
      /* palette: midnight-emerald ground + lustrous brass */
      --d6-bg:#0C1414;
      --d6-bg-2:#0E1A18;
      --d6-bg-3:#11221F;
      --d6-panel:#091110;
      --d6-emerald:#16332B;
      /* PRIMARY accent: Citron's own citron-green (the brand, the interactive layer) */
      --d6-citron:#C4D809;
      --d6-citron-2:#D6E85C;
      --d6-citron-deep:#8FA000;
      --d6-olive:#6B7A00;
      --d6-citron-tint:rgba(196,216,9,.06);
      /* SECONDARY metallic: gilt art-deco linework only, no longer the star */
      --d6-brass:#C9A24B;
      --d6-brass-2:#E4C97F;
      --d6-brass-deep:#9C7A31;
      --d6-cream:#EFE7D3;
      --d6-cream-dim:#CFC7B2;
      --d6-cream-soft:#9FA79C;
      --d6-hair:rgba(201,162,75,.30);
      --d6-hair-2:rgba(201,162,75,.55);
      --d6-hair-soft:rgba(239,231,211,.10);

      --d6-display:'Bodoni Moda','Didot',Georgia,'Times New Roman',serif;
      --d6-sans:'Jost',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;

      /* fluid type: spaces around every +/- (KIT rule) */
      --d6-s--1: clamp(0.8rem, 0.76rem + 0.18vw, 0.9rem);
      --d6-s-0:  clamp(1rem, 0.95rem + 0.22vw, 1.12rem);
      --d6-s-1:  clamp(1.2rem, 1.05rem + 0.6vw, 1.55rem);
      --d6-s-2:  clamp(1.6rem, 1.25rem + 1.6vw, 2.5rem);
      --d6-s-3:  clamp(2.2rem, 1.5rem + 3.3vw, 4rem);
      --d6-s-4:  clamp(2.9rem, 1.5rem + 6.5vw, 6.4rem);
      --d6-s-5:  clamp(3.6rem, 1rem + 11vw, 9rem);

      --d6-gutter: clamp(1.15rem, 0.7rem + 2vw, 2.75rem);
      --d6-maxw:1240px;
      --d6-measure:62ch;

      --d6-t-fast:180ms;
      --d6-t-med:360ms;
      --d6-t-slow:680ms;
      --d6-ease:cubic-bezier(0.22, 1, 0.36, 1);

      margin:0;
      background:var(--d6-bg);
      color:var(--d6-cream-dim);
      font-family:var(--d6-sans);
      font-size:var(--d6-s-0);
      font-weight:300;
      line-height:1.72;
      letter-spacing:0.01em;
      -webkit-font-smoothing:antialiased;
      text-rendering:optimizeLegibility;
      overflow-x:hidden;
    }
    .d6 *,.d6 *::before,.d6 *::after{ box-sizing:border-box; }
    .d6-html{ -webkit-text-size-adjust:100%; scroll-behavior:smooth; background:#0C1414; }
    .d6 img,.d6 svg,.d6 canvas{ display:block; max-width:100%; }
    .d6 a{ color:inherit; text-decoration:none; }
    .d6 button{ font-family:inherit; }
    .d6 ul,.d6 ol{ margin:0; padding:0; list-style:none; }
    .d6 h1,.d6 h2,.d6 h3,.d6 h4{
      font-family:var(--d6-display); font-weight:500; margin:0;
      line-height:1.04; color:var(--d6-cream); letter-spacing:0.005em;
    }
    .d6 :where(a,button,input,textarea,select,[tabindex]):focus-visible{
      outline:2px solid var(--d6-citron); outline-offset:3px; border-radius:1px;
    }
    .d6 ::selection{ background:var(--d6-citron); color:#0C1414; }

    .d6-sr{ position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; }
    .d6-wrap{ width:100%; max-width:var(--d6-maxw); margin-inline:auto; padding-inline:var(--d6-gutter); }

    .d6-skip{ position:absolute; left:-999px; top:0; background:var(--d6-citron); color:#0C1414; padding:12px 20px; z-index:1400; font-weight:600; letter-spacing:0.1em; }
    .d6-skip:focus{ left:12px; top:12px; }

    /* --- kicker / eyebrow --- */
    .d6-kicker{
      font-family:var(--d6-sans); font-weight:500; font-size:var(--d6-s--1);
      letter-spacing:0.42em; text-transform:uppercase; color:var(--d6-citron);
      display:inline-flex; align-items:center; gap:0.9em; margin:0;
    }
    .d6-kicker::before{ content:""; width:2.2em; height:1px; background:linear-gradient(90deg, transparent, var(--d6-citron)); }
    .d6-kicker--center{ justify-content:center; }
    .d6-kicker--center::after{ content:""; width:2.2em; height:1px; background:linear-gradient(90deg, var(--d6-citron), transparent); }

    /* --- buttons --- */
    .d6-btn{
      display:inline-flex; align-items:center; justify-content:center; gap:0.7em;
      min-height:54px; padding:0 1.9em;
      background:transparent; color:var(--d6-citron);
      font-family:var(--d6-sans); font-weight:500; font-size:var(--d6-s--1);
      letter-spacing:0.28em; text-transform:uppercase;
      border:1px solid var(--d6-citron); border-radius:0;
      cursor:pointer; position:relative; overflow:hidden; isolation:isolate;
      transition:color var(--d6-t-med) var(--d6-ease), border-color var(--d6-t-med);
    }
    .d6-btn::before{
      content:""; position:absolute; inset:0; z-index:-1;
      background:var(--d6-citron); transform:scaleY(0); transform-origin:bottom;
      transition:transform var(--d6-t-med) var(--d6-ease);
    }
    .d6-btn:hover{ color:#0C1414; }
    .d6-btn:hover::before{ transform:scaleY(1); }
    .d6-btn--sm{ min-height:44px; padding:0 1.3em; letter-spacing:0.2em; }
    .d6-btn--solid{ background:var(--d6-citron); color:#0C1414; font-weight:600; }
    .d6-btn--solid::before{ background:var(--d6-citron-2); }
    .d6-btn--ghost{ border-color:var(--d6-hair-2); color:var(--d6-cream); }
    .d6-btn--ghost::before{ background:var(--d6-citron); }
    .d6-btn--ghost:hover{ color:#0C1414; border-color:var(--d6-citron); }

    /* --- section rhythm --- */
    .d6-section{ padding-block: clamp(3.8rem, 2.4rem + 6vw, 7.5rem); position:relative; }
    .d6-section--tint{ background:var(--d6-bg-2); }
    .d6-section--deep{ background:var(--d6-panel); }

    /* --- deco divider (double gold rule with diamond) --- */
    .d6-div{ display:flex; align-items:center; justify-content:center; gap:1rem; color:var(--d6-brass); }
    .d6-div::before,.d6-div::after{ content:""; height:1px; flex:1; max-width:180px; background:linear-gradient(90deg, transparent, var(--d6-hair-2)); }
    .d6-div::after{ background:linear-gradient(90deg, var(--d6-hair-2), transparent); }
    .d6-div__gem{ width:9px; height:9px; border:1px solid var(--d6-brass); transform:rotate(45deg); }

    /* --- section header --- */
    .d6-sechead{ display:flex; flex-direction:column; gap:1.1rem; }
    .d6-sechead__title{ font-size:var(--d6-s-3); }
    .d6-sechead__lead{ color:var(--d6-cream-dim); max-width:var(--d6-measure); font-size:var(--d6-s-1); font-weight:300; }

    /* --- stat figure (shared across pages) --- */
    .d6-stat__n{ font-family:var(--d6-display); font-weight:500; font-size:var(--d6-s-3); color:var(--d6-citron); line-height:1; }
    .d6-stat__l{ font-size:0.78rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--d6-cream-soft); margin-top:8px; }

    /* --- framed image (brass border, inner hairline) --- */
    .d6-frame{ position:relative; overflow:hidden; background:var(--d6-bg-3); }
    .d6-frame img{ width:100%; height:100%; object-fit:cover; filter:saturate(.9) contrast(1.02) brightness(.9); transition:transform var(--d6-t-slow) var(--d6-ease), filter var(--d6-t-slow) var(--d6-ease); }
    .d6-frame::after{ content:""; position:absolute; inset:10px; border:1px solid var(--d6-hair); pointer-events:none; z-index:2; }
    .d6-frame::before{ content:""; position:absolute; inset:0; z-index:1; pointer-events:none;
      background:linear-gradient(180deg, rgba(12,20,20,.08), rgba(12,20,20,.5)); }
    .d6-frame:hover img{ transform:scale(1.04); filter:saturate(1) contrast(1.04) brightness(.98); }

    /* --- reveal + kinetic --- */
    .d6-rv{ opacity:0; transform:translateY(22px); transition:opacity var(--d6-t-slow) var(--d6-ease), transform var(--d6-t-slow) var(--d6-ease); }
    .d6-rv.is-in{ opacity:1; transform:none; }
    .d6-rv[data-delay="1"]{ transition-delay:90ms; }
    .d6-rv[data-delay="2"]{ transition-delay:180ms; }
    .d6-rv[data-delay="3"]{ transition-delay:270ms; }
    .d6-rv[data-delay="4"]{ transition-delay:360ms; }
    .d6-rv[data-delay="5"]{ transition-delay:450ms; }

    /* kinetic deco heading: letters rise + settle */
    .d6-kin{ display:inline-block; }
    .d6-kin__l{ display:inline-block; opacity:0; transform:translateY(0.5em) rotate(4deg); transition:opacity var(--d6-t-slow) var(--d6-ease), transform var(--d6-t-slow) var(--d6-ease); }
    .d6-kin__l--space{ width:0.28em; }
    .d6-kin.is-in .d6-kin__l{ opacity:1; transform:none; }

    /* sunburst draw-on-reveal (stroke-dashoffset) */
    .d6-sun path,.d6-sun line,.d6-sun circle{ stroke-dasharray:1; stroke-dashoffset:1; transition:stroke-dashoffset 1.5s var(--d6-ease); }
    .d6-sun.is-in path,.d6-sun.is-in line,.d6-sun.is-in circle{ stroke-dashoffset:0; }

    /* ===================== NAV ===================== */
    .d6-nav{ position:sticky; top:0; z-index:1000; background:rgba(12,20,20,.86); backdrop-filter:blur(10px); transition:background var(--d6-t-med), box-shadow var(--d6-t-med); }
    .d6-nav:not([data-at-top]){ background:rgba(9,17,16,.96); box-shadow:0 10px 40px -24px rgba(0,0,0,.9); }
    .d6-nav__rule{ height:2px; background:linear-gradient(90deg, transparent, var(--d6-brass) 20%, var(--d6-brass) 80%, transparent); opacity:.8; }
    .d6-nav__rule--hair{ height:1px; background:var(--d6-hair); opacity:.5; }
    .d6-nav__bar{ display:flex; align-items:center; justify-content:space-between; gap:1.4rem; height:76px; }
    .d6-brand{ display:flex; align-items:center; gap:12px; }
    .d6-brand__word{ display:flex; flex-direction:column; line-height:1; }
    /* faithful lowercase "citron" wordmark, cream on dark, with the citron-green ring "o" */
    .d6-brand__name{ font-family:var(--d6-sans); font-weight:400; font-size:1.62rem; color:var(--d6-cream); letter-spacing:0.01em; line-height:1; display:inline-flex; align-items:baseline; }
    .d6-brand__o{ display:inline-block; width:0.62em; height:0.62em; margin:0 0.015em; border-radius:50%; border:0.13em solid var(--d6-citron); position:relative; transform:translateY(0.02em); transition:transform var(--d6-t-slow) var(--d6-ease), border-color var(--d6-t-med); }
    .d6-brand__o::after{ content:""; position:absolute; top:-0.08em; right:-0.02em; width:0.2em; height:0.2em; border-radius:50%; background:var(--d6-citron); }
    .d6-brand:hover .d6-brand__o{ transform:translateY(0.02em) rotate(45deg); }
    .d6-brand__sub{ font-family:var(--d6-sans); font-weight:500; font-size:0.54rem; letter-spacing:0.36em; text-transform:uppercase; color:var(--d6-citron); margin-top:6px; }
    .d6-nav__links{ display:flex; align-items:center; gap:30px; }
    .d6-nav__link{ font-family:var(--d6-sans); font-weight:400; font-size:0.72rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--d6-cream-dim); padding:8px 0; position:relative; transition:color var(--d6-t-fast); }
    .d6-nav__link::after{ content:""; position:absolute; left:50%; right:50%; bottom:0; height:1px; background:var(--d6-citron); transition:left var(--d6-t-med) var(--d6-ease), right var(--d6-t-med) var(--d6-ease); }
    .d6-nav__link:hover{ color:var(--d6-cream); }
    .d6-nav__link:hover::after,.d6-nav__link.is-current::after{ left:0; right:0; }
    .d6-nav__link.is-current{ color:var(--d6-citron); }
    .d6-nav__actions{ display:flex; align-items:center; gap:14px; }
    .d6-burger{ display:none; width:46px; height:46px; background:none; border:1px solid var(--d6-hair-2); border-radius:0; cursor:pointer; flex-direction:column; align-items:center; justify-content:center; gap:5px; }
    .d6-burger span{ width:20px; height:1px; background:var(--d6-citron); transition:transform var(--d6-t-fast), opacity var(--d6-t-fast); }
    .d6-burger[aria-expanded="true"] span:nth-child(1){ transform:translateY(6px) rotate(45deg); }
    .d6-burger[aria-expanded="true"] span:nth-child(2){ opacity:0; }
    .d6-burger[aria-expanded="true"] span:nth-child(3){ transform:translateY(-6px) rotate(-45deg); }

    .d6-drawer{ overflow:hidden; background:var(--d6-panel); border-bottom:1px solid var(--d6-hair); }
    .d6-drawer nav{ display:flex; flex-direction:column; padding:8px var(--d6-gutter) 22px; }
    .d6-drawer__link{ padding:15px 2px; font-family:var(--d6-sans); font-weight:400; font-size:0.95rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--d6-cream); border-bottom:1px solid var(--d6-hair-soft); }
    .d6-drawer__link--muted{ color:var(--d6-citron); }
    .d6-drawer__cta{ margin-top:18px; }

    @media (max-width:1000px){
      .d6-nav__links,.d6-nav__actions .d6-btn{ display:none; }
      .d6-burger{ display:flex; }
    }

    /* ===================== FOOTER ===================== */
    .d6-foot{ background:var(--d6-panel); padding-bottom:2.4rem; position:relative; border-top:2px solid var(--d6-brass-deep); }
    .d6-foot__crest{ display:flex; justify-content:center; color:var(--d6-brass); padding-top:2.4rem; opacity:.85; }
    .d6-foot__grid{ display:grid; grid-template-columns:1.7fr 1fr 1fr 1.2fr; gap:clamp(1.6rem, 0.8rem + 3vw, 3.6rem); padding-top:clamp(2rem, 1.4rem + 2vw, 3rem); }
    .d6-foot__word{ display:inline-flex; align-items:baseline; gap:0.45rem; }
    .d6-foot__logo{ font-family:var(--d6-sans); font-weight:400; font-size:1.95rem; color:var(--d6-cream); letter-spacing:0.01em; display:inline-flex; align-items:baseline; }
    .d6-foot__word em{ font-family:var(--d6-display); font-style:italic; font-weight:500; font-size:1.55rem; color:var(--d6-citron); }
    .d6-foot__blurb{ color:var(--d6-cream-soft); font-size:var(--d6-s--1); max-width:42ch; margin:0.9em 0 1.6em; line-height:1.8; }
    .d6-foot__news .d6-kicker{ margin-bottom:0.9em; }
    .d6-foot__form{ display:flex; gap:8px; max-width:380px; }
    .d6-foot__form input{ flex:1; min-height:48px; padding:0 14px; background:rgba(239,231,211,.03); border:1px solid var(--d6-hair); border-radius:0; color:var(--d6-cream); font-family:var(--d6-sans); }
    .d6-foot__form input::placeholder{ color:var(--d6-cream-soft); }
    .d6-foot__form input:focus{ border-color:var(--d6-citron); outline:none; }
    .d6-foot__note{ font-size:0.78rem; color:var(--d6-cream-soft); margin:0.9em 0 0; }
    .d6-foot__note.is-ok{ color:var(--d6-citron); }
    .d6-foot__h{ font-family:var(--d6-sans); font-weight:500; font-size:0.64rem; letter-spacing:0.32em; text-transform:uppercase; color:var(--d6-citron); margin-bottom:1.2em; padding-bottom:0.8em; border-bottom:1px solid var(--d6-hair); }
    .d6-foot__col{ display:flex; flex-direction:column; }
    .d6-foot__link{ display:inline-flex; align-items:center; min-height:38px; color:var(--d6-cream-dim); font-size:var(--d6-s--1); padding:3px 0; transition:color var(--d6-t-fast), padding-left var(--d6-t-fast); }
    .d6-foot__link:hover{ color:var(--d6-citron); padding-left:6px; }
    .d6-foot__addr{ font-style:normal; color:var(--d6-cream-dim); font-size:var(--d6-s--1); line-height:1.95; }
    .d6-foot__hours{ color:var(--d6-cream-soft); font-size:0.8rem; margin-top:1.1em; line-height:1.8; }
    .d6-foot__bottom{ display:flex; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-top:clamp(2.4rem, 1.4rem + 3vw, 3.6rem); padding-top:1.6rem; border-top:1px solid var(--d6-hair-soft); font-size:0.74rem; color:var(--d6-cream-soft); letter-spacing:0.04em; }
    .d6-foot__award{ color:var(--d6-brass); }
    @media (max-width:900px){ .d6-foot__grid{ grid-template-columns:1fr 1fr; } }
    @media (max-width:560px){ .d6-foot__grid{ grid-template-columns:1fr; } }

    /* ===================== CTA MODAL ===================== */
    .d6-modal{ position:fixed; inset:0; z-index:1300; display:grid; place-items:center; padding:22px; }
    .d6-modal[hidden]{ display:none; }
    .d6-modal__scrim{ position:absolute; inset:0; background:rgba(6,11,11,.78); backdrop-filter:blur(5px); opacity:0; transition:opacity var(--d6-t-med) var(--d6-ease); }
    .d6-modal.is-open .d6-modal__scrim{ opacity:1; }
    .d6-modal__panel{ position:relative; width:min(560px,100%);
      background:linear-gradient(180deg, var(--d6-bg-2), var(--d6-panel));
      border:1px solid var(--d6-brass); border-radius:0;
      padding:clamp(1.8rem, 1.2rem + 2.4vw, 2.8rem);
      box-shadow:0 40px 120px -30px rgba(0,0,0,.85), inset 0 0 0 6px rgba(201,162,75,.06);
      transform:translateY(18px) scale(.98); opacity:0;
      transition:transform var(--d6-t-med) var(--d6-ease), opacity var(--d6-t-med) var(--d6-ease); }
    .d6-modal.is-open .d6-modal__panel{ transform:none; opacity:1; }
    .d6-modal__fan{ position:absolute; width:38px; height:38px; pointer-events:none; }
    .d6-modal__fan::before,.d6-modal__fan::after{ content:""; position:absolute; background:var(--d6-brass); }
    .d6-modal__fan--tl{ top:12px; left:12px; border-top:1px solid var(--d6-brass); border-left:1px solid var(--d6-brass); }
    .d6-modal__fan--br{ bottom:12px; right:12px; border-bottom:1px solid var(--d6-brass); border-right:1px solid var(--d6-brass); }
    .d6-modal__fan::before{ width:1px; height:14px; top:0; left:0; }
    .d6-modal__fan--br::before{ top:auto; bottom:0; left:auto; right:0; }
    .d6-modal__fan::after{ height:1px; width:14px; top:0; left:0; }
    .d6-modal__fan--br::after{ top:auto; bottom:0; left:auto; right:0; }
    .d6-modal__close{ position:absolute; top:14px; right:14px; width:44px; height:44px; display:grid; place-items:center; background:none; border:none; color:var(--d6-cream-soft); cursor:pointer; transition:color var(--d6-t-fast), transform var(--d6-t-fast); z-index:3; }
    .d6-modal__close:hover{ color:var(--d6-citron); transform:rotate(90deg); }
    .d6-modal__title{ font-size:var(--d6-s-2); text-align:center; margin:0.6em 0 0.5em; }
    .d6-modal__rule{ display:flex; justify-content:center; margin:0 auto 1.2em; width:70px; height:1px; background:linear-gradient(90deg, transparent, var(--d6-brass), transparent); }
    .d6-modal__grid{ display:flex; flex-direction:column; }
    .d6-choice{ display:flex; align-items:center; gap:18px; padding:18px 6px; border-top:1px solid var(--d6-hair-soft); transition:background var(--d6-t-med), padding-left var(--d6-t-fast); }
    .d6-choice:last-child{ border-bottom:1px solid var(--d6-hair-soft); }
    .d6-choice:hover{ background:var(--d6-citron-tint); padding-left:14px; }
    .d6-choice__no{ font-family:var(--d6-display); font-weight:500; font-size:1.2rem; color:var(--d6-brass); flex:none; width:2em; text-align:center; letter-spacing:0.05em; }
    .d6-choice--feature .d6-choice__no{ color:var(--d6-citron); }
    .d6-choice__body{ display:flex; flex-direction:column; gap:3px; flex:1; }
    .d6-choice__k{ font-family:var(--d6-display); font-weight:500; font-size:var(--d6-s-1); color:var(--d6-cream); line-height:1.1; }
    .d6-choice__d{ font-size:var(--d6-s--1); color:var(--d6-cream-soft); }
    .d6-choice__arrow{ color:var(--d6-cream-soft); font-size:1.2rem; transition:transform var(--d6-t-fast) var(--d6-ease), color var(--d6-t-fast); }
    .d6-choice:hover .d6-choice__arrow{ transform:translateX(6px); color:var(--d6-citron); }

    /* ===================== MOTION GUARD ===================== */
    @media (prefers-reduced-motion: reduce){
      .d6-html{ scroll-behavior:auto; }
      .d6 *,.d6 *::before,.d6 *::after{ animation-duration:.001ms !important; animation-iteration-count:1 !important; transition-duration:.001ms !important; }
      .d6-rv,.d6-kin__l{ opacity:1; transform:none; }
      .d6-sun path,.d6-sun line,.d6-sun circle{ stroke-dashoffset:0; }
    }
  </style>

  <script>
    // reveal + sunburst draw + kinetic headings (IntersectionObserver, no rAF loop)
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els = document.querySelectorAll('.d6-rv, .d6-sun, .d6-kin');
    if (els.length){
      if (!('IntersectionObserver' in window) || reduce){
        els.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((en) => { if (en.isIntersecting){ en.target.classList.add('is-in'); io.unobserve(en.target); } });
        }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
      }
    }

    // count-up numbers on reveal
    document.querySelectorAll('[data-count]').forEach((el) => {
      const raw = el.getAttribute('data-count');
      const num = parseFloat(raw.replace(/[^0-9.]/g, ''));
      const prefix = raw.startsWith('~') ? '~' : '';
      const hasComma = raw.includes(',');
      if (reduce || !('IntersectionObserver' in window) || isNaN(num)){ el.textContent = raw; return; }
      el.textContent = prefix + '0';
      const io = new IntersectionObserver((ents) => {
        ents.forEach((en) => {
          if (!en.isIntersecting) return; io.unobserve(el);
          const dur = 1300, t0 = performance.now();
          const tick = (t) => {
            const p = Math.min((t - t0) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            const v = Math.round(num * eased);
            el.textContent = prefix + (hasComma ? v.toLocaleString('en-US') : String(v));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.5 });
      io.observe(el);
    });

    // nav: solid-on-scroll
    const nav = document.getElementById('d6-nav');
    if (nav){
      const onScroll = () => { if (window.scrollY > 24) nav.removeAttribute('data-at-top'); else nav.setAttribute('data-at-top',''); };
      window.addEventListener('scroll', onScroll, { passive: true }); onScroll();
    }

    // mobile drawer
    const burger = document.getElementById('d6-burger');
    const drawer = document.getElementById('d6-drawer');
    const setOpen = (open) => {
      if (!burger || !drawer) return;
      burger.setAttribute('aria-expanded', String(open));
      if (open){ drawer.hidden = false; } else { setTimeout(() => { drawer.hidden = true; }, 10); }
    };
    burger?.addEventListener('click', () => setOpen(burger.getAttribute('aria-expanded') !== 'true'));
    drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));

    // newsletter
    const nf = document.getElementById('d6-news');
    nf?.addEventListener('submit', (e) => {
      e.preventDefault();
      const note = document.getElementById('d6-news-note');
      if (note){ note.textContent = 'Welcome to the guest list. Watch for our first note soon.'; note.classList.add('is-ok'); }
      nf.reset();
    });

    // CTA modal (focus trap + Escape + scrim)
    const modal = document.getElementById('d6-modal');
    if (modal){
      let lastFocus = null;
      const open = () => {
        lastFocus = document.activeElement;
        modal.hidden = false;
        requestAnimationFrame(() => modal.classList.add('is-open'));
        document.documentElement.style.overflow = 'hidden';
        const first = modal.querySelector('.d6-choice');
        if (first) first.focus();
      };
      const close = () => {
        modal.classList.remove('is-open');
        document.documentElement.style.overflow = '';
        const done = () => { modal.hidden = true; modal.removeEventListener('transitionend', done); };
        modal.addEventListener('transitionend', done);
        if (lastFocus && lastFocus.focus) lastFocus.focus();
      };
      document.addEventListener('click', (e) => {
        const trigger = e.target.closest('[data-cta]');
        if (trigger){ e.preventDefault(); open(); return; }
        if (e.target.closest('[data-cta-close]')){ close(); }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.hidden) close();
        if (e.key === 'Tab' && !modal.hidden){
          const f = modal.querySelectorAll('a[href],button:not([disabled])');
          if (!f.length) return;
          const first = f[0], last = f[f.length - 1];
          if (e.shiftKey && document.activeElement === first){ e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && document.activeElement === last){ e.preventDefault(); first.focus(); }
        }
      });
    }
  </script>
</body>
</html>
